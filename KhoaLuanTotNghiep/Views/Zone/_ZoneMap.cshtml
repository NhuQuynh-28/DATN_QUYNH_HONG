<h2 style="display:flex; align-items:center; gap:8px; margin-bottom:16px; font-size:22px;">
    <i class="fas fa-map-marked-alt" style="color:#3b82f6"></i>
    Bản đồ khu vực : 
    <span style="color:#60a5fa">@ViewBag.AreaName</span>
    <span style="color:#94a3b8; font-size:18px;">&gt;</span>
    <span style="color:#f59e0b">@ViewBag.VersionName</span>
</h2>

<div id="map" style="width:100%; height:650px;"></div>

<div id="matrixResult" style="
margin-top:20px;
background:white;
color:black;
padding:10px;
border-radius:8px;
"></div>