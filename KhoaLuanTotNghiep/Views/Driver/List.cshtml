                        <i class="fas fa-edit"></i>
                    </button>
                </td>
            </tr>
            <tr id="evalDetail-${i}" style="display:none">
                <td colspan="11" style="padding:0">
                    <table style="width:100%;border-collapse:collapse;background:#0d111c">
                        <thead><tr style="background:#0a0f1a">
                            <th colspan="2" style="padding:8px 14px;color:#475569;font-size:10px;text-align:left">VÙNG</th>
                            <th style="padding:8px;color:#475569;font-size:10px">ĐƠN DK</th>
                            <th style="padding:8px;color:#475569;font-size:10px">ĐƠN TT</th>
                            <th style="padding:8px;color:#475569;font-size:10px">KH DK</th>
                            <th style="padding:8px;color:#475569;font-size:10px">KH TT</th>
                            <th style="padding:8px;color:#475569;font-size:10px">CHÊNH LỆCH</th>
                            <th colspan="4"></th>
                        </tr></thead>
                        <tbody>${zoneRows || '<tr><td colspan="11" style="padding:12px;color:#475569;text-align:center;font-size:11px">Không có dữ liệu vùng</td></tr>'}</tbody>
                    </table>
                </td>
            </tr>`;
        }).join('');

        document.getElementById('evalDrivers').innerHTML = `
            <div class="dm-table-wrap">
                <table class="dm-table">
                    <thead><tr>
                        <th>#</th>
                        <th>Tài xế</th>
                        <th title="Đơn hàng dự kiến">Đơn DK</th>
                        <th title="Đơn hàng thực tế">Đơn TT</th>
                        <th title="Khách hàng dự kiến">KH DK</th>
                        <th title="Khách hàng thực tế">KH TT</th>
                        <th>Hao hụt</th>
                        <th title="Tổng khoảng cách tới tâm">Nhỏ gọn</th>
                        <th>Cân bằng</th>
                        <th>vs T${data.prevMonth}</th>
                        <th></th>
                    </tr></thead>
                    <tbody>${driverRows}</tbody>
                </table>
            </div>
        `;

        document.getElementById('statAssignMonth').textContent = s.totalDrivers;
    })
    .catch(err => {
        console.error(err);
        showToast('Lỗi khi tải dữ liệu đánh giá!', 'error');
    });
}

function toggleEvalDetail(idx) {
    let el = document.getElementById('evalDetail-' + idx);
    if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
}

function openActualModal(driverId, driverName, curOrders, curCustomers) {
    let ov = document.getElementById('driverOverlay');
    document.getElementById('modalTitle').innerHTML = `<i class="fas fa-clipboard-check" style="color:#4ade80"></i> Nhập thực tế — ${driverName}`;
    ov.querySelector('.dm-modal').innerHTML = `
        <h3 id="modalTitle"><i class="fas fa-clipboard-check" style="color:#4ade80"></i> Nhập số liệu thực tế — ${driverName}</h3>
        <div class="dm-field">
            <label>Đơn hàng thực tế</label>
            <input class="dm-input" id="actualOrders" type="number" value="${curOrders}" min="0">
        </div>
        <div class="dm-field">
            <label>Khách hàng thực tế</label>
            <input class="dm-input" id="actualCustomers" type="number" value="${curCustomers}" min="0">
        </div>
        <div class="dm-modal-footer">
            <button class="dm-btn-cancel" onclick="closeDriverModal()">Hủy</button>
            <button class="dm-btn-save" onclick="saveActualData(${driverId})"><i class="fas fa-save"></i> Lưu</button>
        </div>
    `;
    ov.classList.add('open');
}

function saveActualData(driverId) {
    let m = document.getElementById('mf-month').value;
    let y = document.getElementById('mf-year').value;
    let a = document.getElementById('mf-area').value;
    let actualOrders = parseInt(document.getElementById('actualOrders').value) || 0;
    let actualCustomers = parseInt(document.getElementById('actualCustomers').value) || 0;

    // Find assignment ID first
    fetch(`/Driver/GetByMonth?month=${m}&year=${y}&areaId=${a}`)
    .then(r => r.json())
    .then(data => {
        let assignment = data.find(x => x.id);
        // Find the correct assignment by matching driverId through the evaluation data
        fetch(`/Driver/GetAssignmentEvaluation?month=${m}&year=${y}&areaId=${a}`)
        .then(r => r.json())
        .then(evalData => {
            let driver = (evalData.drivers || []).find(d => d.driverId === driverId);
            if (!driver) { showToast('Không tìm thấy phân công!', 'error'); return; }

            // Get the assignment from GetByMonth by matching
            let matched = data.find(x => x.driverName === driver.driverName);
            if (!matched) { showToast('Không tìm thấy phân công!', 'error'); return; }

            fetch('/Driver/UpdateActual', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: matched.id, actualOrders, actualCustomers })
            })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    closeDriverModal();
                    showToast('Đã cập nhật số liệu thực tế!', 'success');
                    loadEvaluation();
                } else {
                    showToast(d.message || 'Lỗi cập nhật!', 'error');
                }
            });
        });
    });
}

/* ===== DRIVER MODAL ===== */
function openDriverModal() {
    document.getElementById('modalTitle').innerHTML = '<i class="fas fa-user-plus" style="color:#3b82f6"></i> Thêm tài xế';
    document.getElementById('editId').value = '';
    document.getElementById('f-name').value = '';
    document.getElementById('f-phone').value = '';
    document.getElementById('f-status').value = 'DangLam';
    document.getElementById('driverOverlay').classList.add('open');
    setTimeout(() => document.getElementById('f-name').focus(), 100);
}
function editDriver(id, name, phone, status) {
    document.getElementById('modalTitle').innerHTML = '<i class="fas fa-pen" style="color:#f59e0b"></i> Chỉnh sửa tài xế';
    document.getElementById('editId').value = id;
    document.getElementById('f-name').value = name;
    document.getElementById('f-phone').value = phone;
    document.getElementById('f-status').value = status;
    document.getElementById('driverOverlay').classList.add('open');
}
function closeDriverModal() {
    document.getElementById('driverOverlay').classList.remove('open');
}
function saveDriver() {
    let id     = document.getElementById('editId').value;
    let name   = document.getElementById('f-name').value.trim();
    let phone  = document.getElementById('f-phone').value.trim();
    let status = document.getElementById('f-status').value;

    if (!name) { showToast('Vui lòng nhập họ tên tài xế!', 'error'); return; }

    let url    = id ? '/Driver/Update' : '/Driver/Create';
    let body   = id ? { id: parseInt(id), driverName: name, phone, status }
                    : { driverName: name, phone, status };

    fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) })
    .then(r => r.json())
    .then(d => {
        if (d.success) {
            closeDriverModal();
            showToast(id ? 'Đã cập nhật tài xế!' : 'Đã thêm tài xế mới!', 'success');
            loadPage('/Driver/List');
        } else {
            showToast(d.message || 'Có lỗi xảy ra!', 'error');
        }
    })
    .catch(() => showToast('Lỗi kết nối server!', 'error'));
}
function deleteDriver(id) {
    if (!confirm('Xác nhận xóa tài xế này?')) return;
    fetch('/Driver/Delete', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:'id='+id })
    .then(r => r.json())
    .then(d => {
        if (d.success) { showToast('Đã xóa tài xế!', 'info'); loadPage('/Driver/List'); }
        else showToast(d.message || 'Không thể xóa!', 'error');
    });
}

// Keyboard shortcuts
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDriverModal();
    if (e.key === 'Enter' && document.getElementById('driverOverlay').classList.contains('open')) saveDriver();
});

/* ===== SWITCH TAB (override - 3 tabs) ===== */
function switchTab(tab) {
    document.querySelectorAll('.dm-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.dm-panel').forEach(p => p.classList.remove('active'));
    let tabEl   = document.getElementById('tab-' + tab);
    let panelEl = document.getElementById('panel-' + tab);
    if (tabEl)   tabEl.classList.add('active');
    if (panelEl) panelEl.classList.add('active');
    if (tab === 'month')  loadEvaluation();
    if (tab === 'detail') loadDetailData();
}

/* ===== LOAD DETAIL DATA ===== */
function loadDetailData() {
    let driver = document.getElementById('df-driver')?.value || '';
    let area   = document.getElementById('df-area')?.value   || '';
    let status = document.getElementById('df-status')?.value || '';

    let url = `/Driver/GetAllAssignments?driverName=${encodeURIComponent(driver)}&areaId=${area}&status=${status}`;

    fetch(url)
    .then(r => r.json())
    .then(data => {
        // Summary cards
        let total   = data.length;
        let ok      = data.filter(x => x.isOk).length;
        let fail    = total - ok;
        let sumPlan = data.reduce((s, x) => s + x.plannedOrders, 0);
        let sumAct  = data.reduce((s, x) => s + x.actualOrders, 0);
        let rate    = total > 0 ? Math.round(ok / total * 100) : 0;

        document.getElementById('detailSummary').innerHTML = `
            <div class="dm-mstat" style="--c:#3b82f6"><div class="mv">${total}</div><div class="ml">Tổng phân công</div></div>
            <div class="dm-mstat" style="--c:#4ade80"><div class="mv">${ok}</div><div class="ml">Đạt chỉ tiêu</div></div>
            <div class="dm-mstat" style="--c:#f87171"><div class="mv">${fail}</div><div class="ml">Chưa đạt</div></div>
            <div class="dm-mstat" style="--c:#f59e0b"><div class="mv">${sumPlan}</div><div class="ml">Tổng đơn dự kiến</div></div>
            <div class="dm-mstat" style="--c:#4ade80"><div class="mv">${sumAct}</div><div class="ml">Tổng đơn thực tế</div></div>
            <div class="dm-mstat" style="--c:${rate>=80?'#4ade80':rate>=50?'#f59e0b':'#f87171'}">
                <div class="mv">${rate}%</div><div class="ml">Tỉ lệ hoàn thành</div>
            </div>
        `;

        // Table
        let tbody = document.getElementById('detailTbody');
        if (!data.length) {
            tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:40px;color:#475569">
                <i class="fas fa-inbox" style="font-size:28px;display:block;margin-bottom:10px"></i>
                Không có dữ liệu phân công phù hợp
            </td></tr>`;
            return;
        }
        tbody.innerHTML = data.map((a, i) => {
            let pct   = a.plannedOrders > 0 ? Math.min(100, Math.round(a.actualOrders / a.plannedOrders * 100)) : 0;
            let color = a.isOk ? '#4ade80' : '#f87171';
            let icon  = a.isOk ? '✅' : '❌';
            let zoneIds = a.zoneIds || '';
            return `<tr onclick="previewAssignmentOnMap('${zoneIds}', '${a.driverName}')" style="cursor:pointer">
                <td style="color:#475569;font-weight:700">${i+1}</td>
                <td>
                    <div style="font-weight:700;color:#f1f5f9">${icon} ${a.driverName}</div>
                    <div style="font-size:11px;color:#475569">${a.driverPhone}</div>
                </td>
                <td><span class="dm-chip"><i class="fas fa-map-marker-alt"></i> ${a.areaName}</span></td>
                <td style="color:#64748b;font-size:12px">${a.dispatcher || '—'}</td>
                <td style="color:#64748b;font-size:12px">T${a.month}/${a.year}</td>
                <td style="color:#3b82f6;font-weight:700">${a.zoneCount}</td>
                <td style="font-weight:700;color:#60a5fa">${a.plannedOrders}</td>
                <td style="font-weight:700;color:${color}">${a.actualOrders}</td>
                <td>
                    <div class="dm-progress-bar"><div class="dm-progress-fill" style="width:${pct}%;background:${color}"></div></div>
                    <div style="font-size:10px;color:${color};margin-top:3px">${pct}%</div>
                </td>
                <td style="font-size:12px;color:#64748b">${a.date}</td>
            </tr>`;
        }).join('');
    })
    .catch(() => showToast('Lỗi khi tải dữ liệu phân công!', 'error'));
}

function clearDetailFilter() {
    document.getElementById('df-driver').value = '';
    document.getElementById('df-area').value   = '';
    document.getElementById('df-status').value = '';
    loadDetailData();
}

/* ===== MAP LOGIC ===== */
let dmMap = null;
let dmPolygons = [];
let dmMarkers = [];

function initDmMap() {
    if (dmMap) return;
    dmMap = L.map('dmMap').setView([21.0285, 105.8542], 11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap contributors'
    }).addTo(dmMap);
}

function previewAssignmentOnMap(zoneIds, driverName) {
    if (!zoneIds) {
        dpToast('Tài xế này không có vùng phân công cụ thể!', 'info');
        return;
    }
    
    initDmMap();
    if(dmMap) {
        dmMap.invalidateSize();
    }

    // Clear old layers
    dmPolygons.forEach(p => dmMap.removeLayer(p));
    dmMarkers.forEach(m => dmMap.removeLayer(m));
    dmPolygons = [];
    dmMarkers = [];

    document.getElementById('dmMapTitle').innerHTML = `Đang xem các vùng của: <b style="color:#f1f5f9">${driverName}</b>`;

    let idArray = zoneIds.split(',').map(x => x.trim()).filter(x => x);
    let bounds = [];
    
    // Fetch zone geometries
    fetch(`/Dispatcher/GetForecastStatus?month=0&year=0`).then(r=>r.json()).then(data => {
        let allZones = data.zones || [];
        idArray.forEach(zid => {
            let zInfo = allZones.find(x => x.zoneId == zid);
            if(zInfo && zInfo.points) {
                try {
                    let pts = JSON.parse(zInfo.points);
                    let poly = L.polygon(pts, {color: '#3b82f6', weight: 3, fillOpacity: 0.4}).addTo(dmMap);
                    dmPolygons.push(poly);
                    let center = poly.getBounds().getCenter();
                    bounds.push(center);

                    let marker = L.marker(center, {
                        interactive: false,
                        icon: L.divIcon({
                            className: 'zone-label',
                            html: `<div style="background:#2563eb;color:white;padding:2px 6px;border-radius:4px;font-size:10px;font-weight:700;white-space:nowrap;box-shadow:0 2px 6px rgba(0,0,0,.3)">${zInfo.zoneName}</div>`
                        })
                    }).addTo(dmMap);
                    dmMarkers.push(marker);
                    
                    poly.bindTooltip(`${driverName} - ${zInfo.zoneName}`, {sticky:true});
                } catch(e){}
            }
        });

        if(bounds.length) {
            dmMap.fitBounds(bounds, {padding:[50,50]});
        }
        
        // Scroll to map
        document.getElementById('dmMap').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
}
</script>
</script>