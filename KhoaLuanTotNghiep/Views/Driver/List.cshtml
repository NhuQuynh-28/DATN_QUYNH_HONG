@{
    Layout = null;
}
@model List<Driver>
@{
    var assignmentCounts = ViewBag.AssignmentCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var areas = ViewBag.Areas as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    int totalDrivers    = ViewBag.TotalDrivers   ?? 0;
    int activeDrivers   = ViewBag.ActiveDrivers  ?? 0;
    int inactiveDrivers = ViewBag.InactiveDrivers ?? 0;
    int now_month = DateTime.Now.Month;
    int now_year  = DateTime.Now.Year;
}

<style>
/* ===== DRIVER MANAGEMENT ===== */
.dm-wrap { font-family:'Segoe UI',sans-serif; color:#e2e8f0; }

/* STATS */
.dm-stats { display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
.dm-stat {
    background:#1e293b; border:1px solid #334155; border-radius:12px;
    padding:14px 20px; min-width:130px; position:relative; overflow:hidden;
}
.dm-stat::before { content:''; position:absolute; top:0;left:0;right:0; height:3px; background:var(--c,#3b82f6); }
.dm-stat .val { font-size:24px; font-weight:800; color:var(--c,#3b82f6); }
.dm-stat .lbl { font-size:11px; color:#64748b; margin-top:2px; font-weight:600; text-transform:uppercase; }

/* TABS */
.dm-tabs { display:flex; gap:4px; margin-bottom:20px; background:#1e293b; border-radius:10px; padding:4px; width:fit-content; }
.dm-tab {
    padding:8px 20px; border-radius:8px; cursor:pointer; font-size:13px; font-weight:600;
    color:#64748b; transition:all .2s; display:flex; align-items:center; gap:6px; border:none; background:none;
}
.dm-tab.active { background:#3b82f6; color:white; }
.dm-tab:hover:not(.active) { color:#e2e8f0; background:#334155; }

/* PANELS */
.dm-panel { display:none; }
.dm-panel.active { display:block; }

/* TOOLBAR */
.dm-toolbar { display:flex; gap:10px; margin-bottom:16px; flex-wrap:wrap; align-items:center; }
.dm-search { background:#1e293b; border:1px solid #334155; border-radius:8px; padding:8px 12px; color:#f1f5f9; font-size:13px; outline:none; }
.dm-search:focus { border-color:#3b82f6; }
.dm-btn-add { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(135deg,#3b82f6,#2563eb); color:white; border:none; padding:9px 18px; border-radius:9px; font-size:13px; font-weight:700; cursor:pointer; transition:opacity .15s; }
.dm-btn-add:hover { opacity:.88; }

/* TABLE */
.dm-table-wrap { background:#1e293b; border-radius:14px; border:1px solid #334155; overflow:hidden; }
.dm-table { width:100%; border-collapse:collapse; font-size:13px; }
.dm-table thead tr { background:#0f172a; }
.dm-table th { padding:12px 14px; text-align:left; color:#64748b; font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:.04em; border-bottom:1px solid #1e293b55; }
.dm-table tbody tr { border-bottom:1px solid #0f172a44; transition:background .15s; }
.dm-table tbody tr:hover { background:#0f172a66; }
.dm-table td { padding:13px 14px; vertical-align:middle; }

/* DRIVER CELL */
.dm-driver-cell { display:flex; align-items:center; gap:10px; }
.dm-avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#3b82f6,#6366f1); display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; font-weight:700; color:white; }

/* STATUS BADGE */
.dm-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
.dm-badge-active   { background:#16a34a22; color:#4ade80; border:1px solid #16a34a44; }
.dm-badge-inactive { background:#dc262622; color:#f87171; border:1px solid #dc262644; }
.dm-badge-leave    { background:#78716c22; color:#a8a29e; border:1px solid #78716c44; }

/* ASSIGNMENT CHIP */
.dm-chip { display:inline-flex; align-items:center; gap:4px; background:#0f172a; border:1px solid #334155; border-radius:8px; padding:3px 9px; font-size:11px; color:#94a3b8; }

/* ACTIONS */
.dm-acts { display:flex; gap:6px; }
.dm-act { display:inline-flex; align-items:center; gap:4px; padding:6px 11px; border-radius:7px; border:none; font-size:11px; font-weight:700; cursor:pointer; transition:all .15s; }
.dm-act-edit  { background:#1c3d5a; color:#38bdf8; }
.dm-act-edit:hover  { background:#0284c7; color:white; }
.dm-act-del   { background:#3d1c1c; color:#f87171; }
.dm-act-del:hover   { background:#dc2626; color:white; }

/* FILTER BAR (tab month) */
.dm-filter { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; align-items:center; background:#1e293b; border-radius:12px; padding:12px 16px; border:1px solid #334155; }
.dm-filter label { font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; }
.dm-select { background:#0f172a; border:1px solid #334155; border-radius:7px; padding:7px 10px; color:#f1f5f9; font-size:12px; outline:none; }
.dm-select:focus { border-color:#3b82f6; }
.dm-btn-filter { display:inline-flex; align-items:center; gap:6px; background:#334155; color:#e2e8f0; border:none; padding:8px 16px; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; transition:all .15s; }
.dm-btn-filter:hover { background:#475569; }

/* MONTH SUMMARY CARDS */
.dm-month-stats { display:flex; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
.dm-mstat { background:#1e293b; border:1px solid #334155; border-radius:10px; padding:10px 16px; text-align:center; }
.dm-mstat .mv { font-size:18px; font-weight:800; color:var(--c,#3b82f6); }
.dm-mstat .ml { font-size:10px; color:#64748b; font-weight:600; text-transform:uppercase; margin-top:2px; }

/* ASSIGNMENT TABLE */
.dm-at { width:100%; border-collapse:collapse; font-size:12px; }
.dm-at th { padding:10px 12px; text-align:left; color:#64748b; font-weight:700; font-size:11px; text-transform:uppercase; background:#0f172a; }
.dm-at td { padding:11px 12px; border-bottom:1px solid #1e293b; color:#e2e8f0; vertical-align:middle; }
.dm-at tr:hover td { background:#0f172a55; }
.dm-ok-yes { color:#4ade80; font-weight:700; }
.dm-ok-no  { color:#f87171; font-weight:700; }
.dm-progress-bar { background:#1e293b; border-radius:4px; height:6px; overflow:hidden; min-width:60px; }
.dm-progress-fill { height:100%; border-radius:4px; background:#3b82f6; }

/* EMPTY STATE */
.dm-empty { text-align:center; padding:60px 20px; }
.dm-empty i { font-size:42px; color:#334155; display:block; margin-bottom:14px; }
.dm-empty .et { font-size:16px; font-weight:700; color:#64748b; }
.dm-empty .es { font-size:13px; color:#475569; margin-top:6px; }

/* MODAL */
.dm-overlay { position:fixed; inset:0; background:rgba(0,0,0,.65); z-index:9500; display:none; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
.dm-overlay.open { display:flex; }
.dm-modal { background:#1e293b; border:1px solid #334155; border-radius:16px; padding:28px; min-width:340px; max-width:420px; width:100%; box-shadow:0 24px 64px rgba(0,0,0,.6); }
.dm-modal h3 { margin:0 0 20px; font-size:16px; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:8px; }
.dm-field { margin-bottom:13px; }
.dm-field label { display:block; font-size:11px; color:#94a3b8; font-weight:700; margin-bottom:5px; text-transform:uppercase; }
.dm-input { width:100%; background:#0f172a; border:1px solid #334155; border-radius:8px; padding:9px 12px; color:#f1f5f9; font-size:13px; outline:none; box-sizing:border-box; }
.dm-input:focus { border-color:#3b82f6; }
.dm-modal-footer { display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:16px; border-top:1px solid #334155; }
.dm-btn-cancel { background:#334155; border:none; border-radius:8px; padding:9px 18px; color:#94a3b8; font-size:13px; cursor:pointer; }
.dm-btn-save { background:linear-gradient(135deg,#3b82f6,#2563eb); border:none; border-radius:8px; padding:9px 22px; color:white; font-size:13px; font-weight:700; cursor:pointer; }
</style>

<div class="dm-wrap">

    <!-- STATS -->
    <div class="dm-stats">
        <div class="dm-stat" style="--c:#3b82f6">
            <div class="val">@totalDrivers</div><div class="lbl">Tổng tài xế</div>
        </div>
        <div class="dm-stat" style="--c:#4ade80">
            <div class="val">@activeDrivers</div><div class="lbl">Đang làm</div>
        </div>
        <div class="dm-stat" style="--c:#f87171">
            <div class="val">@inactiveDrivers</div><div class="lbl">Không hoạt động</div>
        </div>
        <div class="dm-stat" style="--c:#fbbf24">
            <div class="val" id="statAssignMonth">—</div><div class="lbl">Phân công tháng @now_month</div>
        </div>
    </div>

    <!-- TABS -->
    <div class="dm-tabs">
        <button class="dm-tab active" id="tab-list" onclick="switchTab('list')">
            <i class="fas fa-users"></i> Danh sách tài xế
        </button>
        <button class="dm-tab" id="tab-month" onclick="switchTab('month')">
            <i class="fas fa-calendar-alt"></i> Phân công theo tháng
        </button>
        <button class="dm-tab" id="tab-detail" onclick="switchTab('detail')">
            <i class="fas fa-clipboard-list"></i> Lịch sử phân công
        </button>
    </div>

    <!-- PANEL 1: DANH SÁCH TÀI XẾ -->
    <div class="dm-panel active" id="panel-list">
        <div class="dm-toolbar">
            <input class="dm-search" id="driverSearch" placeholder="🔍 Tìm tên tài xế..." oninput="filterDriverTable()" style="width:220px">
            <select class="dm-select" id="statusFilter" onchange="filterDriverTable()">
                <option value="">Tất cả trạng thái</option>
                <option value="DangLam">Đang làm</option>
                <option value="NghiLam">Nghỉ làm</option>
                <option value="RoiBo">Rời bỏ</option>
            </select>
            <button class="dm-btn-add" onclick="openDriverModal()">
                <i class="fas fa-plus-circle"></i> Thêm tài xế
            </button>
        </div>
        <div class="dm-table-wrap">
            <table class="dm-table" id="driverTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tài xế</th>
                        <th>Số điện thoại</th>
                        <th>Trạng thái</th>
                        <th><i class="fas fa-calendar-check"></i> PC tháng @now_month</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="driverTbody">
                @{ int idx = 0; }
                @foreach (var d in Model)
                {
                    idx++;
                    int assignCount = assignmentCounts.ContainsKey(d.Id) ? assignmentCounts[d.Id] : 0;
                    string initial = d.DriverName?.Length > 0 ? d.DriverName[0].ToString().ToUpper() : "?";
                    string badgeClass = d.Status switch {
                        "DangLam" => "dm-badge-active",
                        "NghiLam" => "dm-badge-inactive",
                        _         => "dm-badge-leave"
                    };
                    string statusLabel = d.Status switch {
                        "DangLam" => "Đang làm",
                        "NghiLam" => "Nghỉ làm",
                        "RoiBo"   => "Rời bỏ",
                        _         => d.Status
                    };
                    <tr data-name="@d.DriverName?.ToLower()" data-status="@d.Status">
                        <td style="color:#475569;font-weight:700">@idx</td>
                        <td>
                            <div class="dm-driver-cell">
                                <div class="dm-avatar">@initial</div>
                                <div>
                                    <div style="font-weight:700;color:#f1f5f9">@d.DriverName</div>
                                    <div style="font-size:11px;color:#475569">ID: @d.Id</div>
                                </div>
                            </div>
                        </td>
                        <td style="color:#94a3b8">@d.Phone</td>
                        <td><span class="dm-badge @badgeClass"><i class="fas fa-circle" style="font-size:7px"></i> @statusLabel</span></td>
                        <td>
                            <span class="dm-chip"><i class="fas fa-briefcase"></i> @assignCount lần</span>
                        </td>
                        <td style="font-size:12px;color:#64748b">@d.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="dm-acts">
                                <button class="dm-act dm-act-edit" onclick="editDriver(@d.Id,'@d.DriverName','@d.Phone','@d.Status')">
                                    <i class="fas fa-pen"></i> Sửa
                                </button>
                                <button class="dm-act dm-act-del" onclick="deleteDriver(@d.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="dm-empty">
                    <i class="fas fa-truck"></i>
                    <div class="et">Chưa có tài xế nào</div>
                    <div class="es">Nhấn "Thêm tài xế" để bắt đầu</div>
                </div>
            }
        </div>
    </div>

    <!-- PANEL 2: PHÂN CÔNG THEO THÁNG - ĐÁNH GIÁ TOÀN DIỆN -->
    <div class="dm-panel" id="panel-month">
        <!-- FILTER -->
        <div class="dm-filter">
            <div>
                <label>Tháng</label>
                <select class="dm-select" id="mf-month">
                    @for (int i = 1; i <= 12; i++)
                    {
                        if (i == now_month)
                        { <option value="@i" selected>Tháng @i</option> }
                        else
                        { <option value="@i">Tháng @i</option> }
                    }
                </select>
            </div>
            <div>
                <label>Năm</label>
                <select class="dm-select" id="mf-year">
                    @for (int y = now_year; y >= now_year - 2; y--)
                    {
                        if (y == now_year)
                        { <option value="@y" selected>@y</option> }
                        else
                        { <option value="@y">@y</option> }
                    }
                </select>
            </div>
            <div>
                <label>Khu vực</label>
                <select class="dm-select" id="mf-area">
                    <option value="">Tất cả</option>
                    @foreach (dynamic a in areas)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
            <button class="dm-btn-filter" onclick="loadEvaluation()">
                <i class="fas fa-chart-bar"></i> Đánh giá
            </button>
        </div>

        <!-- TỔNG QUAN THÁNG -->
        <div id="evalOverview" style="margin-bottom:18px"></div>

        <!-- ĐÁNH GIÁ SOLUTION -->
        <div id="evalSolution" style="margin-bottom:18px"></div>

        <!-- SO SÁNH VỚI THÁNG TRƯỚC -->
        <div id="evalComparison" style="margin-bottom:18px"></div>

        <!-- BẢNG ĐÁNH GIÁ TỪNG TÀI XẾ -->
        <div id="evalDrivers"></div>
    </div>
    <!-- PANEL 3: LỊCH SỬ PHÂN CÔNG -->
    <div class="dm-panel" id="panel-detail">
        <!-- FILTER -->
        <div class="dm-filter">
            <div>
                <label>Tài xế</label>
                <input class="dm-search" id="df-driver" placeholder="Tên tài xế..." style="width:160px">
            </div>
            <div>
                <label>Khu vực</label>
                <select class="dm-select" id="df-area">
                    <option value="">Tất cả</option>
                    @foreach (dynamic a in areas)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
            <div>
                <label>Kết quả</label>
                <select class="dm-select" id="df-status">
                    <option value="">Tất cả</option>
                    <option value="ok">✅ Đạt chỉ tiêu</option>
                    <option value="fail">❌ Chưa đạt</option>
                </select>
            </div>
            <button class="dm-btn-filter" onclick="loadDetailData()">
                <i class="fas fa-search"></i> Lọc
            </button>
            <button class="dm-btn-filter" onclick="clearDetailFilter()" style="background:#475569">
                <i class="fas fa-times"></i> Xóa lọc
            </button>
        </div>

        <!-- DETAIL SUMMARY -->
        <div id="detailSummary" style="display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap"></div>

        <!-- TABLE -->
        <div class="dm-table-wrap">
            <table class="dm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tài xế</th>
                        <th>Khu vực</th>
                        <th>Điều phối</th>
                        <th>Tháng/Năm</th>
                        <th>Số vùng</th>
                        <th>Dự kiến</th>
                        <th>Thực tế</th>
                        <th>Tiến độ</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody id="detailTbody">
                    <tr><td colspan="9" style="text-align:center;padding:40px;color:#475569">
                        <i class="fas fa-clipboard-list" style="font-size:28px;display:block;margin-bottom:10px"></i>
                        Nhấn "Lọc" để xem dữ liệu phân công
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>


<div class="dm-overlay" id="driverOverlay" onclick="if(event.target===this)closeDriverModal()">
    <div class="dm-modal">
        <h3 id="modalTitle"><i class="fas fa-user-plus" style="color:#3b82f6"></i> Thêm tài xế</h3>
        <input type="hidden" id="editId">
        <div class="dm-field">
            <label>Họ tên <span style="color:#ef4444">*</span></label>
            <input class="dm-input" id="f-name" placeholder="Nguyễn Văn A">
        </div>
        <div class="dm-field">
            <label>Số điện thoại</label>
            <input class="dm-input" id="f-phone" placeholder="0912345678">
        </div>
        <div class="dm-field">
            <label>Trạng thái</label>
            <select class="dm-input" id="f-status">
                <option value="DangLam">Đang làm</option>
                <option value="NghiLam">Nghỉ làm</option>
                <option value="RoiBo">Rời bỏ</option>
            </select>
        </div>
        <div class="dm-modal-footer">
            <button class="dm-btn-cancel" onclick="closeDriverModal()">Hủy</button>
            <button class="dm-btn-save" onclick="saveDriver()"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </div>

    <!-- MAP PREVIEW AT BOTTOM -->
    <div class="dp-map-wrap" style="margin-top:20px;">
        <div class="dp-map-header">
            <div class="dp-map-title">
                <i class="fas fa-map-marked-alt" style="color:#f59e0b"></i> Xem chi tiết vùng phân công
                <span id="dmMapTitle" style="font-size:12px;color:#64748b;font-weight:400;margin-left:12px">Chọn một dòng phân công để xem bản đồ</span>
            </div>
        </div>
        <div id="dmMap" style="height:450px; background:#0f172a"></div>
    </div>
</div>

<script>
/* ===== TABS ===== */
function switchTab(tab) {
    document.querySelectorAll('.dm-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.dm-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('tab-' + tab).classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
    if (tab === 'month') loadEvaluation();
}

/* ===== FILTER DRIVER TABLE ===== */
function filterDriverTable() {
    let q = document.getElementById('driverSearch').value.toLowerCase();
    let s = document.getElementById('statusFilter').value;
    document.querySelectorAll('#driverTbody tr').forEach(tr => {
        let name   = tr.dataset.name   || '';
        let status = tr.dataset.status || '';
        let show = name.includes(q) && (!s || status === s);
        tr.style.display = show ? '' : 'none';
    });
}

/* ===== LOAD EVALUATION DATA ===== */
function loadEvaluation() {
    let m = document.getElementById('mf-month').value;
    let y = document.getElementById('mf-year').value;
    let a = document.getElementById('mf-area').value;

    fetch(`/Driver/GetAssignmentEvaluation?month=${m}&year=${y}&areaId=${a}`)
    .then(r => r.json())
    .then(data => {
        let s = data.summary;
        let p = data.prevSummary;
        let drivers = data.drivers || [];

        if (!drivers.length) {
            document.getElementById('evalOverview').innerHTML = '';
            document.getElementById('evalSolution').innerHTML = '';
            document.getElementById('evalComparison').innerHTML = '';
            document.getElementById('evalDrivers').innerHTML = `
                <div class="dm-empty">
                    <i class="fas fa-inbox"></i>
                    <div class="et">Chưa có dữ liệu phân công tháng ${m}/${y}</div>
                    <div class="es">Vào Điều phối để phân công tài xế trước</div>
                </div>`;
            return;
        }

        // === 1. OVERVIEW CARDS ===
        let diffColor = s.totalOrderDiffPct > 20 ? '#f87171' : s.totalOrderDiffPct > 10 ? '#fbbf24' : '#4ade80';
        let changePctHtml = p.ordersChangePct !== 0 ?
            `<span style="font-size:11px;color:${p.ordersChangePct>0?'#4ade80':'#f87171'}">${p.ordersChangePct>0?'▲':'▼'} ${Math.abs(p.ordersChangePct)}% vs T${data.prevMonth}</span>` : '';
        let actualChangePctHtml = p.actualChangePct !== 0 ?
            `<span style="font-size:11px;color:${p.actualChangePct>0?'#4ade80':'#f87171'}">${p.actualChangePct>0?'▲':'▼'} ${Math.abs(p.actualChangePct)}% vs T${data.prevMonth}</span>` : '';

        document.getElementById('evalOverview').innerHTML = `
            <div style="display:flex; gap:10px; flex-wrap:wrap">
                <div class="dm-mstat" style="--c:#3b82f6"><div class="mv">${s.totalDrivers}</div><div class="ml">Tài xế</div></div>
                <div class="dm-mstat" style="--c:#8b5cf6"><div class="mv">${s.totalPolygons}</div><div class="ml">Polygon</div><div style="font-size:10px;color:#64748b">TB: ${s.avgPolygons}/TX</div></div>
                <div class="dm-mstat" style="--c:#f59e0b"><div class="mv">${s.totalPlannedOrders}</div><div class="ml">Đơn dự kiến</div>${changePctHtml}</div>
                <div class="dm-mstat" style="--c:#4ade80"><div class="mv">${s.totalActualOrders}</div><div class="ml">Đơn thực tế</div>${actualChangePctHtml}</div>
                <div class="dm-mstat" style="--c:#06b6d4"><div class="mv">${s.totalPlannedCustomers}</div><div class="ml">KH dự kiến</div></div>
