                            <div><div style="font-size:10px;color:#475569">TB</div><div style="font-size:16px;font-weight:700;color:#3b82f6">${s.compactnessAvg.toLocaleString()}m</div></div>
                            <div><div style="font-size:10px;color:#475569">Max</div><div style="font-size:16px;font-weight:700;color:#f59e0b">${s.compactnessMax.toLocaleString()}m</div></div>
