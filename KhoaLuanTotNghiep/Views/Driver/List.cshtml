@{
    Layout = null;
}
@model List<Driver>
@{
    var assignmentCounts = ViewBag.AssignmentCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var areas = ViewBag.Areas as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    int totalDrivers    = ViewBag.TotalDrivers   ?? 0;
    int activeDrivers   = ViewBag.ActiveDrivers  ?? 0;
    int inactiveDrivers = ViewBag.InactiveDrivers ?? 0;
    int now_month = DateTime.Now.Month;
    int now_year  = DateTime.Now.Year;
}

<style>
/* ===== DRIVER MANAGEMENT ===== */
.dm-wrap { font-family:'Segoe UI',sans-serif; color:#e2e8f0; }

/* STATS */
.dm-stats { display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
.dm-stat {
    background:#1e293b; border:1px solid #334155; border-radius:12px;
    padding:14px 20px; min-width:130px; position:relative; overflow:hidden;
}
.dm-stat::before { content:''; position:absolute; top:0;left:0;right:0; height:3px; background:var(--c,#3b82f6); }
.dm-stat .val { font-size:24px; font-weight:800; color:var(--c,#3b82f6); }
.dm-stat .lbl { font-size:11px; color:#64748b; margin-top:2px; font-weight:600; text-transform:uppercase; }

/* FILTER BAR */
.dm-filter { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; align-items:center; background:#1e293b; border-radius:12px; padding:12px 16px; border:1px solid #334155; }
.dm-filter label { font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; }
.dm-select { background:#0f172a; border:1px solid #334155; border-radius:7px; padding:7px 10px; color:#f1f5f9; font-size:12px; outline:none; }
.dm-select:focus { border-color:#3b82f6; }
.dm-btn-filter { display:inline-flex; align-items:center; gap:6px; background:#334155; color:#e2e8f0; border:none; padding:8px 16px; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; transition:all .15s; }
.dm-btn-filter:hover { background:#475569; }

/* MONTH SUMMARY CARDS */
.dm-month-stats { display:flex; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
.dm-mstat { background:#1e293b; border:1px solid #334155; border-radius:10px; padding:10px 16px; text-align:center; }
.dm-mstat .mv { font-size:18px; font-weight:800; color:var(--c,#3b82f6); }
.dm-mstat .ml { font-size:10px; color:#64748b; font-weight:600; text-transform:uppercase; margin-top:2px; }

/* TABLE */
.dm-table-wrap { background:#1e293b; border-radius:14px; border:1px solid #334155; overflow:hidden; }
.dm-table { width:100%; border-collapse:collapse; font-size:13px; }
.dm-table thead tr { background:#0f172a; }
.dm-table th { padding:12px 14px; text-align:left; color:#64748b; font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:.04em; border-bottom:1px solid #1e293b55; }
.dm-table tbody tr { border-bottom:1px solid #0f172a44; transition:background .15s; }
.dm-table tbody tr:hover { background:#0f172a66; }
.dm-table td { padding:13px 14px; vertical-align:middle; }

/* DRIVER CELL */
.dm-driver-cell { display:flex; align-items:center; gap:10px; }
.dm-avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#3b82f6,#6366f1); display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; font-weight:700; color:white; }

/* ACTIONS */
.dm-acts { display:flex; gap:6px; }
.dm-act { display:inline-flex; align-items:center; gap:4px; padding:6px 11px; border-radius:7px; border:none; font-size:11px; font-weight:700; cursor:pointer; transition:all .15s; }
.dm-act-edit  { background:#1c3d5a; color:#38bdf8; }
.dm-act-edit:hover  { background:#0284c7; color:white; }

/* EMPTY STATE */
.dm-empty { text-align:center; padding:60px 20px; }
.dm-empty i { font-size:42px; color:#334155; display:block; margin-bottom:14px; }
.dm-empty .et { font-size:16px; font-weight:700; color:#64748b; }
.dm-empty .es { font-size:13px; color:#475569; margin-top:6px; }

/* MODAL */
.dm-overlay { position:fixed; inset:0; background:rgba(0,0,0,.65); z-index:9500; display:none; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
.dm-overlay.open { display:flex; }
.dm-modal { background:#1e293b; border:1px solid #334155; border-radius:16px; padding:28px; min-width:340px; max-width:420px; width:100%; box-shadow:0 24px 64px rgba(0,0,0,.6); }
.dm-modal h3 { margin:0 0 20px; font-size:16px; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:8px; }
.dm-field { margin-bottom:13px; }
.dm-field label { display:block; font-size:11px; color:#94a3b8; font-weight:700; margin-bottom:5px; text-transform:uppercase; }
.dm-input { width:100%; background:#0f172a; border:1px solid #334155; border-radius:8px; padding:9px 12px; color:#f1f5f9; font-size:13px; outline:none; box-sizing:border-box; }
.dm-input:focus { border-color:#3b82f6; }
.dm-modal-footer { display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:16px; border-top:1px solid #334155; }
.dm-btn-cancel { background:#334155; border:none; border-radius:8px; padding:9px 18px; color:#94a3b8; font-size:13px; cursor:pointer; }
.dm-btn-save { background:linear-gradient(135deg,#3b82f6,#2563eb); border:none; border-radius:8px; padding:9px 22px; color:white; font-size:13px; font-weight:700; cursor:pointer; }

/* SECTION CARDS */
.eval-section { background:#1e293b; border:1px solid #334155; border-radius:14px; padding:18px; margin-bottom:18px; }
.eval-section-title { font-size:15px; font-weight:700; color:#f1f5f9; margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.eval-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(180px,1fr)); gap:12px; }
.eval-card { background:#0f172a; border-radius:10px; padding:14px; }
.eval-card-label { font-size:11px; color:#64748b; font-weight:600; text-transform:uppercase; margin-bottom:6px; }
.eval-card-value { font-size:22px; font-weight:800; }
.eval-card-sub { font-size:12px; color:#94a3b8; margin-top:4px; }
.eval-mini { display:flex; gap:16px; }
.eval-mini-item .mini-label { font-size:10px; color:#475569; }
.eval-mini-item .mini-value { font-size:16px; font-weight:700; }

/* TABS for sub-sections */
.eval-tabs { display:flex; gap:4px; margin-bottom:16px; background:#1e293b; border-radius:10px; padding:4px; width:fit-content; }
.eval-tab {
    padding:8px 20px; border-radius:8px; cursor:pointer; font-size:13px; font-weight:600;
    color:#64748b; transition:all .2s; display:flex; align-items:center; gap:6px; border:none; background:none;
}
.eval-tab.active { background:#3b82f6; color:white; }
.eval-tab:hover:not(.active) { color:#e2e8f0; background:#334155; }
.eval-panel { display:none; }
.eval-panel.active { display:block; }
</style>

<div class="dm-wrap">

    <!-- STATS -->
    <div class="dm-stats">
        <div class="dm-stat" style="--c:#3b82f6">
            <div class="val">@totalDrivers</div><div class="lbl">Tổng tài xế</div>
        </div>
        <div class="dm-stat" style="--c:#4ade80">
            <div class="val">@activeDrivers</div><div class="lbl">Đang làm</div>
        </div>
        <div class="dm-stat" style="--c:#f87171">
            <div class="val">@inactiveDrivers</div><div class="lbl">Không hoạt động</div>
        </div>
        <div class="dm-stat" style="--c:#fbbf24">
            <div class="val" id="statAssignMonth">—</div><div class="lbl">Phân công tháng @now_month</div>
        </div>
    </div>

    <!-- EVAL TABS -->
    <div class="eval-tabs">
        <button class="eval-tab active" id="evtab-solution" onclick="switchEvalTab('solution')">
            <i class="fas fa-chart-pie"></i> Đánh giá tổng thể Solution
        </button>
        <button class="eval-tab" id="evtab-driver" onclick="switchEvalTab('driver')">
            <i class="fas fa-user-check"></i> Đánh giá từng tài xế
        </button>
        <button class="eval-tab" id="evtab-dispatcher" onclick="switchEvalTab('dispatcher')">
            <i class="fas fa-user-tie"></i> Đánh giá người điều phối
        </button>
    </div>

    <!-- FILTER -->
    <div class="dm-filter">
        <div>
            <label>Tháng</label>
            <select class="dm-select" id="mf-month">
                @for (int i = 1; i <= 12; i++)
                {
                    if (i == now_month)
                    { <option value="@i" selected>Tháng @i</option> }
                    else
                    { <option value="@i">Tháng @i</option> }
                }
            </select>
        </div>
        <div>
            <label>Năm</label>
            <select class="dm-select" id="mf-year">
                @for (int y = now_year; y >= now_year - 2; y--)
                {
                    if (y == now_year)
                    { <option value="@y" selected>@y</option> }
                    else
                    { <option value="@y">@y</option> }
                }
            </select>
        </div>
        <div>
            <label>Khu vực</label>
            <select class="dm-select" id="mf-area">
                <option value="">Tất cả</option>
                @foreach (dynamic a in areas)
                {
                    <option value="@a.Id">@a.Name</option>
                }
            </select>
        </div>
        <button class="dm-btn-filter" onclick="loadEvaluation()">
            <i class="fas fa-chart-bar"></i> Đánh giá
        </button>
    </div>

    <!-- ======== PANEL 1: ĐÁNH GIÁ TỔNG THỂ SOLUTION ======== -->
    <div class="eval-panel active" id="evpanel-solution">
        <div id="evalOverview" style="margin-bottom:18px"></div>
        <div id="evalSolution" style="margin-bottom:18px"></div>
        <div id="evalComparison" style="margin-bottom:18px"></div>
    </div>

    <!-- ======== PANEL 2: ĐÁNH GIÁ TỪNG TÀI XẾ ======== -->
    <div class="eval-panel" id="evpanel-driver">
        <div id="evalDrivers"></div>
    </div>

    <!-- ======== PANEL 3: ĐÁNH GIÁ NGƯỜI ĐIỀU PHỐI ======== -->
    <div class="eval-panel" id="evpanel-dispatcher">
        <div id="evalDispatcher"></div>
    </div>

</div>

<!-- MODAL -->
<div class="dm-overlay" id="driverOverlay" onclick="if(event.target===this)closeDriverModal()">
    <div class="dm-modal">
        <h3 id="modalTitle"><i class="fas fa-clipboard-check" style="color:#4ade80"></i> Nhập thực tế</h3>
        <div class="dm-modal-footer">
            <button class="dm-btn-cancel" onclick="closeDriverModal()">Hủy</button>
            <button class="dm-btn-save" onclick="closeDriverModal()"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </div>
</div>

<script>
/* ===== EVAL TABS ===== */
function switchEvalTab(tab) {
    document.querySelectorAll('.eval-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.eval-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('evtab-' + tab).classList.add('active');
    document.getElementById('evpanel-' + tab).classList.add('active');
}

/* ===== LOAD EVALUATION DATA ===== */
function loadEvaluation() {
    let m = document.getElementById('mf-month').value;
    let y = document.getElementById('mf-year').value;
    let a = document.getElementById('mf-area').value;

    fetch(`/Driver/GetAssignmentEvaluation?month=${m}&year=${y}&areaId=${a}`)
    .then(r => r.json())
    .then(data => {
        let s = data.summary;
        let p = data.prevSummary;
        let drivers = data.drivers || [];

        if (!drivers.length) {
            document.getElementById('evalOverview').innerHTML = '';
            document.getElementById('evalSolution').innerHTML = '';
            document.getElementById('evalComparison').innerHTML = '';
            document.getElementById('evalDrivers').innerHTML = `
                <div class="dm-empty">
                    <i class="fas fa-inbox"></i>
                    <div class="et">Chưa có dữ liệu phân công tháng ${m}/${y}</div>
                    <div class="es">Vào Điều phối để phân công tài xế trước</div>
                </div>`;
            document.getElementById('evalDispatcher').innerHTML = '';
            return;
        }

        // Find max/min driver
        let maxDriver = drivers.reduce((a,b) => a.plannedOrders > b.plannedOrders ? a : b);
        let minDriver = drivers.reduce((a,b) => a.plannedOrders < b.plannedOrders ? a : b);

        // ===== PANEL 1: TỔNG THỂ SOLUTION =====
        let diffColor = s.totalOrderDiffPct > 20 ? '#f87171' : s.totalOrderDiffPct > 10 ? '#fbbf24' : '#4ade80';
        let changePctHtml = p.ordersChangePct !== 0 ?
            `<span style="font-size:11px;color:${p.ordersChangePct>0?'#4ade80':'#f87171'}">${p.ordersChangePct>0?'▲':'▼'} ${Math.abs(p.ordersChangePct)}% vs T${data.prevMonth}</span>` : '';

        // Overview cards
        document.getElementById('evalOverview').innerHTML = `
            <div style="display:flex; gap:10px; flex-wrap:wrap">
                <div class="dm-mstat" style="--c:#3b82f6"><div class="mv">${s.totalDrivers}</div><div class="ml">Tài xế</div></div>
                <div class="dm-mstat" style="--c:#8b5cf6"><div class="mv">${s.totalPolygons}</div><div class="ml">Polygon</div><div style="font-size:10px;color:#64748b">TB: ${s.avgPolygons}/TX</div></div>
                <div class="dm-mstat" style="--c:#f59e0b"><div class="mv">${s.totalPlannedOrders}</div><div class="ml">Đơn dự kiến</div>${changePctHtml}</div>
                <div class="dm-mstat" style="--c:#4ade80"><div class="mv">${s.totalActualOrders}</div><div class="ml">Đơn thực tế</div></div>
                <div class="dm-mstat" style="--c:#06b6d4"><div class="mv">${s.totalPlannedCustomers}</div><div class="ml">KH dự kiến</div></div>
                <div class="dm-mstat" style="--c:#22d3ee"><div class="mv">${s.totalActualCustomers}</div><div class="ml">KH thực tế</div></div>
            </div>`;

        // Solution quality section
        let violationColor = s.totalViolations > 0 ? '#f87171' : '#4ade80';
        document.getElementById('evalSolution').innerHTML = `
            <div class="eval-section">
                <div class="eval-section-title"><i class="fas fa-chart-pie" style="color:#8b5cf6"></i> Tiêu chí đánh giá tổng thể Solution</div>
                <div class="eval-grid">
                    <div class="eval-card">
                        <div class="eval-card-label">Tổng mức mất cân bằng</div>
                        <div class="eval-card-value" style="color:#f59e0b">${s.orderStdDev}</div>
                        <div class="eval-card-sub">Độ lệch chuẩn đơn hàng</div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Vi phạm cân bằng (±${s.balanceThresholdPct}%)</div>
                        <div class="eval-card-value" style="color:${violationColor}">${s.totalViolations} <span style="font-size:12px;color:#64748b">tài xế vượt</span></div>
                        <div class="eval-card-sub">Tổng mức vi phạm: <b style="color:${violationColor}">${s.totalViolationAmount}</b></div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Tổng Compactness (Nhỏ gọn)</div>
                        <div class="eval-mini">
                            <div class="eval-mini-item"><div class="mini-label">Min</div><div class="mini-value" style="color:#4ade80">${s.compactnessMin.toLocaleString()}m</div></div>
                            <div class="eval-mini-item"><div class="mini-label">TB</div><div class="mini-value" style="color:#3b82f6">${s.compactnessAvg.toLocaleString()}m</div></div>
                            <div class="eval-mini-item"><div class="mini-label">Max</div><div class="mini-value" style="color:#f59e0b">${s.compactnessMax.toLocaleString()}m</div></div>
                        </div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">TB / Tài xế</div>
                        <div class="eval-mini">
                            <div class="eval-mini-item"><div class="mini-label">Đơn</div><div class="mini-value" style="color:#3b82f6">${s.avgOrders}</div></div>
                            <div class="eval-mini-item"><div class="mini-label">KH</div><div class="mini-value" style="color:#06b6d4">${s.avgCustomers}</div></div>
                        </div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Tài xế NHIỀU nhất</div>
                        <div style="font-size:14px;font-weight:700;color:#f59e0b">${maxDriver.driverName}</div>
                        <div class="eval-card-sub">${maxDriver.plannedOrders} đơn · ${maxDriver.plannedCustomers} KH · ${maxDriver.zoneCount} vùng</div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Tài xế ÍT nhất</div>
                        <div style="font-size:14px;font-weight:700;color:#06b6d4">${minDriver.driverName}</div>
                        <div class="eval-card-sub">${minDriver.plannedOrders} đơn · ${minDriver.plannedCustomers} KH · ${minDriver.zoneCount} vùng</div>
                    </div>
                </div>
            </div>`;

        // Comparison section
        let prevDiffColor = p.totalDiffPct > 20 ? '#f87171' : p.totalDiffPct > 10 ? '#fbbf24' : '#4ade80';
        document.getElementById('evalComparison').innerHTML = `
            <div class="eval-section">
                <div class="eval-section-title"><i class="fas fa-exchange-alt" style="color:#f59e0b"></i> So sánh Tháng ${m} vs Tháng ${data.prevMonth}</div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px">
                    <div class="eval-card">
                        <div style="font-size:13px;font-weight:700;color:#3b82f6;margin-bottom:10px">📅 Tháng ${m}/${y}</div>
                        <table style="width:100%;font-size:12px;color:#94a3b8">
                            <tr><td>Tài xế</td><td style="text-align:right;color:#f1f5f9;font-weight:700">${s.totalDrivers}</td></tr>
                            <tr><td>Đơn dự kiến</td><td style="text-align:right;color:#f59e0b;font-weight:700">${s.totalPlannedOrders}</td></tr>
                            <tr><td>Đơn thực tế</td><td style="text-align:right;color:#4ade80;font-weight:700">${s.totalActualOrders}</td></tr>
                            <tr><td>KH dự kiến</td><td style="text-align:right;color:#06b6d4;font-weight:700">${s.totalPlannedCustomers}</td></tr>
                            <tr><td>KH thực tế</td><td style="text-align:right;color:#22d3ee;font-weight:700">${s.totalActualCustomers}</td></tr>
                            <tr><td>Hao hụt đơn</td><td style="text-align:right;color:${diffColor};font-weight:700">${s.totalOrderDiff} (${s.totalOrderDiffPct}%)</td></tr>
                        </table>
                    </div>
                    <div class="eval-card">
                        <div style="font-size:13px;font-weight:700;color:#64748b;margin-bottom:10px">📅 Tháng ${data.prevMonth}/${data.prevYear}</div>
                        <table style="width:100%;font-size:12px;color:#94a3b8">
                            <tr><td>Tài xế</td><td style="text-align:right;color:#f1f5f9;font-weight:700">${p.totalDrivers || 0}</td></tr>
                            <tr><td>Đơn dự kiến</td><td style="text-align:right;color:#f59e0b;font-weight:700">${p.totalPlannedOrders}</td></tr>
                            <tr><td>Đơn thực tế</td><td style="text-align:right;color:#4ade80;font-weight:700">${p.totalActualOrders}</td></tr>
                            <tr><td>KH dự kiến</td><td style="text-align:right;color:#06b6d4;font-weight:700">${p.totalPlannedCustomers}</td></tr>
                            <tr><td>KH thực tế</td><td style="text-align:right;color:#22d3ee;font-weight:700">${p.totalActualCustomers}</td></tr>
                            <tr><td>Hao hụt đơn</td><td style="text-align:right;color:${prevDiffColor};font-weight:700">${p.totalPlannedOrders - p.totalActualOrders} (${p.totalDiffPct}%)</td></tr>
                        </table>
                    </div>
                </div>
            </div>`;

        // ===== PANEL 2: PER-DRIVER TABLE =====
        let driverRows = drivers.map((d, i) => {
            let balanceBadge = d.violatesBalance
                ? `<span style="color:#f87171;font-weight:700;font-size:11px"><i class="fas fa-exclamation-triangle"></i> Vượt ${d.violationAmount}</span>`
                : `<span style="color:#4ade80;font-size:11px"><i class="fas fa-check-circle"></i> OK</span>`;
            let dColor = Math.abs(d.orderDiffPct) > 20 ? '#f87171' : Math.abs(d.orderDiffPct) > 10 ? '#fbbf24' : '#4ade80';
            let prevDiffC = Math.abs(d.prevOrderDiffPct) > 20 ? '#f87171' : Math.abs(d.prevOrderDiffPct) > 10 ? '#fbbf24' : '#4ade80';

            let zoneRows = (d.zones || []).map(z => {
                let real = z.ordersReal !== null ? z.ordersReal : '—';
                let custReal = z.customersReal !== null ? z.customersReal : '—';
                let diff = z.ordersReal !== null ? z.ordersForecast - z.ordersReal : null;
                let diffStr = diff !== null ? `<span style="color:${Math.abs(diff)>5?'#f87171':'#4ade80'}">${diff>0?'+':''}${diff}</span>` : '—';
                return `<tr style="background:#0a0f1a;font-size:11px">
                    <td colspan="2" style="padding-left:52px;color:#475569">↳ ${z.zoneName}</td>
                    <td style="color:#f59e0b">${z.ordersForecast}</td>
                    <td style="color:#4ade80">${real}</td>
                    <td style="color:#06b6d4">${z.customersForecast}</td>
                    <td style="color:#22d3ee">${custReal}</td>
                    <td>${diffStr}</td>
                    <td colspan="4"></td>
                </tr>`;
            }).join('');

            return `<tr onclick="toggleEvalDetail(${i})" style="cursor:pointer" class="eval-row">
                <td style="color:#475569;font-weight:700">${i+1}</td>
                <td>
                    <div class="dm-driver-cell">
                        <div class="dm-avatar">${(d.driverName||'?')[0]}</div>
                        <div>
                            <div style="font-weight:700;color:#f1f5f9">${d.driverName}</div>
                            <div style="font-size:10px;color:#475569">${d.areaName} · ${d.zoneCount} vùng</div>
                        </div>
                    </div>
                </td>
                <td style="font-weight:700;color:#f59e0b">${d.plannedOrders}</td>
                <td style="font-weight:700;color:#4ade80">${d.actualOrders}</td>
                <td style="font-weight:700;color:#06b6d4">${d.plannedCustomers}</td>
                <td style="font-weight:700;color:#22d3ee">${d.actualCustomers}</td>
                <td><span style="color:${dColor};font-weight:700">${d.orderDiff>0?'+':''}${d.orderDiff} <span style="font-size:10px">(${d.orderDiffPct}%)</span></span></td>
                <td style="font-size:11px;color:#94a3b8">${d.compactness.toLocaleString()}m</td>
                <td>${balanceBadge}</td>
                <td>
                    <div style="font-size:11px">
                        <span style="color:${prevDiffC}">${d.prevOrderDiff>0?'+':''}${d.prevOrderDiff} (${d.prevOrderDiffPct}%)</span>
                        <div style="font-size:9px;color:#475569">T${data.prevMonth}: ${d.prevPlannedOrders}→${d.prevActualOrders}</div>
                    </div>
                </td>
                <td>
                    <button class="dm-act dm-act-edit" onclick="event.stopPropagation();openActualModal(${d.driverId},'${d.driverName}',${d.actualOrders},${d.actualCustomers})" title="Nhập thực tế">
                        <i class="fas fa-edit"></i>
                    </button>
                </td>
            </tr>
            <tr id="evalDetail-${i}" style="display:none">
                <td colspan="11" style="padding:0">
                    <table style="width:100%;border-collapse:collapse;background:#0d111c">
                        <thead><tr style="background:#0a0f1a">
                            <th colspan="2" style="padding:8px 14px;color:#475569;font-size:10px;text-align:left">VÙNG</th>
                            <th style="padding:8px;color:#475569;font-size:10px">ĐƠN DK</th>
                            <th style="padding:8px;color:#475569;font-size:10px">ĐƠN TT</th>
                            <th style="padding:8px;color:#475569;font-size:10px">KH DK</th>
                            <th style="padding:8px;color:#475569;font-size:10px">KH TT</th>
                            <th style="padding:8px;color:#475569;font-size:10px">CHÊNH LỆCH</th>
                            <th colspan="4"></th>
                        </tr></thead>
                        <tbody>${zoneRows || '<tr><td colspan="11" style="padding:12px;color:#475569;text-align:center;font-size:11px">Không có dữ liệu vùng</td></tr>'}</tbody>
                    </table>
                </td>
            </tr>`;
        }).join('');

        document.getElementById('evalDrivers').innerHTML = `
            <div class="eval-section">
                <div class="eval-section-title"><i class="fas fa-user-check" style="color:#4ade80"></i> Tiêu chí đánh giá phân công từng tài xế</div>
                <div style="font-size:12px;color:#64748b;margin-bottom:12px">
                    Nhấn vào từng dòng để xem chi tiết vùng. Các tiêu chí: tổng đơn, tổng KH, mức độ thiếu/vượt, compactness, chênh lệch so với kì trước.
                </div>
                <div class="dm-table-wrap">
                    <table class="dm-table">
                        <thead><tr>
                            <th>#</th>
                            <th>Tài xế</th>
                            <th title="Đơn hàng dự kiến">Đơn DK</th>
                            <th title="Đơn hàng thực tế">Đơn TT</th>
                            <th title="Khách hàng dự kiến">KH DK</th>
                            <th title="Khách hàng thực tế">KH TT</th>
                            <th>Thiếu/Vượt</th>
                            <th title="Tổng khoảng cách tới tâm">Compactness</th>
                            <th>Cân bằng</th>
                            <th>Δ vs T${data.prevMonth}</th>
                            <th></th>
                        </tr></thead>
                        <tbody>${driverRows}</tbody>
                    </table>
                </div>
            </div>`;

        // ===== PANEL 3: ĐÁNH GIÁ NGƯỜI ĐIỀU PHỐI =====
        // Section A: Chất lượng solution chuẩn bị apply cho tháng sau (= tiêu chí tổng thể)
        // Section B: Chất lượng solution thực tế tháng trước (so sánh DK vs TT)
        let prevOrderDiffAbs = p.totalPlannedOrders - p.totalActualOrders;
        let prevCustDiffAbs = p.totalPlannedCustomers - p.totalActualCustomers;
        let prevOrderDiffPctVal = p.totalPlannedOrders > 0 ? ((prevOrderDiffAbs / p.totalPlannedOrders) * 100).toFixed(1) : 0;
        let prevCustDiffPctVal = p.totalPlannedCustomers > 0 ? ((prevCustDiffAbs / p.totalPlannedCustomers) * 100).toFixed(1) : 0;
        let prevDiffColorD = Math.abs(prevOrderDiffPctVal) > 20 ? '#f87171' : Math.abs(prevOrderDiffPctVal) > 10 ? '#fbbf24' : '#4ade80';
        let biendong = Math.abs(p.ordersChangePct) > 20 ? '#f87171' : Math.abs(p.ordersChangePct) > 10 ? '#fbbf24' : '#4ade80';

        document.getElementById('evalDispatcher').innerHTML = `
            <!-- A: Chất lượng solution cho tháng tới -->
            <div class="eval-section">
                <div class="eval-section-title"><i class="fas fa-clipboard-check" style="color:#3b82f6"></i> Chất lượng Solution chuẩn bị apply (Tháng ${m}/${y})</div>
                <div style="font-size:12px;color:#64748b;margin-bottom:12px">
                    Đánh giá solution mà người điều phối đã chuẩn bị cho tháng ${m}. Bao gồm mức cân bằng, compactness, phân bổ tài xế.
                </div>
                <div class="eval-grid">
                    <div class="eval-card">
                        <div class="eval-card-label">Tổng mất cân bằng dự kiến</div>
                        <div class="eval-card-value" style="color:#f59e0b">${s.orderStdDev}</div>
                        <div class="eval-card-sub">Độ lệch chuẩn · ${s.totalViolations} TX vượt ngưỡng</div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Tổng Compactness dự kiến</div>
                        <div class="eval-card-value" style="color:#3b82f6">${s.compactnessAvg.toLocaleString()}m</div>
                        <div class="eval-card-sub">TB khoảng cách tới tâm</div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Tài xế nhiều nhất</div>
                        <div style="font-size:14px;font-weight:700;color:#f59e0b">${maxDriver.driverName}</div>
                        <div class="eval-card-sub">${maxDriver.plannedOrders} đơn · ${maxDriver.plannedCustomers} KH</div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Tài xế ít nhất</div>
                        <div style="font-size:14px;font-weight:700;color:#06b6d4">${minDriver.driverName}</div>
                        <div class="eval-card-sub">${minDriver.plannedOrders} đơn · ${minDriver.plannedCustomers} KH</div>
                    </div>
                </div>
            </div>

            <!-- B: Chất lượng thực tế tháng trước -->
            <div class="eval-section">
                <div class="eval-section-title"><i class="fas fa-history" style="color:#f59e0b"></i> Chất lượng thực tế tháng trước (Tháng ${data.prevMonth}/${data.prevYear})</div>
                <div style="font-size:12px;color:#64748b;margin-bottom:12px">
                    So sánh SL đơn/KH dự kiến khi điều phối tháng trước vs SL thực tế cuối tháng → đánh giá mức chênh lệch & biến động.
                </div>
                <div class="eval-grid">
                    <div class="eval-card">
                        <div class="eval-card-label">Đơn hàng</div>
                        <table style="width:100%;font-size:12px;color:#94a3b8;margin-top:6px">
                            <tr><td>Dự kiến</td><td style="text-align:right;color:#f59e0b;font-weight:700">${p.totalPlannedOrders}</td></tr>
                            <tr><td>Thực tế</td><td style="text-align:right;color:#4ade80;font-weight:700">${p.totalActualOrders}</td></tr>
                            <tr><td>Chênh lệch</td><td style="text-align:right;color:${prevDiffColorD};font-weight:700">${prevOrderDiffAbs} (${prevOrderDiffPctVal}%)</td></tr>
                        </table>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Khách hàng</div>
                        <table style="width:100%;font-size:12px;color:#94a3b8;margin-top:6px">
                            <tr><td>Dự kiến</td><td style="text-align:right;color:#06b6d4;font-weight:700">${p.totalPlannedCustomers}</td></tr>
                            <tr><td>Thực tế</td><td style="text-align:right;color:#22d3ee;font-weight:700">${p.totalActualCustomers}</td></tr>
                            <tr><td>Chênh lệch</td><td style="text-align:right;color:${prevDiffColorD};font-weight:700">${prevCustDiffAbs} (${prevCustDiffPctVal}%)</td></tr>
                        </table>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Mức độ biến động</div>
                        <div class="eval-card-value" style="color:${biendong}">${Math.abs(p.ordersChangePct)}%</div>
                        <div class="eval-card-sub">Thay đổi đơn hàng so với T${data.prevMonth > 1 ? data.prevMonth-1 : 12}</div>
                    </div>
                    <div class="eval-card">
                        <div class="eval-card-label">Đánh giá chung</div>
                        <div style="font-size:14px;font-weight:700;color:${Math.abs(prevOrderDiffPctVal) <= 10 ? '#4ade80' : Math.abs(prevOrderDiffPctVal) <= 20 ? '#fbbf24' : '#f87171'}">
                            ${Math.abs(prevOrderDiffPctVal) <= 10 ? '✅ Tốt' : Math.abs(prevOrderDiffPctVal) <= 20 ? '⚠️ Trung bình' : '❌ Cần cải thiện'}
                        </div>
                        <div class="eval-card-sub">Sai lệch ${prevOrderDiffPctVal}% đơn hàng</div>
                    </div>
                </div>
            </div>
        `;

        document.getElementById('statAssignMonth').textContent = s.totalDrivers;
    })
    .catch(err => {
        console.error(err);
        showToast('Lỗi khi tải dữ liệu đánh giá!', 'error');
    });
}

function toggleEvalDetail(idx) {
    let el = document.getElementById('evalDetail-' + idx);
    if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
}

function openActualModal(driverId, driverName, curOrders, curCustomers) {
    let ov = document.getElementById('driverOverlay');
    ov.querySelector('.dm-modal').innerHTML = `
        <h3 id="modalTitle"><i class="fas fa-clipboard-check" style="color:#4ade80"></i> Nhập số liệu thực tế — ${driverName}</h3>
        <div class="dm-field">
            <label>Đơn hàng thực tế</label>
            <input class="dm-input" id="actualOrders" type="number" value="${curOrders}" min="0">
        </div>
        <div class="dm-field">
            <label>Khách hàng thực tế</label>
            <input class="dm-input" id="actualCustomers" type="number" value="${curCustomers}" min="0">
        </div>
        <div class="dm-modal-footer">
            <button class="dm-btn-cancel" onclick="closeDriverModal()">Hủy</button>
            <button class="dm-btn-save" onclick="saveActualData(${driverId})"><i class="fas fa-save"></i> Lưu</button>
        </div>
    `;
    ov.classList.add('open');
}

function saveActualData(driverId) {
    let m = document.getElementById('mf-month').value;
    let y = document.getElementById('mf-year').value;
    let a = document.getElementById('mf-area').value;
    let actualOrders = parseInt(document.getElementById('actualOrders').value) || 0;
    let actualCustomers = parseInt(document.getElementById('actualCustomers').value) || 0;

    fetch(`/Driver/GetByMonth?month=${m}&year=${y}&areaId=${a}`)
    .then(r => r.json())
    .then(data => {
        fetch(`/Driver/GetAssignmentEvaluation?month=${m}&year=${y}&areaId=${a}`)
        .then(r => r.json())
        .then(evalData => {
            let driver = (evalData.drivers || []).find(d => d.driverId === driverId);
            if (!driver) { showToast('Không tìm thấy phân công!', 'error'); return; }
            let matched = data.find(x => x.driverName === driver.driverName);
            if (!matched) { showToast('Không tìm thấy phân công!', 'error'); return; }

            fetch('/Driver/UpdateActual', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: matched.id, actualOrders, actualCustomers })
            })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    closeDriverModal();
                    showToast('Đã cập nhật số liệu thực tế!', 'success');
                    loadEvaluation();
                } else {
                    showToast(d.message || 'Lỗi cập nhật!', 'error');
                }
            });
        });
    });
}

function closeDriverModal() {
    document.getElementById('driverOverlay').classList.remove('open');
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDriverModal();
});

// Auto-load on page ready
loadEvaluation();
</script>