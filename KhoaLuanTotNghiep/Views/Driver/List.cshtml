                <td style="font-weight:700;color:#4ade80">${d.actualOrders}</td>
                <td style="font-weight:700;color:#06b6d4">${d.plannedCustomers}</td>
                <td style="font-weight:700;color:#22d3ee">${d.actualCustomers}</td>
                <td><span style="color:${diffColor};font-weight:700">${d.orderDiff>0?'+':''}${d.orderDiff} <span style="font-size:10px">(${d.orderDiffPct}%)</span></span></td>
                <td style="font-size:11px;color:#94a3b8">${d.compactness.toLocaleString()}m</td>
                <td>${balanceBadge}</td>
                <td>
                    <div style="font-size:11px">
                        <span style="color:${prevDiffC}">${d.prevOrderDiff>0?'+':''}${d.prevOrderDiff} (${d.prevOrderDiffPct}%)</span>
                        <div style="font-size:9px;color:#475569">T${data.prevMonth}: ${d.prevPlannedOrders}→${d.prevActualOrders}</div>
