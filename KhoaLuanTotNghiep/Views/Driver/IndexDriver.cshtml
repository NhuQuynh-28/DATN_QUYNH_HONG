@{
    Layout = null;
}
<h2>🚚 Quản lý tài xế</h2>

<div style="margin-bottom:10px;">
    <button onclick="loadList()">Danh sách</button>
    <button onclick="loadStats()">Thống kê</button>
</div>

<div style="margin-bottom:10px;">
    <input type="number" id="month" placeholder="Tháng">
    <input type="number" id="year" placeholder="Năm">
    <button onclick="loadMonth()">Xem theo tháng</button>
</div>

<div id="driver-content"></div>

<script>
    function loadList(){
        fetch('/Driver/List')
        .then(r=>r.text())
        .then(d=>{
            document.getElementById("driver-content").innerHTML=d;
        });
    }

    function loadStats(){
        fetch('/Driver/Statistics')
        .then(r=>r.text())
        .then(d=>{
            document.getElementById("driver-content").innerHTML=d;
        });
    }

    function loadMonth(){
        let m = document.getElementById("month").value;
        let y = document.getElementById("year").value;

        fetch(`/Driver/ByMonth?month=${m}&year=${y}`)
        .then(r=>r.text())
        .then(d=>{
            document.getElementById("driver-content").innerHTML=d;
        });
    }
</script>