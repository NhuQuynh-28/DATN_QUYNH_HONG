@model List<KhoaLuanTotNghiep.Models.ZoneVersion>

<style>
.vl-wrap { font-family:'Segoe UI',sans-serif; padding:4px 0; }

/* HEADER */
.vl-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:12px; }
.vl-title { display:flex; align-items:center; gap:10px; }
.vl-title h2 { margin:0; font-size:20px; font-weight:700; color:#f1f5f9; }
.vl-back-btn {
    display:inline-flex; align-items:center; gap:6px;
    background:#1e293b; border:1px solid #334155; color:#94a3b8;
    padding:7px 14px; border-radius:8px; font-size:12px; cursor:pointer;
    text-decoration:none; transition:all .15s;
}
.vl-back-btn:hover { background:#334155; color:#e2e8f0; }

/* STAT CARDS */
.vl-stats { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.vl-stat {
    background:#1e293b; border:1px solid #334155; border-radius:12px;
    padding:14px 20px; min-width:120px; position:relative; overflow:hidden;
}
.vl-stat::before {
    content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background:var(--accent,#3b82f6);
}
.vl-stat .val { font-size:22px; font-weight:800; color:var(--accent,#3b82f6); }
.vl-stat .lbl { font-size:11px; color:#64748b; margin-top:3px; font-weight:600; text-transform:uppercase; letter-spacing:.04em; }

/* ADD BUTTON */
.vl-add-btn {
    display:inline-flex; align-items:center; gap:8px;
    background:linear-gradient(135deg,#3b82f6,#2563eb); color:white;
    border:none; padding:10px 20px; border-radius:10px; font-size:13px;
    font-weight:700; cursor:pointer; transition:opacity .15s;
}
.vl-add-btn:hover { opacity:.88; }

/* TABLE */
.vl-table-wrap { background:#1e293b; border-radius:14px; border:1px solid #334155; overflow:hidden; }
.vl-table { width:100%; border-collapse:collapse; font-size:13px; }
.vl-table thead tr { background:#0f172a; }
.vl-table th {
    padding:12px 16px; text-align:left; color:#64748b;
    font-weight:700; font-size:11px; text-transform:uppercase;
    letter-spacing:.05em; border-bottom:1px solid #1e293b;
}
.vl-table tbody tr { border-bottom:1px solid #0f172a55; transition:background .15s; cursor:pointer; }
.vl-table tbody tr:hover { background:#0f172a88; }
.vl-table td { padding:14px 16px; color:#e2e8f0; vertical-align:middle; }

/* VERSION NAME CELL */
.vl-ver-cell { display:flex; align-items:center; gap:10px; }
.vl-ver-icon {
    width:34px; height:34px; border-radius:9px; flex-shrink:0;
    display:flex; align-items:center; justify-content:center; font-size:15px;
    background:linear-gradient(135deg,#1d4ed8,#6366f1);
}
.vl-ver-name { font-weight:700; color:#f1f5f9; }
.vl-ver-id   { font-size:11px; color:#475569; margin-top:1px; }

/* BADGES */
.vl-badge {
    display:inline-flex; align-items:center; gap:4px;
    padding:3px 11px; border-radius:20px; font-size:11px; font-weight:700;
}
.vl-badge-active   { background:#16a34a22; color:#4ade80; border:1px solid #16a34a44; }
.vl-badge-inactive { background:#47474722; color:#94a3b8; border:1px solid #47474744; }

/* CHIPS */
.vl-chip {
    display:inline-flex; align-items:center; gap:4px;
    background:#0f172a; border:1px solid #334155; border-radius:8px;
    padding:4px 10px; font-size:12px; color:#94a3b8; font-weight:600;
}
.vl-chip i { font-size:10px; }

/* AREA DISPLAY */
.vl-area {
    font-size:13px; color:#e2e8f0; font-weight:600;
    display:flex; align-items:baseline; gap:4px;
}
.vl-area .unit { font-size:10px; color:#475569; font-weight:400; }

/* ACTION BUTTONS */
.vl-actions { display:flex; gap:6px; flex-wrap:nowrap; }
.vl-btn {
    display:inline-flex; align-items:center; gap:5px;
    padding:6px 12px; border-radius:8px; border:none;
    font-size:11px; font-weight:700; cursor:pointer; transition:all .15s; white-space:nowrap;
}
.vl-btn-map    { background:#1c3d5a; color:#38bdf8; }
.vl-btn-map:hover    { background:#0284c7; color:white; }
.vl-btn-active { background:#1e3d2f; color:#4ade80; }
.vl-btn-active:hover { background:#16a34a; color:white; }
.vl-btn-del    { background:#3d1c1c; color:#f87171; }
.vl-btn-del:hover    { background:#dc2626; color:white; }
.vl-btn-update { background:#3d2f1c; color:#f59e0b; }
.vl-btn-update:hover { background:#d97706; color:white; }

.vl-btn-dist   { background:#1e293b; color:#fbbf24; border:1px solid #fbbf2444; }
.vl-btn-dist:hover   { background:#fbbf24; color:#0f172a; }
.vl-btn-adj    { background:#1e293b; color:#a78bfa; border:1px solid #a78bfa44; }
.vl-btn-adj:hover    { background:#a78bfa; color:#0f172a; }

.vl-date { font-size:12px; color:#64748b; }
.vl-num  { font-weight:700; color:#475569; }

/* MODAL OVERLAY & CONTENT */
.am-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.85); display: none; align-items: center; justify-content: center;
    z-index: 9999; backdrop-filter: blur(8px);
}
.am-overlay.open { display: flex; }
.am-modal {
    background: #111827; border: 1px solid #334155; border-radius: 20px;
    padding: 28px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    max-width: 1000px; width: 95%; max-height: 90vh; overflow-y: auto;
    position: relative; animation: amPop .3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
@@keyframes amPop { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.am-footer { margin-top: 24px; padding-top: 18px; border-top: 1px solid #334155; display: flex; justify-content: flex-end; }
.am-btn-cancel {
    background: #334155; color: #f1f5f9; border: none; padding: 10px 24px;
    border-radius: 10px; font-weight: 700; font-size: 13px; cursor: pointer; transition: all .2s;
}
.am-btn-cancel:hover { background: #475569; }
</style>

<div class="vl-wrap">

    <!-- HEADER -->
    <div class="vl-header">
        <div class="vl-title">
            <span onclick="loadArea()" class="vl-back-btn" title="Quay lại danh sách khu vực">
                <i class="fas fa-arrow-left"></i>
            </span>
            <div>
                <h2><i class="fas fa-layer-group" style="color:#3b82f6;margin-right:8px"></i>Danh sách Version</h2>
                <div style="font-size:12px;color:#64748b;margin-top:2px">
                    Khu vực: <span style="color:#60a5fa;font-weight:600">@ViewBag.AreaName</span>
                </div>
            </div>
        </div>
        <button class="vl-add-btn" onclick="openCreateVersion(@ViewBag.AreaId)">
            <i class="fas fa-plus-circle"></i> Thêm Version mới
        </button>
    </div>

    <!-- STATS -->
    <div class="vl-stats">
        <div class="vl-stat" style="--accent:#3b82f6">
            <div class="val">@Model.Count</div>
            <div class="lbl">Tổng Version</div>
        </div>
        <div class="vl-stat" style="--accent:#4ade80">
            <div class="val">@Model.Count(v => v.IsActive == true)</div>
            <div class="lbl">Đang Active</div>
        </div>
        <div class="vl-stat" style="--accent:#f59e0b">
            <div class="val">@Model.Sum(v => v.SoPolygon ?? 0)</div>
            <div class="lbl">Tổng Polygon</div>
        </div>
        <div class="vl-stat" style="--accent:#a78bfa">
            @{
                double totalArea = Model.Sum(v => v.DienTichBaoPhu ?? 0);
                double totalAreaKm = totalArea / 1_000_000.0;
                string totalAreaDisp = totalArea > 0 
                    ? (totalAreaKm >= 0.1 ? totalAreaKm.ToString("N2") + " km²" : totalArea.ToString("N0") + " m²")
                    : "0 m²";
            }
            <div class="val">@totalAreaDisp</div>
            <div class="lbl">Tổng diện tích</div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="vl-table-wrap">
        <table class="vl-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên Version</th>
                    <th>Ngày tạo</th>
                    <th>Cập nhật</th>
                    <th><i class="fas fa-vector-square"></i> Polygon</th>
                    <th><i class="fas fa-ruler-combined"></i> Diện tích</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 0; }
                @foreach (var v in Model)
                {
                    idx++;

                    <tr>
                        <td class="vl-num">@idx</td>
                        <td>
                            <div class="vl-ver-cell">
                                <div class="vl-ver-icon">🗺️</div>
                                <div>
                                    <div class="vl-ver-name">@v.VersionName</div>
                                    <div class="vl-ver-id">ID: @v.Id</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="vl-date">@(v.CreatedDate?.ToString("dd/MM/yyyy") ?? "—")</span></td>
                        <td><span class="vl-date">@(v.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span></td>
                        <td>
                            <div class="vl-chip">
                                <i class="fas fa-draw-polygon"></i>
                                @(v.SoPolygon ?? 0)
                            </div>
                        </td>
                        <td>
                            <div class="vl-area">
                                @{
                                    double dArea = v.DienTichBaoPhu ?? 0;
                                    double dAreaKm = dArea / 1_000_000.0;
                                    string dAreaStr = dArea > 0
                                        ? (dAreaKm >= 0.001 ? dAreaKm.ToString("N3") + " km²" : dArea.ToString("N0") + " m²")
                                        : "0 m²";
                                }
                                <span>@dAreaStr</span>
                            </div>
                        </td>
                        <td>
                            @if (v.IsActive == true)
                            {
                                <span class="vl-badge vl-badge-active">
                                    <i class="fas fa-circle" style="font-size:7px"></i> Active
                                </span>
                            }
                            else
                            {
                                <span class="vl-badge vl-badge-inactive">
                                    <i class="fas fa-circle" style="font-size:7px"></i> Inactive
                                </span>
                            }
                        </td>
                        <td>
                            <div class="vl-actions">
                                <button class="vl-btn vl-btn-map" onclick="openMap(@v.Id)" title="Mở bản đồ version này">
                                    <i class="fas fa-map"></i> Bản đồ
                                </button>
                                <button class="vl-btn vl-btn-dist" onclick="showVersionMatrix(@v.Id, '@v.VersionName', 'dist')" title="Tính toán ma trận khoảng cách">
                                    <i class="fas fa-arrows-alt-h"></i> Khoảng cách
                                </button>
                                <button class="vl-btn vl-btn-adj" onclick="showVersionMatrix(@v.Id, '@v.VersionName', 'adj')" title="Xác định các vùng kề">
                                    <i class="fas fa-link"></i> Vùng kề
                                </button>
                                <button class="vl-btn vl-btn-active" onclick="setActive(@v.Id)" title="Đặt làm version Active">
                                    <i class="fas fa-check"></i> Active
                                </button>
                                <button class="vl-btn vl-btn-del" onclick="deleteVersion(@v.Id)" title="Xóa version này">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot style="border-top:2px solid #334155; background:#0f172a66">
                <tr style="font-weight:800; color:#f1f5f9">
                    <td colspan="4" style="text-align:right; padding:16px; color:#64748b; font-size:11px; text-transform:uppercase; letter-spacing:.05em">Tổng tất cả version:</td>
                    <td>
                        <div class="vl-chip" style="background:#1e293b; border-color:#f59e0b22; color:#f59e0b">
                            <i class="fas fa-draw-polygon"></i>
                            @Model.Sum(v => v.SoPolygon ?? 0)
                        </div>
                    </td>
                    <td>
                        <div class="vl-area" style="color:#f59e0b">
                            @{
                                double sArea = Model.Sum(v => v.DienTichBaoPhu ?? 0);
                                double sAreaKm = sArea / 1_000_000.0;
                                string sAreaStr = sArea > 0 
                                    ? (sAreaKm >= 0.01 ? sAreaKm.ToString("N3") + " km²" : sArea.ToString("N0") + " m²")
                                    : "0 m²";
                            }
                            <span>@sAreaStr</span>
                        </div>
                    </td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>

        @if (!Model.Any())
        {
            <div style="text-align:center;padding:60px;color:#475569">
                <i class="fas fa-layer-group" style="font-size:44px;display:block;margin-bottom:14px;color:#334155"></i>
                <div style="font-size:16px;font-weight:700;color:#64748b">Chưa có Version nào</div>
                <div style="font-size:13px;color:#475569;margin-top:6px">Nhấn "Thêm Version mới" để bắt đầu</div>
            </div>
        }
    </div>
</div>

<!-- MODAL MA TRẬN PHẢN HỒI -->
<div id="matrixModal" class="am-overlay" onclick="if(event.target===this)closeMatrixModal()">
    <div class="am-modal" style="max-width:900px; width:90%; max-height:90vh; overflow-y:auto; background:#111827">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; border-bottom:1px solid #334155; padding-bottom:12px;">
            <h3 style="margin:0"><i class="fas fa-th" style="color:#f59e0b"></i> Ma trận dữ liệu: <span id="mtVerName" style="color:#f59e0b"></span></h3>
            <button class="am-btn-cancel" style="padding:6px 12px" onclick="closeMatrixModal()">X</button>
        </div>
        
        <div style="display:grid; grid-template-columns:1fr; gap:24px;">
            <div>
                <h4 style="color:#94a3b8; font-size:12px; text-transform:uppercase; margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-ruler-horizontal"></i> Ma trận khoảng cách (m)
                </h4>
                <div id="mtDistanceBox" style="overflow-x:auto; background:#0f172a; border-radius:10px; border:1px solid #334155; padding:4px;">
                    <!-- Table rendered here -->
                </div>
            </div>
            
            <div>
                <h4 style="color:#94a3b8; font-size:12px; text-transform:uppercase; margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-link"></i> Danh sách vùng kề (Dựa trên Bounding Box)
                </h4>
                <div id="mtAdjacentBox" style="overflow-x:auto; background:#0f172a; border-radius:10px; border:1px solid #334155; padding:4px;">
                    <!-- Table rendered here -->
                </div>
            </div>
        </div>

        <div class="am-footer">
            <button class="am-btn-cancel" style="background:#475569; color:white" onclick="closeMatrixModal()">Đóng cửa sổ</button>
        </div>
    </div>
</div>

<script>
    function closeMatrixModal() {
        document.getElementById('matrixModal').classList.remove('open');
    }

    function showVersionMatrix(vId, vName, focusType = 'all') {
        document.getElementById('mtVerName').innerText = vName;
        const distBox = document.getElementById('mtDistanceBox');
        const adjBox = document.getElementById('mtAdjacentBox');
        
        distBox.innerHTML = '<div style="padding:40px; text-align:center; color:#64748b;"><i class="fas fa-circle-notch fa-spin" style="font-size:32px; margin-bottom:14px; display:block; color:#fbbf24"></i> Đang tải dữ liệu và phân tích không gian...</div>';
        adjBox.innerHTML = '';
        
        document.getElementById('matrixModal').classList.add('open');
        
        fetch("/Zone/GetZones?versionId=" + vId)
            .then(r => r.json())
            .then(zones => {
                if (!zones || zones.length === 0) {
                    distBox.innerHTML = '<div style="padding:40px; text-align:center; color:#64748b"><i class="fas fa-ghost" style="font-size:32px; display:block; margin-bottom:14px"></i> Không tìm thấy dữ liệu vùng cho Version này.</div>';
                    return;
                }
                
                // Helper: Tính bounds cho vùng (Fallback nếu không có Leaflet)
                function getPolygonBounds(points) {
                    try {
                        let pts = (typeof points === 'string') ? JSON.parse(points) : points;
                        if (!Array.isArray(pts)) return null;
                        
                        let minLat = 90, maxLat = -90, minLng = 180, maxLng = -180;
                        pts.forEach(p => {
                            let lat = (p[0] !== undefined) ? p[0] : p.lat;
                            let lng = (p[1] !== undefined) ? p[1] : p.lng;
                            if (lat < minLat) minLat = lat; if (lat > maxLat) maxLat = lat;
                            if (lng < minLng) minLng = lng; if (lng > maxLng) maxLng = lng;
                        });
                        return { minLat, maxLat, minLng, maxLng };
                    } catch(e) { return null; }
                }

                function checkIntersects(b1, b2) {
                    if (!b1 || !b2) return false;
                    return !(b2.minLat > b1.maxLat || b2.maxLat < b1.minLat || b2.minLng > b1.maxLng || b2.maxLng < b1.minLng);
                }

                // 1. Render Distance Matrix
                let distHtml = '<table class="vl-table" style="min-width:100%"><thead><tr><th>Vùng</th>';
                zones.forEach(z => { distHtml += `<th style="text-align:center; font-size:10px">${z.zoneName}</th>`; });
                distHtml += '</tr></thead><tbody>';
                
                zones.forEach((z1, i) => {
                    distHtml += `<tr><td style="background:#1e293b; font-weight:700; color:#fbbf24; font-size:11px">${z1.zoneName}</td>`;
                    zones.forEach((z2, j) => {
                        if (i === j) {
                            distHtml += '<td style="color:#475569; text-align:center">0</td>';
                        } else {
                            let d = 0;
                            // Tính khoảng cách Havorsine nhanh
                            const R = 6371e3; // meters
                            const p1 = z1.centerLat * Math.PI/180;
                            const p2 = z2.centerLat * Math.PI/180;
                            const dp = (z2.centerLat - z1.centerLat) * Math.PI/180;
                            const dl = (z2.centerLng - z1.centerLng) * Math.PI/180;
                            const a = Math.sin(dp/2) * Math.sin(dp/2) +
                                      Math.cos(p1) * Math.cos(p2) *
                                      Math.sin(dl/2) * Math.sin(dl/2);
                            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                            d = R * c;
                            
                            distHtml += `<td style="text-align:center; font-family:monospace; color:#e2e8f0; font-size:11px">${Math.round(d)}m</td>`;
                        }
                    });
                    distHtml += '</tr>';
                });
                distHtml += '</tbody></table>';
                distBox.innerHTML = distHtml;
                
                // 2. Render Adjacency Matrix
                let adjHtml = '<table class="vl-table" style="min-width:100%"><thead><tr><th>Vùng</th>';
                zones.forEach(z => { adjHtml += `<th style="text-align:center; font-size:10px">${z.zoneName}</th>`; });
                adjHtml += '</tr></thead><tbody>';
                
                // Tiền tính toán bounds cho tất cả zones
                const zoneBounds = zones.map(z => getPolygonBounds(z.points));

                zones.forEach((z1, i) => {
                    adjHtml += `<tr><td style="background:#1e293b; font-weight:700; color:#a78bfa; font-size:11px">${z1.zoneName}</td>`;
                    let b1 = zoneBounds[i];
                    
                    zones.forEach((z2, j) => {
                        if (i === j) {
                            adjHtml += '<td style="color:#475569; text-align:center">-</td>';
                        } else {
                            let b2 = zoneBounds[j];
                            let isAdj = checkIntersects(b1, b2);
                            adjHtml += `<td style="text-align:center"><span class="vl-badge ${isAdj ? 'vl-badge-active' : ''}" style="padding:2px 8px; font-size:10px; min-width:40px; justify-content:center; ${!isAdj?'opacity:0.25;border:none;background:transparent':''}">${isAdj ? 'KỀ' : '—'}</span></td>`;
                        }
                    });
                    adjHtml += '</tr>';
                });
                adjHtml += '</tbody></table>';
                adjBox.innerHTML = adjHtml;

                // Tự động cuộn đến phần quan tâm nếu cần
                if(focusType === 'adj') {
                    adjBox.parentElement.scrollIntoView({ behavior: 'smooth' });
                }
            })
            .catch(err => {
                console.error(err);
                distBox.innerHTML = '<div style="padding:30px; text-align:center; color:#f87171">Lỗi hệ thống khi tải hoặc tính toán ma trận.</div>';
            });
    }
</script>
