    let z = zonesData.find(x => x.zoneId === zoneId);
    if(!z) return;

    // Highlight row
    document.querySelectorAll('.dp-table tbody tr').forEach(r => r.classList.remove('selected'));
    let row = document.getElementById('row-' + zoneId);
    if(row) row.classList.add('selected');

    // Highlight polygon
    Object.values(mapPolygons).forEach(p => p.setStyle({ weight:2 }));
    if(mapPolygons[zoneId]){
        mapPolygons[zoneId].setStyle({ weight:5, color:'#f59e0b' });
        dashMap.fitBounds(mapPolygons[zoneId].getBounds(), { padding:[60,60] });
    }

    let m = document.getElementById('fMonth').value;
    let y = document.getElementById('fYear').value;

    // Build detail panel
    let panel = document.getElementById('zoneDetail');
    panel.innerHTML = `
        <div class="dp-detail-header">
            <div class="dp-detail-title">
                <i class="fas fa-map-pin" style="color:#f59e0b"></i>
