                <td style="font-weight:700;color:#f1f5f9">${z.zoneName}</td>
                <td style="color:#94a3b8">${z.areaName}</td>
                <td><input class="dp-inline-input" type="number" id="bo-${z.zoneId}" value="${z.ordersForecast||''}" placeholder="0"></td>
                <td><input class="dp-inline-input" type="number" id="bc-${z.zoneId}" value="${z.customersForecast||''}" placeholder="0"></td>
