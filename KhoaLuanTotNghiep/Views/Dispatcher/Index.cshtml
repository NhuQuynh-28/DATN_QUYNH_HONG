// ===================== AUTO-ASSIGN SECTION =====================
function initAssignFilters(){
    // Populate month
    let aaM = document.getElementById('aaMonth');
    if(aaM && !aaM.options.length){
        for(let i=1;i<=12;i++){
            let o = document.createElement('option');
            o.value=i; o.text='Tháng '+i;
            if(i===curMonth) o.selected=true;
            aaM.appendChild(o);
        }
    }
    // Populate year
    let aaY = document.getElementById('aaYear');
    if(aaY && !aaY.options.length){
        for(let y=curYear+1;y>=curYear-2;y--){
            let o = document.createElement('option');
            o.value=y; o.text=y;
            if(y===curYear) o.selected=true;
            aaY.appendChild(o);
        }
    }
    // Populate area
    let aaA = document.getElementById('aaArea');
    if(aaA && aaA.options.length <= 1){
        fetch('/Dispatcher/GetAllAreas')
        .then(r=>r.json())
        .then(areas=>{
            areas.forEach(a=>{
                let o = document.createElement('option');
                o.value=a.id; o.text=a.name;
                aaA.appendChild(o);
            });
        });
    }
}

