// ===== RUN AUTO ASSIGN =====
function runAutoAssign(){
    let areaId   = document.getElementById('aaArea').value;
    let month    = parseInt(document.getElementById('aaMonth').value);
    let year     = parseInt(document.getElementById('aaYear').value);
    let maxO     = parseInt(document.getElementById('aaMaxOrders').value)||999999;
    let maxC     = parseInt(document.getElementById('aaMaxCustomers').value)||999999;

    if(!areaId){ dpToast('Vui lòng chọn khu vực!', 'error'); return; }

    // Collect selected driver IDs
    let selectedDriverIds = [];
    document.querySelectorAll('.aa-driver-check:checked').forEach(cb => {
        selectedDriverIds.push(parseInt(cb.value));
    });

    if(selectedDriverIds.length === 0){
        dpToast('Vui lòng chọn ít nhất 1 tài xế!', 'error');
        return;
    }

    // Show loading
    document.getElementById('aaLoading').style.display = 'block';
    document.getElementById('aaMetrics').style.display = 'none';
    document.getElementById('aaResultWrap').style.display = 'none';
    document.getElementById('btnAutoAssign').disabled = true;

    fetch('/Dispatcher/AutoAssign', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({
            areaId,
            month,
            year,
            driverIds: selectedDriverIds,
            driverCount: selectedDriverIds.length,
            maxOrdersPerDriver: maxO,
            maxCustomersPerDriver: maxC
        })
    })
    .then(r=>r.json())
    .then(data=>{
        document.getElementById('aaLoading').style.display = 'none';
        document.getElementById('btnAutoAssign').disabled = false;

        if(!data.success){
            dpToast(data.message || 'Lỗi khi chạy phân công!', 'error');
            return;
        }

        // Show metrics
        document.getElementById('aaMetrics').style.display = 'block';
        document.getElementById('aaGreedyObj').textContent  = data.greedyObjective.toFixed(2);
        document.getElementById('aaBestObj').textContent    = data.bestObjective.toFixed(2);
        document.getElementById('aaImprove').textContent    = data.improvementPct.toFixed(1) + '%';
        document.getElementById('aaTime').textContent       = data.elapsedMs + 'ms';
        document.getElementById('aaCompact').textContent    = data.metrics.compactness.toFixed(4);

        // Show result visual
        document.getElementById('aaResultWrap').style.display = 'block';
        document.getElementById('aaMapArea').style.display = 'block';
        document.getElementById('aaPhaseLabel').textContent = `Phase: ${data.bestPhase} | Iter: ${data.bestIteration}`;

        // Color zones on map
        renderAaMapResults(data);

        let tbody = document.getElementById('aaTbody');
        tbody.innerHTML = data.slots.map((s,i) => {
            let color = driverColors[i % driverColors.length];
            let zoneList = s.zones.map(z =>
                `<span style="background:#334155;color:#94a3b8;padding:2px 7px;border-radius:5px;font-size:10px;margin:2px;display:inline-block;">`
                + `<b style="color:#f1f5f9">${z.zoneName}</b> (${z.orders}📦/${z.customers}KH)</span>`
            ).join('');

            let penColor = (s.totalOrders > maxO || s.totalCustomers > maxC) ? '#f87171' : '#4ade80';
            return `
            <tr onclick="highlightDriverZones(${i})" style="cursor:pointer" id="aa-driver-row-${i}">
                <td style="color:#475569;font-weight:700">${i+1}</td>
                <td style="font-weight:700;color:#f1f5f9">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div style="width:12px;height:12px;border-radius:3px;background:${color}"></div>
                        <span>${s.driverName}</span>
                    </div>
                </td>
                <td style="color:#3b82f6;font-weight:700">${s.zoneCount}</td>
                <td><span style="font-size:16px;font-weight:800;color:${penColor}">${s.totalOrders}</span>
                    ${s.totalOrders > maxO ? '<span style="color:#f87171;font-size:10px"> ⚠ Vượt tải</span>':''}
                </td>
                <td><span style="font-size:16px;font-weight:800;color:${penColor}">${s.totalCustomers}</span>
                    ${s.totalCustomers > maxC ? '<span style="color:#f87171;font-size:10px"> ⚠ Vượt tải</span>':''}
                </td>
                <td style="max-width:340px">${zoneList}</td>
            </tr>`;
        }).join('');

        // Summary on map right
        let dBody = document.getElementById('aaDriverTbody');
        if(dBody) {
            dBody.innerHTML = data.slots.map((s,i) => `
                <tr onclick="highlightDriverZones(${i})" style="cursor:pointer">
                    <td><div style="font-weight:600;color:#f1f5f9">${s.driverName}</div></td>
                    <td><span class="dp-badge dp-badge-ok">${s.zoneCount} vùng</span></td>
                    <td><div style="width:20px;height:20px;border-radius:4px;background:${driverColors[i % driverColors.length]}"></div></td>
                </tr>
            `).join('');
        }

        currentAssignmentResults = data;
        setTimeout(() => { if(aaMap) aaMap.invalidateSize(); }, 200);
        dpToast(`Phân công hoàn tất cho ${selectedDriverIds.length} tài xế! Cải thiện ${data.improvementPct.toFixed(1)}%`, 'success');
    })
    .catch(err=>{
        document.getElementById('aaLoading').style.display = 'none';
        document.getElementById('btnAutoAssign').disabled = false;
        dpToast('Lỗi kết nối: ' + err.message, 'error');
    });
}

function renderAaMapResults(data) {
    if(!aaMap) return;
    Object.values(aaPolygons).forEach(p => aaMap.removeLayer(p));
    if(aaMarkers) aaMarkers.forEach(m => aaMap.removeLayer(m));
    aaPolygons = {}; aaMarkers = [];
    let bounds = [];
    let areaId = document.getElementById('aaArea').value;
    
    fetch(`/Dispatcher/GetZonesByArea?areaId=${areaId}`).then(r=>r.json()).then(zResult=>{
        let all = zResult.zones || [];
        data.slots.forEach((slot, idx) => {
            let color = driverColors[idx % driverColors.length];
            slot.zones.forEach(sz => {
                let zInfo = all.find(x => x.id == sz.zoneId);
                if(!zInfo || !zInfo.points) return;
                try {
                    let pts = JSON.parse(zInfo.points);
                    let poly = L.polygon(pts, {color, weight:2, fillColor:color, fillOpacity:0.4}).addTo(aaMap);
                    aaPolygons[sz.zoneId] = poly;
                    let center = poly.getBounds().getCenter();
                    bounds.push(center);
                    let marker = L.marker(center, {interactive:false, icon:L.divIcon({
                        className:'zone-label',
                        html:`<div style="background:${color};color:white;padding:2px 6px;border-radius:4px;font-size:10px;font-weight:800;white-space:nowrap;box-shadow:0 2px 6px rgba(0,0,0,.3);border:1px solid rgba(255,255,255,0.3)">${sz.zoneName}</div>`
                    })}).addTo(aaMap);
                    aaMarkers.push(marker);
                    poly.bindTooltip(`<b>${slot.driverName}</b><br>${sz.zoneName}<br>${sz.orders} đơn`, {sticky:true});
                }catch(e){}
            });
        });
        if(bounds.length) aaMap.fitBounds(bounds, {padding:[40,40]});
    });
}

function highlightDriverZones(idx) {
    if(!currentAssignmentResults) return;
    let slot = currentAssignmentResults.slots[idx];
    if(!slot) return;
    Object.keys(aaPolygons).forEach(zid => aaPolygons[zid].setStyle({weight:2, fillOpacity:0.4}));
    let polys = [];
    slot.zones.forEach(sz => {
        let p = aaPolygons[sz.zoneId];
        if(p) { p.setStyle({weight:5, fillOpacity:0.7}); polys.push(p); }
    });
    document.querySelectorAll('#aaTbody tr').forEach(r => r.classList.remove('selected'));
    document.getElementById('aa-driver-row-' + idx)?.classList.add('selected');
    if(polys.length) {
        let group = new L.featureGroup(polys);
        aaMap.fitBounds(group.getBounds(), {padding:[100,100]});
    }
    dpToast(`Đã chọn tài xế: ${slot.driverName}`, 'info');
}

function saveAutoAssignResults(){
    if(!currentAssignmentResults || !currentAssignmentResults.success){
        dpToast('Không có kết quả phân công nào để lưu!', 'error');
        return;
    }
    let areaId = document.getElementById('aaArea').value;
    let month  = parseInt(document.getElementById('aaMonth').value);
    let year   = parseInt(document.getElementById('aaYear').value);
    let btn = document.getElementById('btnSaveAutoAssign');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
    let payload = {
        areaId: parseInt(areaId),
        month: month, year: year,
        items: currentAssignmentResults.slots.map(s => ({
            driverId: s.driverId,
            totalOrders: s.totalOrders,
            totalCustomers: s.totalCustomers,
            totalDistance: s.totalDistance || 0, 
            zoneIds: s.zones.map(z => z.zoneId)
        }))
    };

    fetch('/Dispatcher/SaveAssignments', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(payload)
    })
    .then(r => r.json())
    .then(data => {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Lưu kết quả này';
        
        if(data.success){
            dpToast(data.message, 'success');
        } else {
            dpToast(data.message, 'error');
        }
    })
    .catch(err => {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Lưu kết quả này';
        dpToast('Lỗi: ' + err.message, 'error');
    });
}
</script>
}