            <div class="dp-chart-box">
                <div class="dp-chart-title"><i class="fas fa-users"></i> Lịch sử Khách hàng</div>
                <canvas id="cCustomers"></canvas>
            </div>
        </div>

        <!-- ===== CASCADING FORECAST SECTION ===== -->
        <div style="margin-bottom:16px;">

