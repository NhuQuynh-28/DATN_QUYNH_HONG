                    placeholder="Nhập hoặc chọn gợi ý..."
                    oninput="onCurChanged(${zoneId})"
                    style="width:100%;padding-right:36px;">
                  <button onclick="toggleSuggest('suggestOrder')" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;color:#64748b;cursor:pointer;font-size:14px;">▾</button>
                </div>
                <div id="suggestOrder" style="display:none;position:absolute;z-index:99;left:0;right:0;background:#0f172a;border:1px solid #334155;border-radius:8px;margin-top:4px;box-shadow:0 8px 24px rgba(0,0,0,.4);overflow:hidden;">
                  <div style="padding:6px 8px;font-size:10px;color:#475569;border-bottom:1px solid #1e293b;">Chọn cách tính gợi ý</div>
                  <div class="dp-suggest-item" onclick="applySuggest('curOrder','wmaOrder','suggestOrder')">📊 Bình quân gia quyền 3 tháng (WMA)</div>
                  <div class="dp-suggest-item" onclick="applySuggest('curOrder','prevOrder','suggestOrder')">↩ Bằng tháng trước</div>
                  <div class="dp-suggest-item" onclick="applySuggest('curOrder','lastFcOrder','suggestOrder')">📋 Dự kiến cũ của T${m}</div>
                </div>
              </div>
              <!-- Customers -->
              <div style="flex:1;position:relative;">
                <div style="font-size:11px;color:#64748b;margin-bottom:4px;">Khách thực tế T${m}</div>
                <div style="position:relative;">
                  <input class="dp-form-input" type="number" id="curCustomer"
                    placeholder="Nhập hoặc chọn gợi ý..."
                    oninput="onCurChanged(${zoneId})"
                    style="width:100%;padding-right:36px;">
                  <button onclick="toggleSuggest('suggestCustomer')" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;color:#64748b;cursor:pointer;font-size:14px;">▾</button>
