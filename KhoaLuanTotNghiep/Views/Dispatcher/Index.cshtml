@{
    Layout = "~/Views/Shared/_LayoutDispatcher.cshtml";
}

<style>
/* ===== DISPATCHER DASHBOARD ===== */
.dp-section { display:none; }
.dp-section.active { display:block; }

/* STATS ROW */
.dp-stats { display:flex; gap:14px; margin-bottom:22px; flex-wrap:wrap; }
.dp-stat {
    background:#1e293b; border:1px solid #334155; border-radius:14px;
    padding:18px 22px; min-width:160px; flex:1; position:relative; overflow:hidden;
}
.dp-stat::before { content:''; position:absolute; top:0;left:0;right:0; height:3px; background:var(--c,#3b82f6); }
.dp-stat .val { font-size:28px; font-weight:800; color:var(--c,#3b82f6); line-height:1; }
.dp-stat .lbl { font-size:11px; color:#64748b; margin-top:6px; font-weight:700; text-transform:uppercase; letter-spacing:.04em; }

/* FILTER BAR */
.dp-filter {
    display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap; align-items:center;
    background:#1e293b; border-radius:12px; padding:14px 18px; border:1px solid #334155;
}
.dp-filter label { font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:.04em; margin-right:4px; }
.dp-select {
    background:#0f172a; border:1px solid #334155; border-radius:8px;
    padding:8px 12px; color:#f1f5f9; font-size:13px; outline:none; font-family:inherit;
}
.dp-select:focus { border-color:#f59e0b; }
.dp-btn-filter {
    display:inline-flex; align-items:center; gap:6px;
    background:linear-gradient(135deg,#f59e0b,#d97706); color:white;
    border:none; padding:9px 18px; border-radius:9px; font-size:12px; font-weight:700;
    cursor:pointer; transition:opacity .15s; font-family:inherit;
}
.dp-btn-filter:hover { opacity:.88; }
.dp-btn-outline {
    display:inline-flex; align-items:center; gap:6px;
    background:#334155; color:#e2e8f0; border:none; padding:9px 16px;
    border-radius:9px; font-size:12px; font-weight:700; cursor:pointer; font-family:inherit;
}
.dp-btn-save {
    background:#22c55e; color:white; border:none; padding:8px 16px; border-radius:10px;
    font-size:12px; font-weight:700; cursor:pointer; transition:.2s; display:flex; align-items:center; gap:8px;
}
.dp-btn-save:hover { background:#16a34a; transform:translateY(-1px); box-shadow:0 4px 12px rgba(34,197,94,.3); }
.dp-btn-save:disabled { background:#334155; color:#64748b; cursor:not-allowed; }
.dp-btn-outline:hover { background:#475569; }

/* MAP */
.dp-map-wrap {
    background:#1e293b; border-radius:14px; border:1px solid #334155;
    overflow:hidden; margin-bottom:22px;
}
.dp-map-header {
    display:flex; justify-content:space-between; align-items:center;
    padding:14px 18px; border-bottom:1px solid #334155;
}
.dp-map-title { font-size:14px; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:8px; }
.dp-legend { display:flex; gap:14px; }
.dp-legend-item { display:flex; align-items:center; gap:5px; font-size:11px; color:#94a3b8; }
.dp-legend-dot { width:10px; height:10px; border-radius:3px; }

/* TABLE */
.dp-table-wrap {
    background:#1e293b; border-radius:14px; border:1px solid #334155;
    overflow:hidden; margin-bottom:22px;
}
.dp-table-header {
    display:flex; justify-content:space-between; align-items:center;
    padding:14px 18px; border-bottom:1px solid #334155;
}
.dp-table-title { font-size:14px; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:8px; }
.dp-table { width:100%; border-collapse:collapse; font-size:13px; }
.dp-table thead tr { background:#0f172a; }
.dp-table th {
    padding:12px 14px; text-align:left; color:#64748b; font-weight:700;
    font-size:11px; text-transform:uppercase; letter-spacing:.04em;
    border-bottom:1px solid #334155; white-space:nowrap;
}
.dp-table tbody tr {
    border-bottom:1px solid #0f172a44; transition:background .15s; cursor:pointer;
}
.dp-table tbody tr:hover { background:#0f172a88; }
.dp-table tbody tr.selected { background:#f59e0b11; border-left:3px solid #f59e0b; }
.dp-table td { padding:12px 14px; vertical-align:middle; color:#e2e8f0; }

/* BADGE */
.dp-badge {
    display:inline-flex; align-items:center; gap:4px;
    padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;
}
.dp-badge-ok { background:#16a34a22; color:#4ade80; border:1px solid #16a34a44; }
.dp-badge-miss { background:#dc262622; color:#f87171; border:1px solid #dc262644; }

/* INLINE INPUT */
.dp-inline-input {
    background:#0f172a; border:1px solid #334155; border-radius:6px;
    padding:5px 8px; color:#f1f5f9; font-size:12px; outline:none;
    width:80px; text-align:center; font-family:inherit;
}
.dp-inline-input:focus { border-color:#f59e0b; }

/* DETAIL PANEL */
.dp-detail {
    background:#1e293b; border-radius:14px; border:1px solid #334155;
    padding:24px; margin-bottom:22px; display:none;
    animation: slideIn .3s ease;
}
.dp-detail.show { display:block; }
@@keyframes slideIn {
    from { opacity:0; transform:translateY(12px); }
    to { opacity:1; transform:translateY(0); }
}
.dp-detail-header {
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid #334155;
}
.dp-detail-title { font-size:18px; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:10px; }
.dp-detail-close {
    background:#334155; border:none; border-radius:8px; padding:8px 12px;
    color:#94a3b8; cursor:pointer; font-size:13px;
}
.dp-detail-close:hover { background:#475569; color:white; }

/* CHARTS */
.dp-charts { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px; }
.dp-chart-box {
    background:#0f172a; border-radius:12px; padding:16px;
    border:1px solid #334155;
}
.dp-chart-title { font-size:12px; color:#64748b; font-weight:700; text-transform:uppercase; margin-bottom:10px; }

/* FORECAST FORM */
.dp-forecast-form {
    display:flex; gap:14px; align-items:flex-end; flex-wrap:wrap;
    background:#0f172a; border-radius:12px; padding:18px; border:1px solid #334155;
}
.dp-form-group { display:flex; flex-direction:column; gap:5px; }
.dp-form-label { font-size:11px; color:#94a3b8; font-weight:700; text-transform:uppercase; }
.dp-form-input {
    background:#1e293b; border:1px solid #334155; border-radius:8px;
    padding:10px 14px; color:#f1f5f9; font-size:14px; font-weight:600;
    outline:none; width:160px; font-family:inherit;
}
.dp-form-input:focus { border-color:#f59e0b; }
.dp-form-hint { font-size:10px; color:#475569; font-style:italic; }
.dp-btn-save {
    display:inline-flex; align-items:center; gap:6px;
    background:linear-gradient(135deg,#22c55e,#16a34a); border:none;
    border-radius:9px; padding:10px 22px; color:white; font-size:13px;
    font-weight:700; cursor:pointer; font-family:inherit;
}
.dp-btn-save:hover { opacity:.88; }
.dp-btn-predict {
    display:inline-flex; align-items:center; gap:6px;
    background:#1c3d5a; color:#38bdf8; border:none;
    border-radius:9px; padding:10px 16px; font-size:12px;
    font-weight:700; cursor:pointer; font-family:inherit;
}
.dp-btn-predict:hover { background:#0284c7; color:white; }

/* HISTORY TABLE */
.dp-hist-table { width:100%; border-collapse:collapse; font-size:12px; margin-top:16px; }
.dp-hist-table th {
    padding:10px 12px; text-align:left; color:#64748b; font-weight:700;
    font-size:10px; text-transform:uppercase; background:#0f172a; letter-spacing:.03em;
}
.dp-hist-table td { padding:10px 12px; border-bottom:1px solid #1e293b44; color:#e2e8f0; }
.dp-hist-table tr:hover td { background:#0f172a55; }

/* EMPTY STATE */
.dp-empty { text-align:center; padding:50px 20px; }
.dp-empty i { font-size:42px; color:#334155; display:block; margin-bottom:14px; }
.dp-empty .t { font-size:15px; font-weight:700; color:#64748b; }
.dp-empty .s { font-size:12px; color:#475569; margin-top:6px; }

/* SECTION HEADER */
.dp-section-header {
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:20px;
}
.dp-section-title { font-size:20px; font-weight:800; color:#f1f5f9; display:flex; align-items:center; gap:10px; }

/* Pulse animation for missing zones */
@@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}
/* SUGGEST DROPDOWN ITEMS */
.dp-suggest-item {
    padding:10px 14px; font-size:12px; color:#e2e8f0; cursor:pointer;
    transition:background .12s; border-bottom:1px solid #1e293b;
}
.dp-suggest-item:last-child { border-bottom:none; }
.dp-suggest-item:hover { background:#1e293b; color:#f59e0b; }

/* Form input full width override */
.dp-form-input { width:100%; box-sizing:border-box; }
</style>

<!-- ==================== SECTION: DASHBOARD ==================== -->
<div class="dp-section active" id="secDashboard">

    <div class="dp-section-header">
        <div class="dp-section-title"><i class="fas fa-chart-pie" style="color:#f59e0b"></i> Tổng quan dự kiến</div>
    </div>

    <!-- FILTER -->
    <div class="dp-filter">
        <div>
            <label>Tháng</label>
            <select class="dp-select" id="fMonth"></select>
        </div>
        <div>
            <label>Năm</label>
            <select class="dp-select" id="fYear"></select>
        </div>
        <div>
            <label>Khu vực</label>
            <select class="dp-select" id="fArea">
                <option value="">Tất cả</option>
            </select>
        </div>
        <div>
            <label>Trạng thái</label>
            <select class="dp-select" id="fStatus">
                <option value="">Tất cả</option>
                <option value="missing">⚠ Chưa nhập</option>
                <option value="entered">✅ Đã nhập</option>
            </select>
        </div>
        <button class="dp-btn-filter" onclick="loadDashboard()">
            <i class="fas fa-search"></i> Lọc
        </button>
    </div>

    <!-- STATS -->
    <div class="dp-stats" id="dashStats"></div>

    <!-- MAP -->
    <div class="dp-map-wrap">
        <div class="dp-map-header">
            <div class="dp-map-title"><i class="fas fa-map" style="color:#f59e0b"></i> Bản đồ vùng giao hàng</div>
            <div class="dp-legend">
                <div class="dp-legend-item"><div class="dp-legend-dot" style="background:#22c55e"></div> Đã nhập</div>
                <div class="dp-legend-item"><div class="dp-legend-dot" style="background:#ef4444"></div> Chưa nhập</div>
            </div>
        </div>
        <div id="map" style="height:420px;"></div>
    </div>

    <!-- ZONE TABLE -->
    <div class="dp-table-wrap">
        <div class="dp-table-header">
            <div class="dp-table-title"><i class="fas fa-layer-group" style="color:#3b82f6"></i> Danh sách vùng</div>
            <button class="dp-btn-outline" id="btnBatchSave" onclick="saveBatch()" style="display:none">
                <i class="fas fa-save"></i> Lưu tất cả
            </button>
        </div>
        <table class="dp-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Vùng</th>
                    <th>Khu vực</th>
                    <th>Order dự kiến</th>
                    <th>Khách dự kiến</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="zoneTbody"></tbody>
        </table>
    </div>

    <!-- ZONE DETAIL PANEL (appears when clicking a zone) -->
    <div class="dp-detail" id="zoneDetail"></div>

</div>

<!-- ==================== SECTION: FORECAST ==================== -->
<div class="dp-section" id="secForecast">
    <div class="dp-section-header">
        <div class="dp-section-title"><i class="fas fa-edit" style="color:#f59e0b"></i> Nhập dự kiến hàng loạt</div>
    </div>
    <div class="dp-filter">
        <div>
            <label>Tháng</label>
            <select class="dp-select" id="bfMonth"></select>
        </div>
        <div>
            <label>Năm</label>
            <select class="dp-select" id="bfYear"></select>
        </div>
        <div>
            <label>Khu vực</label>
            <select class="dp-select" id="bfArea">
                <option value="">Tất cả</option>
            </select>
        </div>
        <button class="dp-btn-filter" onclick="loadBatchForecast()">
            <i class="fas fa-search"></i> Tải danh sách
        </button>
        <button class="dp-btn-outline" onclick="autoFillAll()">
            <i class="fas fa-magic"></i> Auto-fill dự đoán
        </button>
        <button class="dp-btn-save" id="btnBatchSave2" onclick="saveBatchForecast()">
            <i class="fas fa-save"></i> Lưu tất cả
        </button>
    </div>
    <div class="dp-table-wrap">
        <table class="dp-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Vùng</th>
                    <th>Khu vực</th>
                    <th>Order dự kiến</th>
                    <th>Khách dự kiến</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody id="batchTbody"></tbody>
        </table>
    </div>
</div>

<!-- ==================== SECTION: MAP ==================== -->
<div class="dp-section" id="secMap">
    <div class="dp-section-header">
        <div class="dp-section-title"><i class="fas fa-map-marked-alt" style="color:#f59e0b"></i> Bản đồ chi tiết</div>
    </div>
    <div class="dp-filter">
        <div>
            <label>Khu vực</label>
            <select class="dp-select" id="mapArea" onchange="loadFullMap()">
                <option value="">Tất cả</option>
            </select>
        </div>
    </div>
    <div class="dp-map-wrap">
        <div id="mapFull" style="height:calc(100vh - 260px); min-height:400px;"></div>
    </div>
</div>

<!-- ==================== SECTION: AUTO-ASSIGN ==================== -->
<div class="dp-section" id="secAssign">
    <div class="dp-section-header">
        <div class="dp-section-title"><i class="fas fa-user-check" style="color:#22c55e"></i> Phân công tự động</div>
    </div>

    <!-- Step 1: Config Panel -->
    <div class="dp-filter" style="margin-bottom:16px;">
        <div>
            <label>Khu vực</label>
            <select class="dp-select" id="aaArea" onchange="loadDriversForArea()"><option value="">-- Chọn khu vực --</option></select>
        </div>
        <div>
            <label>Tháng (dự báo)</label>
            <select class="dp-select" id="aaMonth"></select>
        </div>
        <div>
            <label>Năm</label>
            <select class="dp-select" id="aaYear"></select>
        </div>
        <div>
            <label>Đơn tối đa/TX</label>
            <input class="dp-select" type="number" id="aaMaxOrders" value="999999" min="1" style="width:90px;">
        </div>
        <div>
            <label>KH tối đa/TX</label>
            <input class="dp-select" type="number" id="aaMaxCustomers" value="999999" min="1" style="width:90px;">
        </div>
    </div>

    <!-- Step 2: Driver Selection Panel -->
    <div id="aaDriverPanel" style="display:none; margin-bottom:18px;">
        <div class="dp-table-wrap" style="margin-bottom:0;">
            <div class="dp-table-header">
                <div class="dp-table-title">
                    <i class="fas fa-users" style="color:#3b82f6"></i>
                    Chọn tài xế phân công
                    <span id="aaDriverCount" style="font-size:12px;color:#64748b;font-weight:400;margin-left:8px"></span>
                </div>
                <div style="display:flex;gap:8px;align-items:center;">
                    <input class="dp-select" id="aaDriverSearch" placeholder="🔍 Tìm tài xế..." oninput="filterDriverCheckboxes()" style="width:180px;font-size:12px;padding:6px 10px;">
                    <button class="dp-btn-outline" style="font-size:11px;padding:6px 12px" onclick="toggleAllDrivers(true)">
                        <i class="fas fa-check-double"></i> Chọn tất cả
                    </button>
                    <button class="dp-btn-outline" style="font-size:11px;padding:6px 12px;background:#1c2333" onclick="toggleAllDrivers(false)">
                        <i class="fas fa-times"></i> Bỏ chọn
                    </button>
                    <button class="dp-btn-filter" onclick="runAutoAssign()" id="btnAutoAssign">
                        <i class="fas fa-robot"></i> Chạy phân công
                    </button>
                </div>
            </div>
            <table class="dp-table" id="aaDriverSelectTable">
                <thead>
                    <tr>
                        <th style="width:40px"><input type="checkbox" id="aaCheckAll" onchange="toggleAllDrivers(this.checked)" style="cursor:pointer"></th>
                        <th>Tài xế</th>
                        <th>SĐT</th>
                        <th>Khu vực</th>
                        <th>Phân công hiện tại</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="aaDriverSelectTbody">
                    <tr><td colspan="6" style="text-align:center;padding:30px;color:#475569">Chọn khu vực để xem danh sách tài xế</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Map & Legend Row -->
    <div id="aaMapArea" style="display:none; margin-bottom:18px;">
        <div style="display:grid; grid-template-columns: 1fr 300px; gap:16px;">
            <div class="dp-map-wrap" style="margin-bottom:0;">
                <div class="dp-map-header">
                    <div class="dp-map-title"><i class="fas fa-map-marked-alt"></i> Phân vùng theo tài xế</div>
                    <div id="aaMapLegend" style="display:flex; flex-wrap:wrap; gap:10px; max-height:40px; overflow-y:auto;"></div>
                </div>
                <div id="aaMap" style="height:480px;"></div>
            </div>
            
            <div class="dp-table-wrap" style="margin-bottom:0; display:flex; flex-direction:column;">
                <div class="dp-table-header">
                    <div class="dp-table-title"><i class="fas fa-users"></i> Tài xế & Vùng</div>
                </div>
                <div style="flex:1; overflow-y:auto;">
                    <table class="dp-table" id="aaDriverSummaryTable">
                        <thead>
                            <tr><th>Tài xế</th><th>Số vùng</th><th>Màu</th></tr>
                        </thead>
                        <tbody id="aaDriverTbody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Metrics / Progress Row -->
    <div id="aaMetrics" style="display:none; margin-bottom:16px;">
        <div class="dp-stats">
            <div class="dp-stat" style="--c:#f59e0b">
                <div class="val" id="aaGreedyObj">-</div>
                <div class="lbl">Greedy Objective</div>
            </div>
            <div class="dp-stat" style="--c:#22c55e">
                <div class="val" id="aaBestObj">-</div>
                <div class="lbl">Best Objective (ALNS)</div>
            </div>
            <div class="dp-stat" style="--c:#3b82f6">
                <div class="val" id="aaImprove">-</div>
                <div class="lbl">Cải thiện (%)</div>
            </div>
            <div class="dp-stat" style="--c:#8b5cf6">
                <div class="val" id="aaTime">-</div>
                <div class="lbl">Thời gian chạy</div>
            </div>
            <div class="dp-stat" style="--c:#ec4899">
                <div class="val" id="aaCompact">-</div>
                <div class="lbl">Tính nhỏ gọn</div>
            </div>
        </div>
    </div>

    <!-- Result Table -->
    <div class="dp-table-wrap" id="aaResultWrap" style="display:none;">
        <div class="dp-table-header">
            <div class="dp-table-title"><i class="fas fa-table"></i> Kết quả phân công</div>
            <div style="display:flex; align-items:center; gap:12px;">
                <div style="font-size:11px;color:#64748b" id="aaPhaseLabel"></div>
                <button class="dp-btn-save" onclick="saveAutoAssignResults()" id="btnSaveAutoAssign">
                    <i class="fas fa-save"></i> Lưu kết quả này
                </button>
            </div>
        </div>
        <table class="dp-table" id="aaTable">
            <thead><tr>
                <th>#</th>
                <th>Tài xế</th>
                <th>Số vùng</th>
                <th>Tổng đơn dự báo (ARIMA)</th>
                <th>Tổng KH dự báo (ARIMA)</th>
                <th>Danh sách vùng</th>
            </tr></thead>
            <tbody id="aaTbody"></tbody>
        </table>
    </div>

    <!-- Loading Indicator -->
    <div id="aaLoading" style="display:none;text-align:center;padding:40px;">
        <i class="fas fa-spinner fa-spin" style="font-size:32px;color:#f59e0b;"></i>
        <div style="margin-top:12px;color:#94a3b8;font-size:14px;">Greedy → Local Search → ALNS đang chạy...</div>
        <div style="margin-top:6px;color:#475569;font-size:11px;">Có thể mất vài giây tùy theo số vùng</div>
    </div>

    <!-- Driver Edit Modal -->
    <div id="aaDriverEditOverlay" style="position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:9500;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)" onclick="if(event.target===this)closeDriverEditModal()">
        <div style="background:#1e293b;border:1px solid #334155;border-radius:16px;padding:28px;min-width:380px;max-width:420px;box-shadow:0 24px 64px rgba(0,0,0,.6)">
            <h3 id="aaEditTitle" style="margin:0 0 20px;font-size:16px;font-weight:700;color:#f1f5f9;display:flex;align-items:center;gap:8px">
                <i class="fas fa-pen" style="color:#f59e0b"></i> Chỉnh sửa tài xế
            </h3>
            <input type="hidden" id="aaEditId">
            <div style="margin-bottom:13px">
                <label style="display:block;font-size:11px;color:#94a3b8;font-weight:700;margin-bottom:5px;text-transform:uppercase">Họ tên</label>
                <input id="aaEditName" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:8px;padding:9px 12px;color:#f1f5f9;font-size:13px;outline:none;box-sizing:border-box">
            </div>
            <div style="margin-bottom:13px">
                <label style="display:block;font-size:11px;color:#94a3b8;font-weight:700;margin-bottom:5px;text-transform:uppercase">Số điện thoại</label>
                <input id="aaEditPhone" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:8px;padding:9px 12px;color:#f1f5f9;font-size:13px;outline:none;box-sizing:border-box">
            </div>
            <div style="margin-bottom:13px">
                <label style="display:block;font-size:11px;color:#94a3b8;font-weight:700;margin-bottom:5px;text-transform:uppercase">Trạng thái</label>
                <select id="aaEditStatus" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:8px;padding:9px 12px;color:#f1f5f9;font-size:13px;outline:none;box-sizing:border-box">
                    <option value="DangLam">Đang làm</option>
                    <option value="NghiLam">Nghỉ làm</option>
                    <option value="RoiBo">Rời bỏ</option>
                </select>
            </div>
            <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px;padding-top:16px;border-top:1px solid #334155">
                <button onclick="closeDriverEditModal()" style="background:#334155;border:none;border-radius:8px;padding:9px 18px;color:#94a3b8;font-size:13px;cursor:pointer">Hủy</button>
                <button onclick="saveDriverEdit()" style="background:linear-gradient(135deg,#3b82f6,#2563eb);border:none;border-radius:8px;padding:9px 22px;color:white;font-size:13px;font-weight:700;cursor:pointer">
                    <i class="fas fa-save"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ===================== GLOBAL STATE =====================
let dashMap = null;
let fullMap = null;
let selectedZoneId = null;
let orderChart = null;
let customerChart = null;
let zonesData = [];
let mapPolygons = {};
let currentAssignmentResults = null;
let aaMap = null;
let aaPolygons = {};
let aaMarkers = [];

const driverColors = [
    '#3b82f6', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', 
    '#ec4899', '#06b6d4', '#10b981', '#f43f5e', '#6366f1',
    '#14b8a6', '#f97316', '#a855f7', '#d946ef', '#2dd4bf'
];

const now = new Date();
const curMonth = now.getMonth() + 1;
const curYear = now.getFullYear();

// ===================== INIT =====================
document.addEventListener("DOMContentLoaded", () => {
    initFilters();
    loadAreas();
    initDashMap();
    
    // Nếu là Driver -> Tự động chuyển sang TAB Bản đồ
    var currentRole = '@Context.Session.GetString("Role")';
    if(currentRole === 'Driver') {
        onMenuSwitch('map');
    } else {
        loadDashboard();
    }
});

function initFilters(){
    // Month selects
    ['fMonth','bfMonth'].forEach(id => {
        let sel = document.getElementById(id);
        for(let i=1;i<=12;i++){
            let o = document.createElement('option');
            o.value = i; o.text = 'Tháng ' + i;
            if(i === curMonth) o.selected = true;
            sel.appendChild(o);
        }
    });
    // Year selects
    ['fYear','bfYear'].forEach(id => {
        let sel = document.getElementById(id);
        for(let y=curYear+1; y >= curYear-2; y--){
            let o = document.createElement('option');
            o.value = y; o.text = y;
            if(y === curYear) o.selected = true;
            sel.appendChild(o);
        }
    });
}

function loadAreas(){
    fetch('/Dispatcher/GetAllAreas')
    .then(r=>r.json())
    .then(areas => {
        ['fArea','bfArea','mapArea'].forEach(id => {
            let sel = document.getElementById(id);
            if(!sel) return;
            // Keep first option
            areas.forEach(a => {
                let o = document.createElement('option');
                o.value = a.id; o.text = a.name;
                sel.appendChild(o);
            });
        });
    });
}

// ===================== MENU SWITCH =====================
function onMenuSwitch(menu){
    document.querySelectorAll('.dp-section').forEach(s => s.classList.remove('active'));
    if(menu === 'dashboard'){
        document.getElementById('secDashboard').classList.add('active');
        setTimeout(() => { if(dashMap) dashMap.invalidateSize(); }, 100);
    } else if(menu === 'forecast'){
        document.getElementById('secForecast').classList.add('active');
        loadBatchForecast();
    } else if(menu === 'map'){
        document.getElementById('secMap').classList.add('active');
        setTimeout(() => {
            if(!fullMap) initFullMap();
            else fullMap.invalidateSize();
            loadFullMap();
        }, 100);
    } else if(menu === 'assign'){
        document.getElementById('secAssign').classList.add('active');
        initAssignFilters();
        setTimeout(() => { 
            if(!aaMap) initAaMap(); 
            else aaMap.invalidateSize();
        }, 100);
    }
}

// ===================== AA MAP =====================
function initAaMap(){
    aaMap = L.map('aaMap').setView([21.0285, 105.8542], 11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap contributors'
    }).addTo(aaMap);
}

// ===================== DASH MAP =====================
function initDashMap(){
    dashMap = L.map('map').setView([21.0285, 105.8542], 11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {maxZoom:19}).addTo(dashMap);
}

function initFullMap(){
    fullMap = L.map('mapFull').setView([21.0285, 105.8542], 11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {maxZoom:19}).addTo(fullMap);
}

// ===================== LOAD DASHBOARD =====================
function loadDashboard(){
    let mEl = document.getElementById('fMonth');
    let yEl = document.getElementById('fYear');
    let aEl = document.getElementById('fArea');
    let sEl = document.getElementById('fStatus');

    if(!mEl || !yEl) return;

    let m = mEl.value || curMonth;
    let y = yEl.value || curYear;
    let a = aEl?.value || "";
    let s = sEl?.value || "";

    fetch(`/Dispatcher/GetForecastStatus?month=${m}&year=${y}&areaId=${a}&filter=${s}`)
    .then(r => r.json())
    .then(data => {
        zonesData = data.zones;
        renderStats(data.summary, m, y);
        renderMap(data.zones);
        renderTable(data.zones);
    })
    .catch(err => {
        console.error("Fetch error:", err);
        dpToast("Lỗi khi tải dữ liệu!", "error");
    });
}

function renderStats(s, m, y){
    document.getElementById('dashStats').innerHTML = `
        <div class="dp-stat" style="--c:#3b82f6">
            <div class="val">${s.total}</div><div class="lbl">Tổng vùng</div>
        </div>
        <div class="dp-stat" style="--c:#22c55e">
            <div class="val">${s.entered}</div><div class="lbl">Đã nhập T${m}</div>
        </div>
        <div class="dp-stat" style="--c:#ef4444">
            <div class="val">${s.missing}</div><div class="lbl">Chưa nhập</div>
        </div>
        <div class="dp-stat" style="--c:#f59e0b">
            <div class="val">${s.totalOrders.toLocaleString()}</div><div class="lbl">Tổng order dự kiến</div>
        </div>
        <div class="dp-stat" style="--c:#8b5cf6">
            <div class="val">${s.totalCustomers.toLocaleString()}</div><div class="lbl">Tổng khách dự kiến</div>
        </div>
    `;
}

function renderMap(zones){
    // Clear old polygons
    dashMap.eachLayer(l => {
        if(l instanceof L.Polygon || l instanceof L.Marker) dashMap.removeLayer(l);
    });
    // Keep tile layer
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {maxZoom:19}).addTo(dashMap);

    mapPolygons = {};
    let bounds = [];

    zones.forEach(z => {
        if(!z.points) return;
        try {
            let pts = JSON.parse(z.points);
            let color = z.hasForecast ? '#22c55e' : '#ef4444';
            let fillOp = z.hasForecast ? 0.25 : 0.35;

            let poly = L.polygon(pts, {
                color: color, weight: 2, fillOpacity: fillOp,
                dashArray: z.hasForecast ? null : '6,4'
            }).addTo(dashMap);

            mapPolygons[z.zoneId] = poly;

            let center = poly.getBounds().getCenter();
            bounds.push(center);

            L.marker(center, {
                interactive: false,
                icon: L.divIcon({
                    className: 'zone-label',
                    html: `<div style="
                        background:${z.hasForecast ? '#16a34a' : '#dc2626'};
                        color:white; padding:3px 8px; border-radius:6px;
                        font-size:11px; font-weight:700; white-space:nowrap;
                        box-shadow:0 2px 8px rgba(0,0,0,.3);
                    ">${z.zoneName} ${z.hasForecast ? '✅' : '⚠'}</div>`
                })
            }).addTo(dashMap);

            poly.on('click', () => openZoneDetail(z.zoneId));
        } catch(e){}
    });

    if(bounds.length > 0){
        dashMap.fitBounds(bounds, { padding:[30,30] });
    }
}

function renderTable(zones){
    let tbody = document.getElementById('zoneTbody');
    if(!zones.length){
        tbody.innerHTML = `<tr><td colspan="7"><div class="dp-empty">
            <i class="fas fa-inbox"></i>
            <div class="t">Không có dữ liệu</div>
            <div class="s">Thay đổi bộ lọc để xem vùng khác</div>
        </div></td></tr>`;
        return;
    }

    let hasMissing = zones.some(z => !z.hasForecast);
    document.getElementById('btnBatchSave').style.display = hasMissing ? '' : 'none';

    tbody.innerHTML = zones.map((z, i) => `
        <tr onclick="openZoneDetail(${z.zoneId})" id="row-${z.zoneId}" data-zone="${z.zoneId}">
            <td style="color:#475569;font-weight:700">${i+1}</td>
            <td>
                <div style="font-weight:700;color:#f1f5f9">${z.zoneName}</div>
                <div style="font-size:10px;color:#475569">ID: ${z.zoneId}</div>
            </td>
            <td style="color:#94a3b8">${z.areaName}</td>
            <td>
                ${z.hasForecast
                    ? `<span style="font-weight:700;color:#60a5fa">${z.ordersForecast}</span>`
                    : `<input class="dp-inline-input" type="number" id="io-${z.zoneId}" placeholder="0" onclick="event.stopPropagation()">`
                }
            </td>
            <td>
                ${z.hasForecast
                    ? `<span style="font-weight:700;color:#a78bfa">${z.customersForecast}</span>`
                    : `<input class="dp-inline-input" type="number" id="ic-${z.zoneId}" placeholder="0" onclick="event.stopPropagation()">`
                }
            </td>
            <td>
                ${z.hasForecast
                    ? `<span class="dp-badge dp-badge-ok"><i class="fas fa-check-circle" style="font-size:9px"></i> Đã nhập</span>`
                    : `<span class="dp-badge dp-badge-miss"><i class="fas fa-exclamation-circle" style="font-size:9px"></i> Chưa nhập</span>`
                }
            </td>
            <td>
                <button class="dp-btn-predict" style="font-size:11px;padding:5px 10px" onclick="event.stopPropagation();openZoneDetail(${z.zoneId})">
                    <i class="fas fa-chart-line"></i> Chi tiết
                </button>
            </td>
        </tr>
    `).join('');
}

// ===================== BATCH SAVE FROM TABLE =====================
function saveBatch(){
    let m = parseInt(document.getElementById('fMonth').value);
    let y = parseInt(document.getElementById('fYear').value);
    let items = [];

    zonesData.filter(z => !z.hasForecast).forEach(z => {
        let oEl = document.getElementById('io-' + z.zoneId);
        let cEl = document.getElementById('ic-' + z.zoneId);
        let o = parseInt(oEl?.value) || 0;
        let c = parseInt(cEl?.value) || 0;
        if(o > 0 || c > 0) items.push({ zoneId: z.zoneId, ordersForecast: o, customersForecast: c });
    });

    if(!items.length){ dpToast('Chưa nhập giá trị nào!', 'error'); return; }

    fetch('/Dispatcher/SaveBatchForecast', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ month:m, year:y, items })
    })
    .then(r => r.json())
    .then(d => {
        if(d.success){
            dpToast(`Đã lưu ${d.count} vùng thành công!`, 'success');
            loadDashboard();
        }
    });
}

// ===================== ZONE DETAIL =====================
function openZoneDetail(zoneId){
