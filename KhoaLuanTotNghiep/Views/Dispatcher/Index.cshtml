function autoFillAll(){
    let rows = document.querySelectorAll('#batchTbody tr[data-zone]');
    let promises = [];
    rows.forEach(row => {
        let zid = row.dataset.zone;
        promises.push(
            fetch('/Dispatcher/PredictForecast?zoneId=' + zid)
            .then(r => r.json())
            .then(d => {
                let oEl = document.getElementById('bo-' + zid);
                let cEl = document.getElementById('bc-' + zid);
                if(oEl && (!oEl.value || oEl.value === '0') && d.order > 0) oEl.value = d.order;
                if(cEl && (!cEl.value || cEl.value === '0') && d.customer > 0) cEl.value = d.customer;
            })
        );
    });
    Promise.all(promises).then(() => dpToast('Đã auto-fill dự đoán cho tất cả vùng!', 'info'));
}

function saveBatchForecast(){
    let mView = parseInt(document.getElementById('fMonth').value);
    let yView = parseInt(document.getElementById('fYear').value);
    
    // Target is NEXT MONTH
    let m = mView + 1;
    let y = yView;
    if(m > 12){ m = 1; y++; }
    
    let items = [];

    document.querySelectorAll('#batchTbody tr[data-zone]').forEach(row => {
        let zid = parseInt(row.dataset.zone);
        let o = parseInt(document.getElementById('bo-' + zid)?.value) || 0;
        let c = parseInt(document.getElementById('bc-' + zid)?.value) || 0;
        if(o > 0 || c > 0) items.push({ zoneId:zid, ordersForecast:o, customersForecast:c });
    });

    if(!items.length){ dpToast('Chưa nhập giá trị nào!', 'error'); return; }

    fetch('/Dispatcher/SaveBatchForecast', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ month:m, year:y, items })
    })
    .then(r => r.json())
    .then(d => {
        if(d.success){
            dpToast(`Đã lưu ${d.count} vùng thành công!`, 'success');
            loadBatchForecast();
        }
    });
}

// ===================== FULL MAP =====================
function loadFullMap(){
    if(!fullMap) return;
    let a = document.getElementById('mapArea').value;

    // Clear
    fullMap.eachLayer(l => { if(l instanceof L.Polygon || l instanceof L.Marker) fullMap.removeLayer(l); });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {maxZoom:19}).addTo(fullMap);

    // Load zones for area
    let url = a ? `/Dispatcher/GetZonesByArea?areaId=${a}` : '/Dispatcher/GetForecastStatus?month='+curMonth+'&year='+curYear+'&areaId=&filter=';

    fetch(url)
    .then(r => r.json())
    .then(data => {
        let zonesList = data.zones || [];
        let bounds = [];

        zonesList.forEach(z => {
            let pts;
            try { pts = JSON.parse(z.points); } catch(e){ return; }
            let poly = L.polygon(pts, { color:'#3b82f6', fillOpacity:0.3 }).addTo(fullMap);
            let center = poly.getBounds().getCenter();
            bounds.push(center);

            L.marker(center, {
                interactive:false,
                icon: L.divIcon({
                    className:'zone-label',
                    html:`<div style="background:#2563eb;color:white;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.3)">${z.zoneName}</div>`
                })
            }).addTo(fullMap);
        });

        if(bounds.length) fullMap.fitBounds(bounds, { padding:[30,30] });
    });
}

