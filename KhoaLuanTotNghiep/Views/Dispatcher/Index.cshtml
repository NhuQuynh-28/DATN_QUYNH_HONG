function closeDetail(){
    document.getElementById('zoneDetail').classList.remove('show');
    document.querySelectorAll('.dp-table tbody tr').forEach(r => r.classList.remove('selected'));
    Object.values(mapPolygons).forEach(p => {
        let z = zonesData.find(x => x.zoneId == p._zoneId);
        // Reset style
    });
    selectedZoneId = null;
}

// ===================== ZONE HISTORY + CHARTS =====================
function loadZoneHistory(zoneId){
    fetch('/Dispatcher/GetZoneHistory?zoneId=' + zoneId)
    .then(r => r.json())
    .then(data => {
        renderHistoryTable(data);
        renderCharts(data);
    });
}

function isPast(month, year){
    return (year < curYear) || (year === curYear && month <= curMonth);
}

function renderHistoryTable(data){
    let tbody = document.getElementById('histTbody');
    // Filter out invalid records (month=0 or year=0)
    let validData = data.filter(x => x.month > 0 && x.year > 0);
    if(!validData.length){
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:#475569">Chưa có lịch sử</td></tr>';
        return;
    }
    tbody.innerHTML = validData.map(x => {
        let diff = '';
        if(x.ordersReal != null && x.ordersForecast > 0){
            let d = ((x.ordersReal - x.ordersForecast) / x.ordersForecast * 100).toFixed(1);
            let color = Math.abs(d) < 10 ? '#4ade80' : Math.abs(d) < 20 ? '#f59e0b' : '#f87171';
            diff = `<span style="color:${color};font-weight:700">${d > 0 ? '+' : ''}${d}%</span>`;
        }
        return `<tr>
            <td style="font-weight:600">${x.month}/${x.year}</td>
            <td style="color:#60a5fa;font-weight:700">${isPast(x.month,x.year) && x.ordersReal != null ? x.ordersReal : '—'}</td>
            <td style="color:#a78bfa;font-weight:700">${isPast(x.month,x.year) && x.customersReal != null ? x.customersReal : '—'}</td>
            <td>${x.ordersForecast || '—'}</td>
            <td>${x.customersForecast || '—'}</td>
            <td>${diff || '—'}</td>
        </tr>`;
    }).join('');
}

function renderCharts(data){
    if(orderChart) orderChart.destroy();
    if(customerChart) customerChart.destroy();

    // Filter out invalid records (month=0 or year=0)
    let validData = data.filter(x => x.month > 0 && x.year > 0);
    if(!validData.length) return;

    let labels = validData.map(x => x.month + '/' + x.year);
    let oReal = validData.map(x => isPast(x.month,x.year) ? x.ordersReal : null);
    let oFc   = validData.map(x => x.ordersForecast || null);
    let cReal = validData.map(x => isPast(x.month,x.year) ? x.customersReal : null);
    let cFc   = validData.map(x => x.customersForecast || null);

    let chartOpts = {
        responsive: true,
        plugins: { legend: { labels: { color:'#94a3b8', font:{size:11} } } },
        scales: {
            x: { ticks:{color:'#64748b',font:{size:10}}, grid:{color:'#1e293b'} },
            y: { ticks:{color:'#64748b',font:{size:10}}, grid:{color:'#1e293b'} }
        }
    };

    orderChart = new Chart(document.getElementById('cOrders'), {
        type:'line',
        data:{
            labels,
            datasets:[
                { label:'Thực tế', data:oReal, borderColor:'#3b82f6', borderWidth:3, pointRadius:4, tension:.3, spanGaps:false },
                { label:'Dự kiến', data:oFc, borderColor:'#f59e0b', borderWidth:2, borderDash:[5,5], pointRadius:3, tension:.3 }
            ]
        },
        options: chartOpts
    });

    customerChart = new Chart(document.getElementById('cCustomers'), {
        type:'line',
        data:{
            labels,
            datasets:[
                { label:'Thực tế', data:cReal, borderColor:'#22c55e', borderWidth:3, pointRadius:4, tension:.3, spanGaps:false },
                { label:'Dự kiến', data:cFc, borderColor:'#f59e0b', borderWidth:2, borderDash:[5,5], pointRadius:3, tension:.3 }
            ]
        },
        options: chartOpts
    });
}

// ===================== PREDICT HINT + CASCADING LOGIC =====================
let rowPredictions = {};
let suggestValues = {}; // stores wma/prev/lastFc values for dropdowns

function loadPredictHint(zoneId){
    let m = parseInt(document.getElementById('fMonth').value);
    let y = parseInt(document.getElementById('fYear').value);

    // Load WMA prediction (used as default for next month)
    fetch('/Dispatcher/PredictForecast?zoneId=' + zoneId)
    .then(r => r.json())
    .then(d => {
        rowPredictions[zoneId] = d;
        // Pre-populate suggest values with WMA
        suggestValues['wmaOrder']    = d.order;
        suggestValues['wmaCustomer'] = d.customer;
    });

    // Load history to get prev month + lastFc values
    fetch('/Dispatcher/GetZoneHistory?zoneId=' + zoneId)
    .then(r => r.json())
    .then(hist => {
        // Find entry for the current month (m/y)
        let cur  = hist.find(h => h.month == m && h.year == y);
        // Find entry for previous month
        let pm = m == 1 ? 12 : m - 1;
        let py = m == 1 ? y - 1 : y;
        let prev = hist.find(h => h.month == pm && h.year == py);

        suggestValues['prevOrder']    = prev?.ordersReal    ?? prev?.ordersForecast    ?? 0;
        suggestValues['prevCustomer'] = prev?.customersReal ?? prev?.customersForecast ?? 0;
        suggestValues['lastFcOrder']    = cur?.ordersForecast    ?? 0;
        suggestValues['lastFcCustomer'] = cur?.customersForecast ?? 0;

        // If the current month already has real data, pre-fill cur inputs
        if(cur?.ordersReal){
            let el = document.getElementById('curOrder');
            if(el && !el.value) el.value = cur.ordersReal;
        }
        if(cur?.customersReal){
            let el = document.getElementById('curCustomer');
            if(el && !el.value) el.value = cur.customersReal;
        }
        // Trigger cascade update
        onCurChanged(zoneId);
    });
}

function toggleSuggest(id){
    let el = document.getElementById(id);
    if(!el) return;
    let visible = el.style.display !== 'none';
    // Close all
    ['suggestOrder','suggestCustomer'].forEach(s => {
        let se = document.getElementById(s);
        if(se) se.style.display = 'none';
    });
    if(!visible) el.style.display = 'block';
}

function applySuggest(inputId, valueKey, dropdownId){
    let val = suggestValues[valueKey] || 0;
    let el  = document.getElementById(inputId);
    if(el){ el.value = val; }
    let dd = document.getElementById(dropdownId);
    if(dd) dd.style.display = 'none';
    // Trigger cascade recalc
    if(selectedZoneId) onCurChanged(selectedZoneId);
}

// Called whenever T_current inputs change → recalculate T_next prediction
function onCurChanged(zoneId){
    let oEl = document.getElementById('curOrder');
    let cEl = document.getElementById('curCustomer');
    let curO = parseInt(oEl?.value) || 0;
    let curC = parseInt(cEl?.value) || 0;

    if(curO <= 0 && curC <= 0){
        document.getElementById('nextPredictBadge').textContent = 'Nhập T hiện tại để xem dự báo';
        return;
    }

    // Simple cascade: next month ≈ 0.5*cur + 0.3*prev + 0.2*wma
    let wmaO = suggestValues['wmaOrder']    || curO;
    let wmaC = suggestValues['wmaCustomer'] || curC;
    let prvO = suggestValues['prevOrder']   || curO;
    let prvC = suggestValues['prevCustomer']|| curC;

    let nextO = Math.round(curO * 0.5 + prvO * 0.3 + wmaO * 0.2);
    let nextC = Math.round(curC * 0.5 + prvC * 0.3 + wmaC * 0.2);

    // Auto-fill next month inputs (only if empty or previously auto-filled)
    let nextOEl = document.getElementById('detailOrder');
    let nextCEl = document.getElementById('detailCustomer');
    if(nextOEl) nextOEl.value = nextO;
    if(nextCEl) nextCEl.value = nextC;

    let m = parseInt(document.getElementById('fMonth').value);
    let targetM = m == 12 ? 1 : m + 1;
    document.getElementById('nextPredictBadge').innerHTML =
        `<span style="color:#4ade80;">✓ Dự báo T${targetM}: <b>${nextO}</b> đơn / <b>${nextC}</b> KH</span>`;

    // Add growth badge
    if(curO > 0){
        let growth = (((nextO - curO) / curO) * 100).toFixed(1);
        let color  = growth >= 0 ? '#4ade80' : '#f87171';
        let sign   = growth >= 0 ? '+' : '';
        let hO = document.getElementById('hintOrder');
        let hC = document.getElementById('hintCustomer');
        if(hO) hO.innerHTML = `Tăng trưởng dự kiến: <b style="color:${color};">${sign}${growth}%</b>`;
        if(hC){
            let gC = curC > 0 ? (((nextC-curC)/curC)*100).toFixed(1) : 0;
            let cC = gC >= 0 ? '#4ade80' : '#f87171';
            hC.innerHTML = `Tăng trưởng dự kiến: <b style="color:${cC};">${gC >= 0 ? '+' : ''}${gC}%</b>`;
        }
    }
}

// ===================== AUTO PREDICT =====================
function autoPredict(zoneId){
    // Auto-fill cur row from WMA, then cascade
    let wmaO = suggestValues['wmaOrder']    || 0;
    let wmaC = suggestValues['wmaCustomer'] || 0;
    if(wmaO > 0){
        let oEl = document.getElementById('curOrder');
        let cEl = document.getElementById('curCustomer');
        if(oEl) oEl.value = wmaO;
        if(cEl) cEl.value = wmaC;
        onCurChanged(zoneId);
        dpToast('Đã auto-fill từ WMA và cập nhật dự báo tháng sau!', 'info');
    } else {
        fetch('/Dispatcher/PredictForecast?zoneId=' + zoneId)
        .then(r => r.json())
        .then(data => {
            if(data.order > 0){
                let oEl = document.getElementById('curOrder');
                let cEl = document.getElementById('curCustomer');
                if(oEl) oEl.value = data.order;
                if(cEl) cEl.value = data.customer;
                onCurChanged(zoneId);
                dpToast('Đã tự động điền dự đoán!', 'info');
            } else {
                dpToast('Chưa đủ dữ liệu để dự đoán', 'error');
            }
        });
    }
}

// ===================== SAVE FORECAST =====================
function saveZoneForecast(zoneId){
    let mView = parseInt(document.getElementById('fMonth').value);
    let yView = parseInt(document.getElementById('fYear').value);
    
    // Calculate target month (next month)
    let m = mView + 1;
    let y = yView;
    if(m > 12){ m = 1; y++; }

    let o = parseInt(document.getElementById('detailOrder').value) || 0;
    let c = parseInt(document.getElementById('detailCustomer').value) || 0;
    
    if(o <= 0 && c <= 0){ dpToast('Vui lòng nhập giá trị dự kiến!', 'error'); return; }

    fetch('/Dispatcher/SaveForecast', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ zoneId, month:m, year:y, ordersForecast:o, customersForecast:c })
    })
    .then(r => r.json())
    .then(d => {
        if(d.success){
            dpToast(`Đã lưu dự kiến cho "${d.zoneName}"!`, 'success');
            loadDashboard();
