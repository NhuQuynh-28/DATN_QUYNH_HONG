@model List<KhoaLuanTotNghiep.Models.Area>

<style>
.al-wrap { font-family:'Segoe UI',sans-serif; padding:4px 0; }
.al-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
.al-title { font-size:22px; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:10px; }
.al-stats { display:flex; gap:12px; }
.al-stat { background:#1e293b; border:1px solid #334155; border-radius:10px; padding:10px 18px; text-align:center; }
.al-stat .val { font-size:20px; font-weight:700; color:#3b82f6; }
.al-stat .lbl { font-size:11px; color:#94a3b8; margin-top:2px; }
.al-stat.green .val { color:#22c55e; }
.al-btn-add { display:inline-flex; align-items:center; gap:8px; background:linear-gradient(135deg,#3b82f6,#2563eb);
    color:white; border:none; padding:10px 20px; border-radius:10px; font-size:13px; font-weight:700;
    cursor:pointer; margin-bottom:20px; transition:opacity .15s; }
.al-btn-add:hover { opacity:.88; }
.al-table-wrap { background:#1e293b; border-radius:14px; border:1px solid #334155; overflow:hidden; }
.al-table { width:100%; border-collapse:collapse; font-size:13px; }
.al-table thead tr { background:#0f172a; }
.al-table th { padding:13px 16px; text-align:left; color:#64748b; font-weight:600; font-size:12px;
    text-transform:uppercase; letter-spacing:.05em; border-bottom:1px solid #334155; }
.al-table tbody tr { border-bottom:1px solid #0f172a44; transition:background .15s; }
.al-table tbody tr:hover { background:#0f172a66; }
.al-table td { padding:14px 16px; color:#e2e8f0; vertical-align:middle; }
.al-area-name { display:flex; align-items:center; gap:10px; }
.al-area-icon { width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#3b82f6,#6366f1);
    display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; }
.al-area-text .name { font-weight:600; color:#f1f5f9; }
.al-area-text .sub { font-size:11px; color:#64748b; margin-top:2px; }
.al-badge-active { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px;
    font-size:11px; font-weight:600; background:#16a34a22; color:#4ade80; border:1px solid #16a34a55; }
.al-badge-inactive { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px;
    font-size:11px; font-weight:600; background:#dc262622; color:#f87171; border:1px solid #dc262644; }
.al-actions { display:flex; gap:8px; flex-wrap:nowrap; }
.al-btn { display:inline-flex; align-items:center; gap:5px; padding:7px 13px; border-radius:8px;
    border:none; font-size:12px; font-weight:600; cursor:pointer; transition:all .15s; white-space:nowrap; }
.al-btn-ver  { background:#1c3d5a; color:#38bdf8; }
.al-btn-ver:hover  { background:#0284c7; color:white; }
.al-btn-del  { background:#3d1c1c; color:#f87171; }
.al-btn-del:hover  { background:#dc2626; color:white; }
.al-num { color:#475569; font-weight:600; }
.al-date { font-size:12px; color:#64748b; }
</style>

<div class="al-wrap">
    <div class="al-header">
        <div class="al-title">
            <i class="fas fa-map-location-dot" style="color:#3b82f6"></i>
            Quản lý khu vực
        </div>
        <div class="al-stats">
            <div class="al-stat">
                <div class="val">@Model.Count</div>
                <div class="lbl">Tổng khu vực</div>
            </div>
            <div class="al-stat green">
                <div class="val">@Model.Count(a => a.Status == "Active")</div>
                <div class="lbl">Đang hoạt động</div>
            </div>
        </div>
    </div>

    <button class="al-btn-add" onclick="openAddAreaModal()">
        <i class="fas fa-plus-circle"></i> Thêm khu vực mới
    </button>

    <div class="al-table-wrap">
        <table class="al-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên khu vực</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var cityIcons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                    {
                        {"Hà Nội","🏛️"}, {"Hồ Chí Minh","🌆"}, {"Đà Nẵng","🌊"},
                        {"Hải Phòng","⚓"}, {"Cần Thơ","🌾"}, {"Huế","🏯"},
                        {"Nha Trang","🏖️"}, {"Đà Lạt","🌸"}, {"Vũng Tàu","🛳️"}
                    };
                }
                @foreach (var area in Model)
                {
                    string icon = cityIcons.ContainsKey(area.Name) ? cityIcons[area.Name] : "📍";
                    <tr>
                        <td class="al-num">@(Model.IndexOf(area) + 1)</td>
                        <td>
                            <div class="al-area-name">
                                <div class="al-area-icon">@icon</div>
                                <div class="al-area-text">
                                    <div class="name">@area.Name</div>
                                    <div class="sub">ID: @area.Id</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (area.Status == "Active")
                            {
                                <span class="al-badge-active">
                                    <i class="fas fa-circle" style="font-size:7px"></i> Active
                                </span>
                            }
                            else
                            {
                                <span class="al-badge-inactive">
                                    <i class="fas fa-circle" style="font-size:7px"></i> Inactive
                                </span>
                            }
                        </td>
                        <td><span class="al-date">@area.CreatedDate.ToString("dd/MM/yyyy")</span></td>
                        <td>
                            <div class="al-actions">
                                <button class="al-btn al-btn-ver"
                                        onclick="openAreaMap(@area.Id,'@area.Name',null)">
                                    <i class="fas fa-map"></i> Xem bản đồ
                                </button>
                                <button class="al-btn al-btn-del"
                                        onclick="deleteArea(@area.Id)">
                                    <i class="fas fa-trash"></i> Xóa
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div style="text-align:center;padding:50px;color:#475569">
                <i class="fas fa-map" style="font-size:42px;margin-bottom:14px;display:block;color:#334155"></i>
                <div style="font-size:16px;font-weight:600;color:#64748b">Chưa có khu vực nào</div>
                <div style="font-size:13px;color:#475569;margin-top:6px">Nhấn "Thêm khu vực mới" để bắt đầu</div>
            </div>
        }
    </div>
</div>