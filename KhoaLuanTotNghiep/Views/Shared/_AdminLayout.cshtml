        /* ================= UPDATE ================= */

        function updateZone(){
            if(!selectedPolygon || !selectedId){
                showToast("Vui lòng kích chọn một vùng trên bản đồ để cập nhật!", "error");
                return;
            }

            // Tắt editing trước khi lấy tọa độ để đảm bảo data nhất quán
            try { selectedPolygon.editing.disable(); } catch(e){}

            // Lấy tọa độ hiện tại (sau khi đã edit)
            // Leaflet polygon.getLatLngs() trả về [[LatLng, ...]] cho simple polygon
            let rawCoords = selectedPolygon.getLatLngs();
            
            // Flatten an toàn: lấy tất cả LatLng từ mọi ring
            let latlngs = [];
            function flattenLatLngs(arr) {
                arr.forEach(item => {
                    if (item && typeof item.lat === 'number' && typeof item.lng === 'number') {
                        // Đây là LatLng object
                        latlngs.push(item);
                    } else if (Array.isArray(item) || (item && typeof item.forEach === 'function')) {
                        // Đây là mảng lồng → đệ quy
                        flattenLatLngs(Array.from(item));
                    }
                });
            }
            flattenLatLngs(rawCoords);
            
            if (!latlngs || latlngs.length === 0) {
                showToast("Không tìm thấy dữ liệu tọa độ!", "error");
                return;
            }

            // Chuyển sang mảng [lat, lng] để gửi lên server
            let pts = latlngs.map(c => [c.lat, c.lng]);

            if (pts.length < 3) {
                showToast("Vùng cần ít nhất 3 điểm!", "error");
                return;
            }

            // Highlight nút Cập nhật đang xử lý
            let btn = document.querySelector('.mt-btn-update');
            let origText = btn ? btn.innerHTML : '';
            if (btn) { btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...'; btn.disabled = true; }

            let area = calculateArea(latlngs);
            let center = selectedPolygon.getBounds().getCenter();

            fetch('/Zone/UpdateZone',{
                method:'POST',
                headers:{
                    'Content-Type':'application/json'
                },
                body:JSON.stringify({
                    Id: selectedId,
                    ZoneName: selectedPolygon.zoneName || '',
                    Points: JSON.stringify(pts),
                    CenterLat: center.lat,
                    CenterLng: center.lng,
                    Area: area,
                    VersionId: versionId
                })
            })
            .then(r=>r.json())
            .then(d=>{
                if (btn) { btn.innerHTML = origText; btn.disabled = false; }
                if(d.success){
                    showToast(`Đã cập nhật vùng "${selectedPolygon.zoneName || ''}" thành công! ✅`,'success');
                    selectedPolygon = null;
                    selectedId = null;
                    // Reload zones để cập nhật center labels mới
                    loadZones(versionId);
                } else {
                    showToast('Cập nhật thất bại! Vui lòng thử lại.','error');
                    // Bật lại editing nếu thất bại
                    try { selectedPolygon.editing.enable(); } catch(e){}
                }
            })
            .catch(err=>{
                if (btn) { btn.innerHTML = origText; btn.disabled = false; }
                console.error(err);
                showToast('Lỗi kết nối khi cập nhật!','error');
            });
        }

