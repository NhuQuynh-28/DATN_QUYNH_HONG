@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("Role");
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="vi">
<head>

<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<title>Delivery Zone</title>

    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>

        body {
            margin: 0;
            font-family: Segoe UI;
            background: #0f172a;
            color: white;
            height: 100vh;
            overflow: hidden;
        }

        .layout {
            display: flex;
            height: 100vh;
        }

        /* SIDEBAR */

        .sidebar {
            width: 260px;
            background: #1e293b;
            padding: 25px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 30px;
        }

        /* MENU */

        .menu-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            margin-bottom: 10px;
            background: #334155;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            color:white;
        }

            .menu-item:hover {
                background: #2563eb;
            }

        /* SUB MENU - area city tabs */
        .submenu { display:none; padding-left:0; margin-bottom:10px; }
        .submenu a { display:block; padding:8px 12px; color:#cbd5e1; text-decoration:none; border-radius:6px; font-size:13px; }
        .submenu a:hover { background:#1e40af; color:white; }

        /* area city tabs */
        .area-cities { padding-left:10px; margin-top:4px; }
        .area-city-tab {
            display:flex; align-items:center; gap:8px;
            padding:8px 12px; border-radius:8px; cursor:pointer;
            color:#94a3b8; font-size:13px; transition:all .2s;
            margin-bottom:3px;
        }
        .area-city-tab:hover { background:#1e40af22; color:#60a5fa; }
        .area-city-tab.active { background:#1e40af; color:white; font-weight:600; }
        .area-city-dot { width:8px; height:8px; border-radius:50%; background:#3b82f6; flex-shrink:0; }
        .area-city-dot.hcm { background:#f59e0b; }
        .area-city-dot.dn  { background:#22c55e; }
        .area-city-dot.hp  { background:#a78bfa; }
        .area-city-dot.other { background:#64748b; }
        .area-add-btn {
            display:flex; align-items:center; gap:6px;
            padding:7px 12px; border-radius:8px; cursor:pointer;
            color:#38bdf8; font-size:12px; border:1px dashed #334155;
            margin:6px 10px 4px; transition:all .2s;
        }
        .area-add-btn:hover { background:#0f172a; border-color:#3b82f6; }

        /* map toolbar */
        .map-toolbar {
            display:none; background:#1e293b; border-radius:12px;
            padding:10px 14px; margin-bottom:12px;
            flex-wrap:wrap; gap:8px; align-items:center;
            border:1px solid #334155;
        }
        .map-toolbar.visible { display:flex; }
        .mt-label { color:#64748b; font-size:11px; font-weight:700;
            text-transform:uppercase; letter-spacing:.05em; margin-right:4px; }
        .mt-sep { width:1px; height:28px; background:#334155; margin:0 4px; }
        .mt-btn {
            display:inline-flex; align-items:center; gap:6px;
            padding:6px 12px; border-radius:8px; border:none;
            font-size:12px; font-weight:600; cursor:pointer;
            transition:all .15s; white-space:nowrap;
        }
        .mt-btn-draw   { background:#1c3d5a; color:#38bdf8; }
        .mt-btn-draw:hover   { background:#0284c7; color:white; }
        .mt-btn-save   { background:#1e3d2f; color:#4ade80; }
        .mt-btn-save:hover   { background:#16a34a; color:white; }
        .mt-btn-done   { background:#1c3855; color:#93c5fd; }
        .mt-btn-done:hover   { background:#1d4ed8; color:white; }
        .mt-btn-del    { background:#3d1c1c; color:#f87171; }
        .mt-btn-del:hover    { background:#dc2626; color:white; }
        .mt-btn-clear  { background:#2d1f3d; color:#c4b5fd; }
        .mt-btn-clear:hover  { background:#7c3aed; color:white; }
        .mt-btn-update { background:#2d2a1a; color:#fbbf24; }
        .mt-btn-update:hover { background:#d97706; color:white; }
        .mt-btn-dist   { background:#1a2d2a; color:#34d399; }
        .mt-btn-dist:hover   { background:#059669; color:white; }
        .mt-btn-adj    { background:#1a1a2d; color:#818cf8; }
        .mt-btn-adj:hover    { background:#4f46e5; color:white; }
        .mt-zone-name {
            background:#0f172a; border:1px solid #334155; border-radius:7px;
            padding:6px 10px; color:#f1f5f9; font-size:12px; outline:none;
            width:130px;
        }
        .mt-zone-name:focus { border-color:#3b82f6; }
        
        @@keyframes pulse-btn {
            0%   { transform: scale(1); box-shadow: 0 0 0 0 rgba(217,119,6,0.6); }
            50%  { transform: scale(1.06); box-shadow: 0 0 0 8px rgba(217,119,6,0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(217,119,6,0); }
        }

        /* modal overlay */
        .am-overlay { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:9000;
            display:none; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
        .am-overlay.open { display:flex; }
        .am-modal { background:#1e293b; border:1px solid #334155; border-radius:16px;
            padding:28px; min-width:360px; max-width:440px; width:100%;
            box-shadow:0 24px 64px rgba(0,0,0,.5); }
        .am-modal h3 { margin:0 0 20px; font-size:17px; color:#f1f5f9;
            display:flex; align-items:center; gap:8px; }
        .am-form-group { margin-bottom:14px; }
        .am-form-group label { display:block; font-size:12px; color:#94a3b8;
            font-weight:600; margin-bottom:5px; }
        .am-form-input { width:100%; background:#0f172a; border:1px solid #334155;
            border-radius:8px; padding:9px 12px; color:#f1f5f9; font-size:13px;
            outline:none; box-sizing:border-box; }
        .am-form-input:focus { border-color:#3b82f6; }
        .am-footer { display:flex; justify-content:flex-end; gap:10px;
            margin-top:20px; padding-top:16px; border-top:1px solid #334155; }
        .am-btn-cancel { background:#334155; border:none; border-radius:8px;
            padding:9px 18px; color:#94a3b8; font-size:13px; cursor:pointer; }
        .am-btn-save { background:linear-gradient(135deg,#3b82f6,#2563eb); border:none;
            border-radius:8px; padding:9px 22px; color:white; font-size:13px;
            font-weight:700; cursor:pointer; }

        /* CONTENT */
        .content { flex:1; display:flex; flex-direction:column; }
        .topbar { height:60px; background:#1e293b; display:flex; align-items:center;
            justify-content:flex-end; padding:0 24px; border-bottom: 1px solid #334155; }
        .user-box { display:flex; align-items:center; gap:0; }
        
        .header-btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 8px 16px; border-radius: 10px;
            font-size: 13px; font-weight: 600; text-decoration: none;
            transition: all 0.2s ease; border: none; cursor: pointer;
        }
        .btn-profile {
            background: rgba(37, 99, 235, 0.1); color: #3b82f6;
            border: 1px solid rgba(37, 99, 235, 0.2);
            margin-right: 12px;
        }
        .btn-profile:hover {
            background: #2563eb; color: white;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }
        .btn-logout {
            background: rgba(239, 68, 68, 0.1); color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }
        .btn-logout:hover {
            background: #dc2626; color: white;
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
        }
        .user-welcome {
            font-size: 13px; color: #94a3b8; font-weight: 500;
            margin-right: 16px; display: flex; align-items: center; gap: 8px;
        }
        .user-welcome i { font-size: 14px; color: #64748b; }
        .user-welcome b { color: #f1f5f9; font-weight: 700; }

        .page-body { flex:1; padding:20px; overflow:auto; background:#0f172a; }
        .leaflet-div-icon { width:8px !important; height:8px !important; }
        .leaflet-editing-icon { width:8px !important; height:8px !important;
            margin-left:-4px !important; margin-top:-4px !important; }
        #map { width:100%; height:calc(100vh - 220px); min-height:480px; border-radius:10px; }
    </style>

</head>

<body>

    <div class="layout">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <div class="logo">
                🚚 Delivery Zone
            </div>



            @if (!string.IsNullOrEmpty(role) && role.ToLower() == "admin")
            {

                <div class="menu-item" onclick="toggleMenu()" id="areaMenuBtn">
                    <span>📍 Quản lý khu vực</span>
                    <span id="arrow">▼</span>
                </div>

                <div id="areaMenu" class="submenu">
                    <!-- Tab danh sách tổng -->
                    <a href="#" onclick="loadArea();setActiveCity(this)" class="submenu-link" style="font-weight:600;color:#60a5fa;padding:8px 12px;margin-bottom:4px">
                        <i class="fas fa-list" style="width:14px"></i> Tất cả khu vực
                    </a>

                    <!-- Dynamic city tabs -->
                    <div class="area-cities" id="areaCityList">
                        <div style="color:#475569;font-size:11px;padding:4px 12px">Đang tải...</div>
                    </div>

                    <!-- Nút thêm khu vực -->
                    <div class="area-add-btn" onclick="openAddAreaModal()">
                        <i class="fas fa-plus-circle"></i>
                        <span>Thêm khu vực</span>
                    </div>
                </div>

                <div class="menu-item" onclick="loadUsers()">
                    👤 Quản lý User
                </div>
                <div class="menu-item" onclick="toggleDriverMenu()">
                    <span>🚚 Quản lý phân công</span>
                    <span id="arrowDriver">▼</span>
                </div>

                <div id="driverMenu" class="submenu">

                    <a href="#" onclick="loadPage('/Driver/List');return false;">
                        📅 Phân công theo tháng
                    </a>

                </div>
                <div class="menu-item" onclick="toggleReportMenu()">
                    <span>📊 Thống kê báo cáo</span>
                    <span id="arrowReport">▼</span>
                </div>

                <div id="reportMenu" class="submenu">
                    <a href="#" onclick="loadDashboard(); return false;">
                        <i class="fas fa-chart-line"></i> Tổng quan
                    </a>
                    <a href="#" onclick="loadReportZone(); return false;">
                        <i class="fas fa-map-pin"></i> Thống kê vùng
                    </a>
                    <a href="#" onclick="loadReportShipper(); return false;">
                        <i class="fas fa-user-friends"></i> Theo bưu tá
                    </a>
                    <a href="#" onclick="loadReportOrder(); return false;">
                        <i class="fas fa-boxes"></i> Đơn hàng
                    </a>
                </div>  
            }

        </div>

        <!-- CONTENT -->

        <div class="content">

            <div class="topbar">

                <div class="user-box">
                    <a href="/Account/Profile" class="header-btn btn-profile">
                        <i class="fas fa-user-circle"></i> Hồ sơ
                    </a>
                    <div class="user-welcome">
                        <i class="fas fa-user"></i>
                        <span>Xin chào, <b>@username</b></span>
                    </div>
                    <a href="/Account/Logout" class="header-btn btn-logout">
                        <i class="fas fa-sign-out-alt"></i> Thoát
                    </a>
                </div>

            </div>

            <div class="page-body">

                <!-- MAP TOOLBAR (hiển thị khi vào chế độ xem map) -->
                <div class="map-toolbar" id="mapToolbar">
                    <span class="mt-label">🗺️ Công cụ bản đồ</span>
                    <div class="mt-sep"></div>
                    <button class="mt-btn mt-btn-draw" onclick="enableDraw()" title="Bắt đầu vẽ vùng">
                        <i class="fas fa-draw-polygon"></i> Vẽ vùng
                    </button>
                    <button class="mt-btn mt-btn-done" onclick="finishArea()" title="Hoàn thành vùng đang vẽ">
                        <i class="fas fa-check-circle"></i> Done vùng
                    </button>
                    <input class="mt-zone-name" type="text" id="zoneName" placeholder="Tên vùng...">
                    <button class="mt-btn mt-btn-save" onclick="saveZone()" title="Lưu vùng vào DB">
                        <i class="fas fa-floppy-disk"></i> Lưu vùng
                    </button>
                    <button class="mt-btn mt-btn-update" onclick="updateZone()" title="Cập nhật vùng đang chọn">
                        <i class="fas fa-pen"></i> Cập nhật
                    </button>
                    <div class="mt-sep"></div>
                    <button class="mt-btn mt-btn-del" onclick="deleteSelected()" title="Xóa vùng đang chọn">
                        <i class="fas fa-times"></i> Xóa đang chọn
                    </button>
                    <button class="mt-btn mt-btn-clear" onclick="clearAll()" title="Xóa tất cả vùng trên bản đồ">
                        <i class="fas fa-trash"></i> Xóa tất cả
                    </button>
                    <div class="mt-sep"></div>
                    <button class="mt-btn mt-btn-dist" onclick="calculateDistances()" title="Tính khoảng cách">
                        <i class="fas fa-ruler"></i> Khoảng cách
                    </button>
                    <button class="mt-btn mt-btn-adj" onclick="checkAdjacency()" title="Kiểm tra vùng kề nhau">
                        <i class="fas fa-link"></i> Vùng kề
                    </button>
                </div>

                <div id="content-area">
                    @RenderBody()
                </div>

            </div>

            <!-- Modal thêm khu vực -->
            <div class="am-overlay" id="addAreaOverlay" onclick="if(event.target===this)closeAddAreaModal()">
                <div class="am-modal">
                    <h3><i class="fas fa-map-location-dot" style="color:#3b82f6"></i> Thêm khu vực mới</h3>
                    <div class="am-form-group">
                        <label>Tên khu vực <span style="color:#ef4444">*</span></label>
                        <input class="am-form-input" id="newAreaName" placeholder="VD: Hải Dương, Cần Thơ..." autofocus>
                    </div>
                    <div class="am-form-group">
                        <label>Mô tả <span style="color:#64748b;font-weight:400">(tùy chọn)</span></label>
                        <input class="am-form-input" id="newAreaDesc" placeholder="Ghi chú về khu vực...">
                    </div>
                    <div class="am-footer">
                        <button class="am-btn-cancel" onclick="closeAddAreaModal()">Hủy</button>
                        <button class="am-btn-save" onclick="submitAddArea()"><i class="fas fa-plus"></i> Thêm</button>
                    </div>
                </div>
            </div>

        </div>

    </div>


<script>

/* ================= AREA MANAGEMENT ================= */

        let _activeAreaId = null;

        function toggleMenu(){
            var menu = document.getElementById("areaMenu");
            var arrow = document.getElementById("arrow");
            if(menu.style.display==="block"){
                menu.style.display="none";
                arrow.innerHTML="▼";
            } else {
                menu.style.display="block";
                arrow.innerHTML="▲";
                loadAreaSidebar();
            }
        }

        function loadAreaSidebar(){
            fetch("/Area/GetAll")
            .then(r=>r.json())
            .then(areas=>{
                let cityColors = {
                    'hà nội':'#3b82f6','ha noi':'#3b82f6',
                    'hồ chí minh':'#f59e0b','ho chi minh':'#f59e0b','hcm':'#f59e0b',
                    'đà nẵng':'#22c55e','da nang':'#22c55e',
                    'hải phòng':'#a78bfa','hai phong':'#a78bfa'
                };
                let icons = {
                    'hà nội':'🏛️','ha noi':'🏛️',
                    'hồ chí minh':'🌆','ho chi minh':'🌆','hcm':'🌆',
                    'đà nẵng':'🌊','da nang':'🌊',
                    'hải phòng':'⚓','hai phong':'⚓'
                };
                let container = document.getElementById('areaCityList');
                if(!areas.length){
                    container.innerHTML = '<div style="color:#475569;font-size:11px;padding:6px 12px">Chưa có khu vực nào</div>';
                    return;
                }
                container.innerHTML = areas.map(a=>{
                    let key = a.areaName.toLowerCase();
                    let color = cityColors[key] || '#64748b';
                    let icon = icons[key] || '📍';
                    return `<div class="area-city-tab" id="citytab-${a.id}"
                        onclick="openAreaMap(${a.id},'${a.areaName}',this)">
                        <span style="font-size:15px">${icon}</span>
                        <span style="flex:1;color:#e2e8f0">${a.areaName}</span>
                        <span style="width:7px;height:7px;border-radius:50%;background:${color};flex-shrink:0"></span>
                    </div>`;
                }).join('');
            })
            .catch(()=>{
                document.getElementById('areaCityList').innerHTML =
                    '<div style="color:#ef4444;font-size:11px;padding:6px 12px">Lỗi tải khu vực</div>';
            });
        }

        function setActiveCity(el){ document.querySelectorAll('.area-city-tab').forEach(t=>t.classList.remove('active')); }

        function openAreaMap(areaId, areaName, tabEl){
            _activeAreaId = areaId;
            document.querySelectorAll('.area-city-tab').forEach(t=>t.classList.remove('active'));
            if(tabEl) tabEl.classList.add('active');
            // Load danh sách version của khu vực này
            loadVersion(areaId, areaName);
        }

        /* ================= ADD AREA MODAL ================= */
        function openAddAreaModal(){
            document.getElementById('newAreaName').value='';
            document.getElementById('newAreaDesc').value='';
            document.getElementById('addAreaOverlay').classList.add('open');
            setTimeout(()=>document.getElementById('newAreaName').focus(),100);
        }
        function closeAddAreaModal(){
            document.getElementById('addAreaOverlay').classList.remove('open');
        }
        function submitAddArea(){
            let name = document.getElementById('newAreaName').value.trim();
            if(!name){ showToast('Vui lòng nhập tên khu vực!','error'); return; }
            fetch('/Area/Create',{
                method:'POST',
                headers:{'Content-Type':'application/json'},
                body: JSON.stringify({Name: name, Status:'Active'})
            })
            .then(r=>r.json())
            .then(d=>{
                if(d.success){
                    closeAddAreaModal();
                    showToast(`Đã thêm khu vực "${d.name}"!`,'success');
                    loadAreaSidebar();
                    loadArea();
                } else {
                    showToast(d.message||'Lỗi thêm khu vực','error');
                }
            })
            .catch(()=>showToast('Lỗi kết nối server','error'));
        }
        document.addEventListener('keydown', e=>{
            if(e.key==='Enter' && document.getElementById('addAreaOverlay').classList.contains('open'))
                submitAddArea();
            if(e.key==='Escape') closeAddAreaModal();
        });

        function deleteArea(id){
            if(!confirm('Xóa khu vực này?')) return;
            fetch('/Area/Delete',{
                method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:'id='+id
            })
            .then(r=>r.json())
            .then(d=>{
                if(d.success){ showToast('Đã xóa khu vực!','info'); loadAreaSidebar(); loadArea(); }
                else showToast(d.message,'error');
            });
        }

        /* ================= GLOBAL ================= */
        var map; var drawnItems; var versionId;
        var draw=false; var points=[]; var polygon=null;
        var markers=[]; var selectedPolygon=null; var selectedId=null;
        var polygons=[];

        /* ================= LOAD AREA (content) ================= */
        function loadArea(){
            cleanupState();
            fetch("/Area/Index")
            .then(res=>res.text())
            .then(data=>{ document.getElementById("content-area").innerHTML=data; });
        }

        function showMapToolbar(){ document.getElementById('mapToolbar').classList.add('visible'); }
        function hideMapToolbar(){ document.getElementById('mapToolbar').classList.remove('visible'); }

        /* ================= LOAD VERSION ================= */
        function loadVersion(areaId, name){
            areaName = name;
            currentAreaId = areaId;  // track để dùng cho setActive / deleteVersion
            hideMapToolbar();
            fetch("/ZoneVersion/Index?areaId="+areaId)
            .then(res=>res.text())
            .then(data=>{
                let content = document.getElementById("content-area");
                content.innerHTML=data;
                const scripts = content.querySelectorAll('script');
                scripts.forEach(oldScript => {
                    const newScript = document.createElement('script');
                    newScript.text = oldScript.text;
                    newScript.setAttribute('data-injected', 'true');
                    document.body.appendChild(newScript);
                });
            });
        }

        /* ================= OPEN MAP ================= */

        function openMap(id){
            showMapToolbar();
            fetch("/Zone/Map?versionId="+id)
            .then(res=>res.text())
            .then(data=>{
                document.getElementById("content-area").innerHTML=data;
                setTimeout(function(){ initMap(id); }, 300);
            });
        }

        /* ================= INIT MAP ================= */
        function initMap(vId){

        versionId=vId;

        map=L.map('map').setView([21.0285,105.8542],13);

        L.tileLayer(
        'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
        {maxZoom:19}
        ).addTo(map);

        drawnItems=new L.FeatureGroup();
        map.addLayer(drawnItems);

        var drawControl=new L.Control.Draw({
        edit:{
        featureGroup: drawnItems
        },
        draw:false
        });

        map.addControl(drawControl);

        map.on("click",function(e){

        if(!draw) return;

        points.push([e.latlng.lat,e.latlng.lng]);

        var marker=L.circleMarker(e.latlng,{
        radius:5,
        color:"blue"
        }).addTo(map);

        markers.push(marker);

        if(polygon)
        map.removeLayer(polygon);

        polygon=L.polygon(points,{
        color:"#2563eb",
        fillOpacity:0.3
        }).addTo(map);

        });

        loadZones(versionId);

        }

        /* ================= DRAW ================= */

        function enableDraw(){
            if(!map){ showToast('Vui lòng mở bản đồ trước!','error'); return; }
            draw=true;
            points=[];
            if(polygon){ map.removeLayer(polygon); polygon=null; }
            markers.forEach(m=>map.removeLayer(m));
            markers=[];
            // Reset màu input tên vùng
            let ni = document.getElementById('zoneName');
