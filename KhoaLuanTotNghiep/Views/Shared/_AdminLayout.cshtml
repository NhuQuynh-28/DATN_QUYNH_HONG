        /* ================= CALCULATE AREA ================= */
function calculateArea(latlngs) {
    let points = latlngs[0] || latlngs;

    let area = 0;

    for (let i = 0; i < points.length; i++) {
        let j = (i + 1) % points.length;

        let p1 = points[i];
        let p2 = points[j];

        area += (p1.lng * p2.lat) - (p2.lng * p1.lat);
    }

    return Math.abs(area / 2) * 111000 * 111000;
}


/* ================= SAVE ================= */
function saveZone(){
    if(!map){ showToast('Vui lòng mở bản đồ trước!','error'); return; }

    let nameInput = document.getElementById('zoneName');
    let name = nameInput ? nameInput.value.trim() : '';

    if(!name){
        showToast('Vui lòng nhập tên vùng!','error');
        if(nameInput){ nameInput.focus(); nameInput.style.borderColor='#ef4444'; }
        return;
    }

    if(!polygon){
        showToast('Chưa vẽ vùng! Bấm "Vẽ vùng" rồi vẽ điểm trên bản đồ.','error');
        return;
    }

    let latlngs = polygon.getLatLngs();
    if(!latlngs || latlngs.length === 0){
        showToast('Chưa có dữ liệu vùng!','error');
        return;
    }

    let area = calculateArea(latlngs);
    let center = polygon.getBounds().getCenter();

    if(!versionId){
        showToast('Chưa chọn Version! Vui lòng vào khu vực → chọn Version → mở bản đồ.','error');
        return;
    }

    fetch('/Zone/SaveZone',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
            zoneName: name,
            areaName: areaName || '',
            points: JSON.stringify(latlngs),
            centerLat: center.lat,
            centerLng: center.lng,
            versionId: versionId,
            area: area
        })
    })
    .then(r=>r.json())
    .then(d=>{
        if(d.success){
            showToast(`Đã lưu vùng "${name}" thành công! ✅`,'success');
            // Reset
            polygon = null;
            if(nameInput){ nameInput.value=''; nameInput.style.borderColor='#334155'; }
            // Reload zones trên bản đồ hiện tại (KHÔNG điều hướng ra khỏi map)
            loadZones(versionId);
        } else {
            showToast('Lưu vùng thất bại! Vui lòng thử lại.','error');
        }
    })
    .catch(err=>{
        console.error(err);
        showToast('Lỗi kết nối khi lưu vùng!','error');
    });
}
        /* ================= LOAD ZONE ================= */
        function loadZones(versionId){
            // Xóa tất cả layer cũ (polygon + marker) khỏi map
            if(window._zoneMarkers){ window._zoneMarkers.forEach(m=>{ try{ map.removeLayer(m); }catch(e){} }); }
            window._zoneMarkers = [];
            polygons.forEach(p=>{ try{ map.removeLayer(p); }catch(e){}  try{ drawnItems.removeLayer(p); }catch(e){}});
            polygons = [];

            fetch("/Zone/GetZones?versionId="+versionId)
            .then(r=>r.json())
            .then(data=>{
                data.forEach(z=>{
                    let pts;
                    try { pts = JSON.parse(z.points); } catch(e){ return; }

                    // Tạo polygon, thêm TRỰC TIẾP lên map (không qua drawnItems)
                    // để tránh Leaflet.Draw can thiệp click/style
                    let poly = L.polygon(pts, {
                        color: '#3b82f6',
                        weight: 2,
                        fillOpacity: 0.3,
                        fillColor: '#3b82f6'
                    }).addTo(map);

                    poly.zoneId  = z.id;
                    poly.zoneName = z.zoneName ?? z.ZoneName ?? "Zone";
                    polygons.push(poly);

                    // Label marker
                    let center = poly.getBounds().getCenter();
                    let marker = L.marker(center, {
                        interactive: false,
                        icon: L.divIcon({
                            className: 'zone-label',
                            html: `<div style="background:#2563eb;color:white;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:700;white-space:nowrap;box-shadow:0 2px 6px rgba(0,0,0,.3)">${poly.zoneName}</div>`
                        })
                    }).addTo(map);
                    window._zoneMarkers.push(marker);

                    // ===== CLICK: chọn vùng để sửa =====
                    poly.on('click', function(e){
                        L.DomEvent.stopPropagation(e);

                        // Reset tất cả polygon về màu xanh, tắt editing, xóa khỏi drawnItems
                        polygons.forEach(p => {
                            try { p.editing.disable(); } catch(ex){}
                            try { drawnItems.removeLayer(p); } catch(ex){}
                            p.setStyle({ color:'#3b82f6', fillColor:'#3b82f6', weight:2, fillOpacity:0.3 });
                        });

                        // Đánh dấu polygon được chọn
                        selectedPolygon = poly;
                        selectedId      = z.id;

                        // Thêm vào drawnItems để Leaflet.draw editing hoạt động
                        drawnItems.addLayer(poly);

                        // Đổi màu đỏ NGAY SAU KHI thêm vào drawnItems
                        poly.setStyle({ color:'#ef4444', fillColor:'#ef4444', weight:3, fillOpacity:0.5 });

                        // Bật editing → hiện điểm neo để kéo
                        try { poly.editing.enable(); } catch(ex){ console.warn('editing not available', ex); }

                        // Sidebar history/predict
                        if(typeof loadHistory === 'function') loadHistory(z.id);
                        if(typeof loadPredict  === 'function') loadPredict(z.id);

                        // Toast hướng dẫn
                        showToast(`🔴 Đã chọn "${poly.zoneName}". Kéo điểm neo để chỉnh vùng → bấm ✏️ Cập nhật để lưu.`, 'info');

                        // Highlight nút Cập nhật
                        let updateBtn = document.querySelector('.mt-btn-update');
                        if(updateBtn){
                            updateBtn.style.background = '#d97706';
                            updateBtn.style.color = 'white';
                            updateBtn.style.boxShadow = '0 0 0 3px rgba(217,119,6,0.4)';
                            setTimeout(()=>{
                                updateBtn.style.background = '';
                                updateBtn.style.color = '';
                                updateBtn.style.boxShadow = '';
                            }, 3000);
                        }
                    });
                });

                // Zoom vào tất cả vùng sau khi load
                if(polygons.length > 0){
                    let group = new L.featureGroup(polygons);
                    map.fitBounds(group.getBounds(), { padding:[30,30] });
                }
            });
        } // ✅ đóng function
