@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("Role");
    var username = Context.Session.GetString("Username");
}

<!DOCTYPE html>
<html lang="vi">
<head>

<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<title>Delivery Zone</title>

    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <style>

        body {
            margin: 0;
            font-family: Segoe UI;
            background: #0f172a;
            color: white;
            height: 100vh;
            overflow: hidden;
        }

        .layout {
            display: flex;
            height: 100vh;
        }

        /* SIDEBAR */

        .sidebar {
            width: 260px;
            background: #1e293b;
            padding: 25px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 30px;
        }

        /* MENU */

        .menu-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            margin-bottom: 10px;
            background: #334155;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            color:white;
        }

            .menu-item:hover {
                background: #2563eb;
            }

        /* SUB MENU */

        .submenu {
            display: none;
            padding-left: 15px;
            margin-bottom: 10px;
        }

            .submenu a {
                display: block;
                padding: 8px;
                color: white;
                text-decoration: none;
                border-radius: 6px;
            }

                .submenu a:hover {
                    background: #1e40af;
                }

        /* CONTENT */

        .content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* TOPBAR */

        .topbar {
            height: 60px;
            background: #1e293b;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 20px;
        }

        .user-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logout-btn {
            background: #ef4444;
            border: none;
            padding: 6px 12px;
            color: white;
            border-radius: 6px;
            cursor: pointer;
        }

        /* PAGE */

        .page-body {
            flex: 1;
            padding: 20px;
            overflow: auto;
            background: #0f172a;
        }

        .leaflet-div-icon {
            width: 8px !important;
            height: 8px !important;
        }

        .leaflet-editing-icon {
            width: 8px !important;
            height: 8px !important;
            margin-left: -4px !important;
            margin-top: -4px !important;
        }
        #map {
            width: 100%;
            height: 650px;
            border-radius: 10px;
        }

    </style>

</head>

<body>

    <div class="layout">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <div class="logo">
                🚚 Delivery Zone
            </div>



            @if (!string.IsNullOrEmpty(role) && role.ToLower() == "admin")
            {

                <div class="menu-item" onclick="toggleMenu()">
                    <span>📍 Quản lý khu vực</span>
                    <span id="arrow">▼</span>
                </div>

                <div id="areaMenu" class="submenu">

                    <a href="#" onclick="loadArea()">Danh sách khu vực</a>

                    <a href="#" onclick="enableDraw()">
                        <i class="fas fa-draw-polygon"></i>
                        Vẽ vùng giao hàng
                    </a>

                    <a href="#" onclick="clearAll()">
                        <i class="fas fa-trash"></i>
                        Xóa tất cả vùng
                    </a>
                    <input type="text" id="zoneName" placeholder="Nhập tên vùng"
                           style="padding:6px;border-radius:6px;border:none">
                    <a href="#" onclick="saveZone()">
                        <i class="fas fa-floppy-disk"></i>
                        Save vùng
                    </a>

                    <a href="#" onclick="finishArea()">
                        <i class="fas fa-check"></i>
                        Done khu vực
                    </a>

                    <a href="#" onclick="deleteSelected()">
                        <i class="fas fa-xmark"></i>
                        Xóa vùng đang chọn
                    </a>

                    <a href="#" onclick="updateZone()">
                        <i class="fas fa-pen"></i>
                        Update vùng
                    </a>

                    <a href="#" onclick="calculateDistances()">
                        <i class="fas fa-ruler"></i>
                        Tính khoảng cách
                    </a>

                    <a href="#" onclick="checkAdjacency()">
                        <i class="fas fa-link"></i>
                        Kiểm tra vùng kề
                    </a>

                </div>

                <div class="menu-item" onclick="loadUsers()">
                    👤 Quản lý User
                </div>
                <div class="menu-item" onclick="toggleDriverMenu()">
                    <span>🚚 Quản lý tài xế</span>
                    <span id="arrowDriver">▼</span>
                </div>

                <div id="driverMenu" class="submenu">

                    <a href="#" onclick="loadPage('/Driver/ByMonth') ; return false;">
                        📅 Xem theo tháng
                    </a>

                    <a href="#" onclick="loadPage('/Driver/List') ; return false;">
                        📋 Danh sách tài xế
                    </a>

                    <a href="#" onclick="loadPage('/Driver/Detail') ; return false">
                        📊 Thông tin phân công
                    </a>

                

                </div>
                <div class="menu-item" onclick="toggleReportMenu()">
                    📊 Thống kê báo cáo
                    <span id="arrowReport">▼</span>
                </div>

                <div id="reportMenu" style="display:none; padding-left:15px;">

                    <div class="menu-sub" onclick="loadDashboard()">
                        📈 Tổng quan
                    </div>

                    <div class="menu-sub" onclick="loadReportZone()">
                        📍 Thống kê vùng
                    </div>

                    <div class="menu-sub" onclick="loadReportShipper()">
                        🚴 Theo bưu tá
                    </div>

                    <div class="menu-sub" onclick="loadReportOrder()">
                        📦 Đơn hàng
                    </div>

                </div>  
            }

        </div>

        <!-- CONTENT -->

        <div class="content">

            <div class="topbar">

                <div class="user-box">
                    <i class="fas fa-user"></i>
                    <span>@username</span>

                    <a href="/Account/Logout" class="logout-btn">
                        Đăng xuất
                    </a>

                </div>

            </div>

            <div class="page-body">

                <div id="content-area">
                    @RenderBody()
                </div>

            </div>

        </div>

    </div>


<script>

/* ================= MENU ================= */

        /* ================= MENU ================= */

        function toggleMenu(){

        var menu=document.getElementById("areaMenu");
        var arrow=document.getElementById("arrow");

        if(menu.style.display==="block"){
        menu.style.display="none";
        arrow.innerHTML="▼";
        }
        else{
        menu.style.display="block";
        arrow.innerHTML="▲";
        }

        }
                function openCreateArea(){ 
                    fetch("/Area/Create") 
                    .then(res=>res.text())
                    .then(data=>{
                        document.getElementById("content-area").innerHTML=data;
                    })
                } 
                function deleteArea(id){ 
                    if(confirm("Xóa khu vực?")){
                        fetch("/Area/Delete/"+id) 
                        .then(()=>{
                            loadArea()
                        }) 
                    }
                }
                function loadVersion(areaId){ 
                    fetch("/ZoneVersion/Index?areaId=" + areaId)
                    .then(res => res.text())
                    .then(data => { 
                        document.getElementById("content-area").innerHTML = data;
                    });
                }

        /* ================= GLOBAL ================= */

        var map;
        var drawnItems;
        var versionId;

        var draw=false;
        var points=[];
        var polygon=null;

        var markers=[];
        var selectedPolygon=null;
        var selectedId=null;

        var polygons=[];

        /* ================= LOAD AREA ================= */

        function loadArea(){

        fetch("/Area/Index")
        .then(res=>res.text())
        .then(data=>{
        document.getElementById("content-area").innerHTML=data;
        });

        }

        /* ================= LOAD VERSION ================= */

        function loadVersion(areaId , name){
            areaName = name;
         fetch("/ZoneVersion/Index?areaId="+areaId)
        .then(res=>res.text())
        .then(data=>{
        document.getElementById("content-area").innerHTML=data;
        });

        }

        /* ================= OPEN MAP ================= */

        function openMap(id){

        fetch("/Zone/Map?versionId="+id)
        .then(res=>res.text())
        .then(data=>{

        document.getElementById("content-area").innerHTML=data;

        setTimeout(function(){

        initMap(id);

        },300);

        });

        }

        /* ================= INIT MAP ================= */
        function initMap(vId){

        versionId=vId;

        map=L.map('map').setView([21.0285,105.8542],13);

        L.tileLayer(
        'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
        {maxZoom:19}
        ).addTo(map);

        drawnItems=new L.FeatureGroup();
        map.addLayer(drawnItems);

        var drawControl=new L.Control.Draw({
        edit:{
        featureGroup: drawnItems
        },
        draw:false
        });

        map.addControl(drawControl);

        map.on("click",function(e){

        if(!draw) return;

        points.push([e.latlng.lat,e.latlng.lng]);

        var marker=L.circleMarker(e.latlng,{
        radius:5,
        color:"blue"
        }).addTo(map);

        markers.push(marker);

        if(polygon)
        map.removeLayer(polygon);

        polygon=L.polygon(points,{
        color:"#2563eb",
        fillOpacity:0.3
        }).addTo(map);

        });

        loadZones(versionId);

        }

        /* ================= DRAW ================= */

        function enableDraw(){

        draw=true;

        points=[];

        if(polygon){
        map.removeLayer(polygon);
        polygon=null;
        }

        markers.forEach(m=>map.removeLayer(m));
        markers=[];

        }

        /* ================= DONE ================= */


        function finishArea(){

        if(!polygon){
        alert("Chưa vẽ vùng");
        return;
        }

        draw=false;

        selectedPolygon=polygon;

        drawnItems.addLayer(polygon);

        // ⭐ HIỆN FORM CHỌN KHU VỰC

        loadAreaSelect();

        }
        function loadAreaSelect(){

        fetch("/Area/GetAll")
        .then(r=>r.json())
        .then(data=>{

        let html = `<h3>Chọn khu vực</h3>`;

        html += `<select id="areaSelect">`;

        data.forEach(a=>{
        html += `<option value="${a.id}">${a.id} - ${a.areaName}</option>`;
        });

        html += `</select><br><br>`;

        html += `
        <button onclick="assignAreaToZone()">Lưu khu vực</button>
        `;

        document.getElementById("matrixResult").innerHTML = html;

        });

        }
        function assignAreaToZone(){

        let areaId = document.getElementById("areaSelect").value;

        if(!selectedId){
        alert("Chọn vùng trước");
        return;
        }

        fetch("/Zone/UpdateArea",{
        method:"POST",
        headers:{
        'Content-Type':'application/json'
        },
        body:JSON.stringify({
        zoneId:selectedId,
        areaId:areaId
        })
        })
        .then(r=>r.json())
        .then(d=>{

        if(d.success){
        alert("Đã cập nhật khu vực");
        }

        });

        }
        /* ================= CALCULATE AREA ================= */
function calculateArea(latlngs) {
    let points = latlngs[0] || latlngs;

    let area = 0;

    for (let i = 0; i < points.length; i++) {
        let j = (i + 1) % points.length;

        let p1 = points[i];
        let p2 = points[j];

        area += (p1.lng * p2.lat) - (p2.lng * p1.lat);
    }

    return Math.abs(area / 2) * 111000 * 111000;
}


/* ================= SAVE ================= */
function saveZone(){

    let name = document.getElementById("zoneName").value;

    if(!name){
        alert("Nhập tên vùng");
        return;
    }

    if(!polygon){
        alert("Chưa vẽ vùng");
        return;
    }

    let latlngs = polygon.getLatLngs();

    if(!latlngs || latlngs.length === 0){
        alert("Chưa có dữ liệu vùng");
        return;
    }

    // ⭐ tính diện tích
    let area = calculateArea(latlngs);
    console.log("AREA:", area); // debug

    let center = polygon.getBounds().getCenter();

    // ❌ BỎ areaSelect → vì không tồn tại trong map
    // let areaName = "";

    if(!versionId){
        alert("Chưa chọn version");
        return;
    }

    fetch("/Zone/SaveZone",{
        method:"POST",
        headers:{
            'Content-Type':'application/json'
        },
        body: JSON.stringify({
            zoneName: name,
            areaName: currentAreaName,
            points: JSON.stringify(latlngs),
            centerLat: center.lat,
            centerLng: center.lng,
            versionId: versionId,
            area: area
        })
    })
    .then(r=>r.json())
    .then(d=>{

        if(d.success){

            alert("Đã lưu vùng");

            polygon = null;

            loadZones(versionId);

            // ⭐ reload lại version để cập nhật diện tích
            if(typeof loadVersion === "function"){
                loadVersion(currentAreaId);
            }
        }
        else{
            alert("Lưu thất bại");
        }

    })
    .catch(err=>{
        console.error(err);
