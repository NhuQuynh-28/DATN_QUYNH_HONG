                .um-btn-cancel { background:#334155; border:none; border-radius:8px; padding:9px 18px; color:#94a3b8; font-size:13px; font-weight:600; cursor:pointer; }
                .um-btn-cancel:hover { background:#475569; color:white; }
                .um-btn-primary { background:linear-gradient(135deg,#3b82f6,#2563eb); border:none; border-radius:8px; padding:9px 22px; color:white; font-size:13px; font-weight:700; cursor:pointer; }
                .um-btn-primary:hover { opacity:.88; }
                .um-btn-danger { background:linear-gradient(135deg,#ef4444,#dc2626); border:none; border-radius:8px; padding:9px 22px; color:white; font-size:13px; font-weight:700; cursor:pointer; }
                .um-btn-danger:hover { opacity:.88; }
                .um-btn-success { background:linear-gradient(135deg,#22c55e,#16a34a); border:none; border-radius:8px; padding:9px 22px; color:white; font-size:13px; font-weight:700; cursor:pointer; }
                .um-btn-success:hover { opacity:.88; }
                .um-toast { position:fixed; bottom:28px; right:28px; z-index:99999; display:flex; align-items:center; gap:10px; background:#1e293b; border:1px solid #334155; border-radius:12px; padding:14px 20px; color:#f1f5f9; font-size:13px; font-weight:600; box-shadow:0 8px 32px rgba(0,0,0,.4); animation:toastIn .3s; min-width:260px; }
                @@keyframes toastIn { from{transform:translateX(100px);opacity:0} to{transform:translateX(0);opacity:1} }
                .um-toast.success { border-left:4px solid #22c55e; }
                .um-toast.error { border-left:4px solid #ef4444; }
                .um-toast.info { border-left:4px solid #3b82f6; }
                .um-reason-chip { display:inline-block; background:#334155; border-radius:6px; padding:4px 10px; margin:3px; font-size:12px; color:#94a3b8; cursor:pointer; transition:all .15s; }
                .um-reason-chip:hover { background:#3b82f6; color:white; }
                .role-select { background:#0f172a; border:1px solid #334155; border-radius:6px; padding:4px 8px; color:#f1f5f9; font-size:12px; cursor:pointer; outline:none; }
                .um-role-tabs { display:flex; gap:8px; margin-top:12px; }
                .um-role-tab { padding:7px 16px; border-radius:20px; font-size:12px; font-weight:600; cursor:pointer; background:#1e293b; border:1px solid #334155; color:#94a3b8; transition:all .2s; display:flex; align-items:center; gap:6px; }
                .um-role-tab:hover { border-color:#475569; color:#e2e8f0; background:#1e293b; }
                .um-role-tab.active { background:#3b82f6; border-color:#3b82f6; color:white; box-shadow:0 4px 12px rgba(59,130,246,.3); }
                .um-role-tab i { font-size:10px; opacity:.8; }
                </style>
                <div class="um-wrap">
                  <div class="um-header">
                    <div class="um-title"><i class="fas fa-users"></i> Quản lý User</div>
                    <div class="um-stats">
                      <div class="um-stat"><div class="val">${data.length}</div><div class="lbl">Tổng User</div></div>
                      <div class="um-stat green"><div class="val">${activeCount}</div><div class="lbl">Đang hoạt động</div></div>
                      <div class="um-stat yellow"><div class="val">${pendingCount}</div><div class="lbl">Chờ duyệt</div></div>
                    </div>
                  </div>
                  <div class="um-toolbar">
                    <div style="flex:1">
                        <input class="um-search" id="umSearch" placeholder="🔍  Tìm theo username, email..." oninput="umFilter()">
                        <div class="um-role-tabs">
                          <div class="um-role-tab active" data-role="" onclick="setRoleFilter('')"><i class="fas fa-users"></i> Tất cả</div>
                          <div class="um-role-tab" data-role="Admin" onclick="setRoleFilter('Admin')"><i class="fas fa-user-shield"></i> Admin</div>
                          <div class="um-role-tab" data-role="Dispatcher" onclick="setRoleFilter('Dispatcher')"><i class="fas fa-headset"></i> Dispatcher</div>
                          <div class="um-role-tab" data-role="Driver" onclick="setRoleFilter('Driver')"><i class="fas fa-truck"></i> Driver</div>
                        </div>
                    </div>
                    <div style="display:flex; gap:10px; align-items:flex-start">
                        <select class="um-filter" id="umFilterStatus" onchange="umFilter()" style="height:38px">
                          <option value="">Tất cả trạng thái</option>
                          <option value="approved">Đã duyệt</option>
                          <option value="pending">Chờ duyệt</option>
                        </select>
                        <select class="um-filter" id="umFilterRole" onchange="syncRolePills(this.value);umFilter()" style="display:none">
                          <option value="">Tất cả Role</option>
                          <option value="Admin">Admin</option>
                          <option value="Dispatcher">Dispatcher</option>
                          <option value="Driver">Driver</option>
                        </select>
                    </div>
                  </div>
                  <div class="um-table-wrap">
                    <table class="um-table" id="umTable">
                      <thead><tr>
                        <th>#</th>
                        <th>Người dùng</th>
                        <th>Role</th>
                        <th>Trạng thái</th>
                        <th>Khu vực</th>
                        <th>Ngày tạo TK</th>
                        <th>Ngày cập nhật</th>
                        <th>Thao tác</th>
                      </tr></thead>
                      <tbody id="umTbody">`;

                data.forEach((u,i)=>{
                    let initials = u.username ? u.username.substring(0,2).toUpperCase() : '??';
                    let approveStatus = u.isApproved
                        ? `<span class="badge badge-approved"><i class="fas fa-check-circle" style="font-size:9px"></i> Đã duyệt</span>`
                        : `<span class="badge badge-pending"><i class="fas fa-clock" style="font-size:9px"></i> Chờ duyệt</span>`;
                    let activeStatus = u.isActive
                        ? `<span class="badge badge-active" style="margin-top:4px;display:inline-flex"><i class="fas fa-circle" style="font-size:7px"></i> Active</span>`
                        : `<span class="badge badge-inactive" style="margin-top:4px;display:inline-flex"><i class="fas fa-circle" style="font-size:7px"></i> Inactive</span>`;
                    let approveActions = u.isApproved
                        ? `<button class="um-btn um-btn-toggle-${u.isActive?'on':'off'}" onclick="toggleActive(${u.id})" title="${u.isActive?'Khóa':'Kích hoạt'} tài khoản">
                             <i class="fas fa-power-off"></i> ${u.isActive?'Active':'Inactive'}
                           </button>`
                        : `<button class="um-btn um-btn-approve" onclick="approveUser(${u.id})" title="Duyệt tài khoản">
                             <i class="fas fa-check"></i> Duyệt
                           </button>
                           <button class="um-btn um-btn-reject" onclick="openReject(${u.id},'${u.username}')" title="Từ chối">
                             <i class="fas fa-times"></i> Từ chối
                           </button>`;

                    html += `<tr data-username="${u.username}" data-email="${u.email||''}" data-role="${u.role}" data-approved="${u.isApproved}">
                      <td style="color:#64748b;font-weight:600">${i+1}</td>
                      <td>
                        <div class="um-user-cell">
                          <div class="um-avatar">${initials}</div>
                          <div class="um-user-info">
                            <div class="name">${u.username}</div>
                            <div class="email">${u.email||'—'}</div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <select class="role-select" onchange="changeRole(${u.id},this.value)">
                          <option ${u.role==='Admin'?'selected':''}>Admin</option>
                          <option ${u.role==='Dispatcher'?'selected':''}>Dispatcher</option>
                          <option ${u.role==='Driver'?'selected':''}>Driver</option>
                        </select>
                      </td>
                      <td><div style="display:flex;flex-direction:column;gap:4px">${approveStatus}${activeStatus}</div></td>
                      <td><span style="color:${u.areaName?'#e2e8f0':'#475569'}">${u.areaName||'Chưa gán'}</span></td>
                      <td><span class="um-date">${fmtDate(u.createdAt)}</span></td>
                      <td><span class="um-date">${fmtDate(u.updatedAt)}</span></td>
                      <td>
                        <div class="um-actions">
                          <button class="um-btn um-btn-view" onclick="viewUser(${u.id})" title="Xem chi tiết"><i class="fas fa-eye"></i></button>
                          <button class="um-btn um-btn-edit" onclick="editUser(${u.id})" title="Chỉnh sửa"><i class="fas fa-pen"></i></button>
                          ${approveActions}
                          <button class="um-btn um-btn-area" onclick="openAssignArea(${u.id},'${u.username}')" title="Gán khu vực"><i class="fas fa-map-marker-alt"></i></button>
                          <button class="um-btn um-btn-delete" onclick="deleteUser(${u.id},'${u.username}')" title="Xóa"><i class="fas fa-trash"></i></button>
                        </div>
                      </td>
                    </tr>`;
                });

                html += `</tbody></table>
                  </div>
                  ${data.length===0?'<div class="um-empty"><i class="fas fa-inbox" style="font-size:40px;margin-bottom:10px;display:block"></i>Chưa có User nào</div>':''}
                </div>`;

                document.getElementById("content-area").innerHTML = html;
            });
        }

        function setRoleFilter(role){
            let sel = document.getElementById('umFilterRole');
            if(sel) sel.value = role;
            syncRolePills(role);
            umFilter();
        }

        function syncRolePills(role){
            document.querySelectorAll('.um-role-tab').forEach(t=>{
                t.classList.toggle('active', (t.dataset.role||'') === (role||''));
            });
        }

        function umFilter(){
            let q = (document.getElementById('umSearch')||{}).value?.toLowerCase()||'';
            let role = (document.getElementById('umFilterRole')||{}).value||'';
            let status = (document.getElementById('umFilterStatus')||{}).value||'';
            document.querySelectorAll('#umTbody tr').forEach(r=>{
                let matchQ = !q || (r.dataset.username||'').toLowerCase().includes(q) || (r.dataset.email||'').toLowerCase().includes(q);
                let matchRole = !role || r.dataset.role === role;
                let approved = r.dataset.approved === 'true';
                let matchStatus = !status || (status==='approved'&&approved) || (status==='pending'&&!approved);
                r.style.display = (matchQ&&matchRole&&matchStatus) ? '' : 'none';
            });
        }

        function showToast(msg, type='success'){
            let t = document.getElementById('umToast');
            if(!t){ t=document.createElement('div'); t.id='umToast'; document.body.appendChild(t); }
            let icons = {success:'fa-check-circle', error:'fa-times-circle', info:'fa-info-circle'};
            let colors = {success:'#22c55e', error:'#ef4444', info:'#3b82f6'};
            t.className = `um-toast ${type}`;
            t.innerHTML = `<i class="fas ${icons[type]||icons.info}" style="color:${colors[type]||colors.info}"></i> ${msg}`;
            t.style.display = 'flex';
            clearTimeout(t._timer);
            t._timer = setTimeout(()=>{ t.style.display='none'; }, 3200);
        }

        function openModal(html){
            let ov = document.getElementById('umOverlay');
            if(!ov){
                ov = document.createElement('div');
                ov.id = 'umOverlay';
                ov.className = 'um-modal-overlay';
                ov.onclick = function(e){ if(e.target===ov) closeModal(); };
                document.body.appendChild(ov);
            }
            ov.innerHTML = html;
            ov.style.display = 'flex';
        }
        function closeModal(){
            let ov = document.getElementById('umOverlay');
            if(ov) ov.style.display = 'none';
        }

        function viewUser(id){
            fetch("/User/Detail?id="+id).then(r=>r.json()).then(u=>{
                let roleBadge = {Admin:`<span class="badge badge-admin"><i class="fas fa-crown" style="font-size:9px"></i> Admin</span>`,
                    Dispatcher:`<span class="badge badge-dispatcher"><i class="fas fa-headset" style="font-size:9px"></i> Dispatcher</span>`}[u.role]
                    || `<span class="badge badge-driver"><i class="fas fa-truck" style="font-size:9px"></i> Driver</span>`;
                openModal(`<div class="um-modal">
                  <div class="um-modal-header">
                    <div class="um-modal-title"><i class="fas fa-id-card" style="color:#3b82f6"></i> Thông tin User</div>
                    <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
                  </div>
                  <div style="display:flex;align-items:center;gap:14px;margin-bottom:22px;padding:16px;background:#0f172a;border-radius:12px">
                    <div class="um-avatar" style="width:52px;height:52px;font-size:20px">${(u.username||'?').substring(0,2).toUpperCase()}</div>
                    <div><div style="font-size:18px;font-weight:700;color:#f1f5f9">${u.username}</div><div style="margin-top:4px">${roleBadge}</div></div>
                  </div>
                  <div class="um-info-grid">
                    <div class="um-info-item"><label><i class="fas fa-envelope"></i> Email</label><span>${u.email||'—'}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-phone"></i> Số điện thoại</label><span>${u.phone||'—'}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-id-badge"></i> CCCD</label><span>${u.cccd||'—'}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-map-marker-alt"></i> Khu vực</label><span>${u.areaName||'Chưa gán'}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-home"></i> Địa chỉ</label><span>${u.address||'—'}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-check-circle"></i> Trạng thái</label><span>${u.isApproved?(u.isActive?'✅ Active':'⚠️ Khóa'):'⏳ Chờ duyệt'}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-calendar-plus"></i> Ngày tạo TK</label><span style="font-size:12px">${fmtDate(u.createdAt)}</span></div>
                    <div class="um-info-item"><label><i class="fas fa-calendar-check"></i> Ngày cập nhật</label><span style="font-size:12px">${fmtDate(u.updatedAt)}</span></div>
                  </div>
                  <div class="um-modal-footer">
                    <button class="um-btn-cancel" onclick="closeModal()">Đóng</button>
                    <button class="um-btn-primary" onclick="closeModal();editUser(${u.id})"><i class="fas fa-pen"></i> Chỉnh sửa</button>
                  </div>
                </div>`);
            });
        }

        function editUser(id){
            fetch("/User/Detail?id="+id).then(r=>r.json()).then(u=>{
                fetch("/Area/GetAll").then(r2=>r2.json()).then(areas=>{
                    let areaOpts = areas.map(a=>`<option value="${a.id}" ${u.areaId==a.id?'selected':''}>${a.areaName||a.name}</option>`).join('');
                    _showEditModal(u, areaOpts);
                }).catch(()=>_showEditModal(u, ''));
            });
        }
        function _showEditModal(u, areaOpts){
            openModal(`<div class="um-modal">
              <div class="um-modal-header">
                <div class="um-modal-title"><i class="fas fa-user-edit" style="color:#4ade80"></i> Chỉnh sửa User</div>
                <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
              </div>
              <div class="um-form-group"><label>Username</label><input class="um-form-input" value="${u.username}" disabled style="opacity:.6"></div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div class="um-form-group"><label>Email</label><input class="um-form-input" id="eEmail" value="${u.email||''}"></div>
                <div class="um-form-group"><label>Số điện thoại</label><input class="um-form-input" id="ePhone" value="${u.phone||''}"></div>
                <div class="um-form-group"><label>CCCD</label><input class="um-form-input" id="eCccd" value="${u.cccd||''}"></div>
                <div class="um-form-group"><label>Role</label>
                  <select class="um-form-select" id="eRole">
                    <option ${u.role==='Admin'?'selected':''}>Admin</option>
                    <option ${u.role==='Dispatcher'?'selected':''}>Dispatcher</option>
                    <option ${u.role==='Driver'?'selected':''}>Driver</option>
                  </select>
                </div>
              </div>
              <div class="um-form-group"><label>Địa chỉ</label><input class="um-form-input" id="eAddress" value="${u.address||''}"></div>
              ${areaOpts ? `<div class="um-form-group"><label>Khu vực</label><select class="um-form-select" id="eArea"><option value="">-- Chưa gán --</option>${areaOpts}</select></div>` : ''}
              <div class="um-modal-footer">
                <button class="um-btn-cancel" onclick="closeModal()">Hủy</button>
                <button class="um-btn-primary" onclick="saveEdit(${u.id})"><i class="fas fa-save"></i> Lưu thay đổi</button>
              </div>
            </div>`);
        }

        function saveEdit(id){
            let body = `id=${id}`
                + `&email=${encodeURIComponent(document.getElementById('eEmail')?.value||'')}`
                + `&phone=${encodeURIComponent(document.getElementById('ePhone')?.value||'')}`
                + `&cccd=${encodeURIComponent(document.getElementById('eCccd')?.value||'')}`
                + `&address=${encodeURIComponent(document.getElementById('eAddress')?.value||'')}`
                + `&role=${document.getElementById('eRole')?.value||'Driver'}`
                + `&areaId=${document.getElementById('eArea')?.value||''}`;
            fetch("/User/Update",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body })
            .then(r=>r.json()).then(d=>{
                if(d.success){ closeModal(); showToast('Đã cập nhật thông tin user!','success'); loadUsers(); }
                else showToast(d.message||'Lỗi cập nhật','error');
            });
        }

        function approveUser(id){
            fetch("/User/Approve",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:"id="+id })
            .then(r=>r.json()).then(d=>{
                if(d.success){ showToast('Đã duyệt tài khoản thành công! Trạng thái: Active','success'); loadUsers(); }
                else showToast(d.message||'Lỗi khi duyệt','error');
            });
        }

        function openReject(id, username){
            let reasons = ['Thông tin không hợp lệ','CCCD không khớp với hồ sơ','Tài khoản trùng lặp trong hệ thống','Không đủ điều kiện đăng ký','Ảnh hồ sơ không rõ ràng','Số điện thoại không xác minh được'];
            let chips = reasons.map(r=>`<span class="um-reason-chip" onclick="document.getElementById('rejectReason').value='${r}'">${r}</span>`).join('');
            openModal(`<div class="um-modal">
              <div class="um-modal-header">
                <div class="um-modal-title"><i class="fas fa-ban" style="color:#ef4444"></i> Từ chối duyệt</div>
                <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
              </div>
              <p style="color:#94a3b8;margin:0 0 14px">Từ chối tài khoản: <strong style="color:#f1f5f9">${username}</strong></p>
              <div class="um-form-group">
                <label>Lý do từ chối <span style="color:#64748b;font-weight:400">(chọn nhanh hoặc tự nhập)</span></label>
                <div style="margin-bottom:10px">${chips}</div>
                <textarea class="um-form-textarea" id="rejectReason" placeholder="Nhập lý do từ chối..."></textarea>
              </div>
              <div class="um-modal-footer">
                <button class="um-btn-cancel" onclick="closeModal()">Hủy</button>
                <button class="um-btn-danger" onclick="submitReject(${id},'${username}')"><i class="fas fa-times-circle"></i> Xác nhận từ chối</button>
              </div>
            </div>`);
        }

        function submitReject(id, username){
            let reason = document.getElementById('rejectReason').value.trim();
            if(!reason){ showToast('Vui lòng nhập lý do từ chối!','error'); return; }
            fetch("/User/Reject",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:`id=${id}&reason=${encodeURIComponent(reason)}` })
            .then(r=>r.json()).then(d=>{
                if(d.success){
                    closeModal();
                    openModal(`<div class="um-modal">
                      <div class="um-modal-header">
                        <div class="um-modal-title"><i class="fas fa-envelope" style="color:#f59e0b"></i> Đã ghi nhận lý do từ chối</div>
                        <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
                      </div>
                      <div style="background:#0f172a;border-radius:10px;padding:16px;margin-bottom:16px">
                        <div style="color:#94a3b8;font-size:12px;margin-bottom:4px">Tài khoản</div>
                        <div style="font-weight:700;color:#f1f5f9">${d.username}</div>
                        <div style="color:#94a3b8;font-size:12px;margin-top:12px;margin-bottom:4px">Lý do từ chối</div>
                        <div style="color:#fca5a5;font-style:italic">"${d.reason}"</div>
                      </div>
                      <p style="color:#64748b;font-size:12px;margin:0">* Lý do chỉ hiển thị để tham khảo, không lưu vào cơ sở dữ liệu.</p>
                      <div class="um-modal-footer"><button class="um-btn-primary" onclick="closeModal()">Đóng</button></div>
                    </div>`);
                }
            });
        }

        function toggleActive(id){
            fetch("/User/ToggleActive",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:"id="+id })
            .then(r=>r.json()).then(d=>{
                if(d.success){ showToast(d.isActive?'Đã kích hoạt tài khoản!':'Đã khóa tài khoản!', d.isActive?'success':'info'); loadUsers(); }
            });
        }

        function changeRole(id, role){
            fetch("/User/ChangeRole",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:`id=${id}&role=${role}` })
            .then(r=>r.json()).then(d=>{ if(d.success) showToast(`Đã đổi role thành ${role}`,'info'); });
        }

        function openAssignArea(id, username){
            fetch("/Area/GetAll").then(r=>r.json()).then(areas=>{
                let opts = areas.map(a=>`<option value="${a.id}">${a.areaName||a.name}</option>`).join('');
                openModal(`<div class="um-modal" style="min-width:340px;max-width:400px">
                  <div class="um-modal-header">
                    <div class="um-modal-title"><i class="fas fa-map-marked-alt" style="color:#c4b5fd"></i> Gán khu vực</div>
                    <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
                  </div>
                  <p style="color:#94a3b8;margin:0 0 16px">User: <strong style="color:#f1f5f9">${username}</strong></p>
                  <div class="um-form-group"><label>Chọn khu vực</label>
                    <select class="um-form-select" id="assignAreaSel"><option value="">-- Chọn khu vực --</option>${opts}</select>
                  </div>
                  <div class="um-modal-footer">
                    <button class="um-btn-cancel" onclick="closeModal()">Hủy</button>
                    <button class="um-btn-primary" onclick="submitAssignArea(${id})"><i class="fas fa-check"></i> Gán</button>
                  </div>
                </div>`);
            }).catch(()=>{
                openModal(`<div class="um-modal" style="min-width:340px;max-width:400px">
                  <div class="um-modal-header">
                    <div class="um-modal-title"><i class="fas fa-map-marked-alt" style="color:#c4b5fd"></i> Gán khu vực</div>
                    <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
                  </div>
                  <div class="um-form-group"><label>Nhập Area ID</label><input class="um-form-input" id="assignAreaIdInput" placeholder="Nhập ID khu vực..."></div>
                  <div class="um-modal-footer">
                    <button class="um-btn-cancel" onclick="closeModal()">Hủy</button>
                    <button class="um-btn-primary" onclick="submitAssignAreaManual(${id})"><i class="fas fa-check"></i> Gán</button>
                  </div>
                </div>`);
            });
        }
        function submitAssignArea(id){
            let areaId = document.getElementById('assignAreaSel')?.value;
            if(!areaId){ showToast('Vui lòng chọn khu vực!','error'); return; }
            fetch("/User/AssignArea",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:`id=${id}&areaId=${areaId}` })
            .then(r=>r.json()).then(d=>{ if(d.success){ closeModal(); showToast('Đã gán khu vực!','success'); loadUsers(); } });
        }
        function submitAssignAreaManual(id){
            let areaId = document.getElementById('assignAreaIdInput')?.value;
            if(!areaId){ showToast('Vui lòng nhập Area ID!','error'); return; }
            fetch("/User/AssignArea",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:`id=${id}&areaId=${areaId}` })
            .then(r=>r.json()).then(d=>{ if(d.success){ closeModal(); showToast('Đã gán khu vực!','success'); loadUsers(); } });
        }
        function assignArea(id){ openAssignArea(id,''); }

        function deleteUser(id, username){
            openModal(`<div class="um-modal" style="min-width:340px;max-width:400px">
              <div class="um-modal-header">
                <div class="um-modal-title"><i class="fas fa-trash" style="color:#ef4444"></i> Xóa User</div>
                <button class="um-modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
              </div>
              <p style="color:#94a3b8;margin:0 0 6px">Bạn có chắc muốn xóa tài khoản:</p>
              <p style="color:#f87171;font-weight:700;font-size:16px;margin:0 0 18px">${username}</p>
              <p style="color:#64748b;font-size:12px;margin:0">Hành động này không thể hoàn tác.</p>
              <div class="um-modal-footer">
                <button class="um-btn-cancel" onclick="closeModal()">Hủy</button>
                <button class="um-btn-danger" onclick="confirmDelete(${id})"><i class="fas fa-trash"></i> Xóa</button>
              </div>
            </div>`);
        }
        function confirmDelete(id){
            fetch("/User/Delete",{ method:"POST", headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:"id="+id })
            .then(r=>r.json()).then(d=>{ if(d.success){ closeModal(); showToast('Đã xóa user!','info'); loadUsers(); } });
        }
                        function toggleDriverMenu(){

            var menu = document.getElementById("driverMenu");
            var arrow = document.getElementById("arrowDriver");

            if(menu.style.display === "block"){
                menu.style.display = "none";
                arrow.innerHTML = "▼";
            } else {
                menu.style.display = "block";
                arrow.innerHTML = "▲";
            }
        }
                /* ===== CLEANUP STATE KHEN CHUYỂN TRANG ===== */
        function cleanupState(){
            // Ẩn map toolbar
            hideMapToolbar();

            // Destroy map instance nếu có
            if(map){
                try { map.remove(); } catch(e){}
                map = null;
            }
            drawnItems = null;
            versionId = null;
            draw = false;
            points = [];
            polygon = null;
            markers = [];
            selectedPolygon = null;
            selectedId = null;
            polygons = [];

            // Xóa các script đã inject trước đó
            document.querySelectorAll('script[data-injected]').forEach(s => s.remove());

            // Đóng modal nếu đang mở
            closeModal();
            let driverOverlay = document.getElementById('driverOverlay');
            if(driverOverlay) driverOverlay.classList.remove('open');
        }

        function loadPage(url){
            cleanupState();
            fetch(url)
            .then(res => res.text())
            .then(data => {
                const content = document.getElementById("content-area");
                content.innerHTML = data;

                // chạy script trong view
                const scripts = content.querySelectorAll("script");
                scripts.forEach(oldScript => {
                    const newScript = document.createElement("script");
                    newScript.text = oldScript.text;
                    newScript.setAttribute('data-injected', 'true');
                    document.body.appendChild(newScript);
                });

                // 👇 FIX QUAN TRỌNG NHẤT
                setTimeout(function(){
                    if(typeof loadAreas === "function"){
                        loadAreas();
                    }
                }, 100);
            });
        }
                function openCreateVersion(areaId) {

            if (!areaId) {
                alert("Thiếu AreaId");
                return;
            }

            fetch("/ZoneVersion/Create?areaId=" + areaId)
                .then(res => res.text())
                .then(html => {

                    // 👉 nếu chưa có modal thì tạo
                    let modal = document.getElementById("modal");

                    if (!modal) {
                        modal = document.createElement("div");
                        modal.id = "modal";

                        modal.style.position = "fixed";
                        modal.style.top = "50%";
                        modal.style.left = "50%";
                        modal.style.transform = "translate(-50%, -50%)";
                        modal.style.background = "#1e293b";
                        modal.style.color = "white";
                        modal.style.padding = "20px";
                        modal.style.borderRadius = "10px";
                        modal.style.zIndex = "9999";
                        modal.style.minWidth = "300px";

                        document.body.appendChild(modal);
                    }

                    // 👉 gán nội dung form
                    modal.innerHTML = html;

                    // 👉 hiển thị
                    modal.style.display = "block";
                })
                .catch(err => {
                    console.error(err);
                    alert("Lỗi mở form");
                });
        }
                document.addEventListener("click", function (e) {
            let modal = document.getElementById("modal");

            if (modal && e.target === modal) {
                modal.style.display = "none";
            }
        });
        function deleteVersion(id) {
            if (!confirm("Bạn có chắc muốn xoá version này?")) return;
            fetch("/ZoneVersion/Delete?id=" + id)
            .then(res => res.text())
            .then(html => {
                document.getElementById("content-area").innerHTML = html;
                showToast('Đã xóa version!','info');
            })
            .catch(err => { console.error(err); showToast('Lỗi khi xóa!','error'); });
        }
        function setActive(id) {
            fetch("/ZoneVersion/SetActive?id=" + id)
            .then(res => {
                if (!res.ok) throw new Error("Lỗi set active");
                let aid = getCurrentAreaId();
                if (!aid) { showToast('Không xác định được khu vực!','error'); return Promise.reject('no area'); }
                return fetch("/ZoneVersion/Index?areaId=" + aid);
            })
            .then(res => res.text())
            .then(html => {
                document.getElementById("content-area").innerHTML = html;
                showToast('Đã đặt Active thành công!','success');
            })
            .catch(err => {
                if (err !== 'no area') { console.error(err); showToast('Lỗi khi set Active!','error'); }
            });
        }
        function getCurrentAreaId() {
            // Dùng biến global currentAreaId (được set khi openAreaMap / loadVersion)
            return currentAreaId || _activeAreaId || 0;
        }
