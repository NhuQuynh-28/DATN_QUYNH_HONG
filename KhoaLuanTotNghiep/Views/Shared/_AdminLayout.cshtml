    });

}
        /* ================= LOAD ZONE ================= */
                     function loadZones(versionId){

            drawnItems.clearLayers();

            fetch("/Zone/GetZones?versionId="+versionId)
            .then(r=>r.json())
            .then(data=>{

                polygons=[];

                data.forEach(z=>{

                    let pts = JSON.parse(z.points);

            let poly = L.polygon(pts,{
            color:'blue',
            fillOpacity:0.3
        });

        drawnItems.addLayer(poly); // ⭐ thêm vào layer chuẩn

                    poly.zoneId = z.id;
                    polygons.push(poly);

                    // HIỆN TÊN
                    let center = poly.getBounds().getCenter();
                    let name = z.zoneName ?? z.ZoneName ?? "Zone";

                    L.marker(center,{
                        icon: L.divIcon({
                            className:'zone-label',
                            html:`<div style="
                                background:#2563eb;
                                color:white;
                                padding:3px 6px;
                                border-radius:4px;
                                font-size:12px;
                            ">${name}</div>`
                        })
                    }).addTo(map);

                    // CLICK
                    poly.on("click", function () {

                        selectedPolygon = poly;
                        selectedId = z.id;

                        loadHistory(z.id);
                        loadPredict(z.id);

                        drawnItems.addLayer(poly);

                        polygons.forEach(p=>{
                            p.setStyle({
                                color:'blue',
                                fillOpacity:0.3
                            });
                        });

                        poly.setStyle({
                            color:'red',
                            fillOpacity:0.6
                        });

                        poly.editing.enable();
                    });

                }); // ✅ đóng forEach

            }); // ✅ đóng then

        } // ✅ đóng function
        /* ================= DELETE ================= */

        function deleteSelected(){

        if(!selectedId){
        alert("Chọn vùng trước");
        return;
        }

        fetch('/Zone/DeleteZone?id='+selectedId,{
        method:'POST'
        })
        .then(r=>r.json())
        .then(d=>{

        if(d.success){

        alert("Đã xóa");

        loadZones(versionId);

        }

        })

        }

        /* ================= UPDATE ================= */

        function updateZone(){

        if(!selectedPolygon){
        alert("Chọn vùng");
        return;
        }

        let coords=selectedPolygon.getLatLngs()[0];

        let pts=[];

        coords.forEach(c=>{
        pts.push([c.lat,c.lng]);
        });

        let center=getCenter(pts);

        fetch('/Zone/UpdateZone',{
        method:'POST',
        headers:{
        'Content-Type':'application/json'
        },
        body:JSON.stringify({

        Id:selectedId,
        Points:JSON.stringify(pts),
        CenterLat:center.lat,
        CenterLng:center.lng

        })
        })
        .then(r=>r.json())
        .then(d=>{

        if(d.success){
        alert("Đã cập nhật");
        }

        })

        }

        /* ================= DELETE ALL ================= */

        function clearAll(){

        fetch('/Zone/DeleteAll?versionId='+versionId,{
        method:'POST'
        })
        .then(r=>r.json())
        .then(d=>{

        if(d.success){

        loadZones(versionId);

        }

        })

        }

        /* ================= DISTANCE ================= */

                function calculateDistances(){

        let polys=[];
        let names=[];

        drawnItems.eachLayer(function(layer){

        polys.push(layer);

        names.push("Zone "+layer.zoneId);

        });

        let html="<h3>Ma trận khoảng cách</h3>";
        html+="<table border='1' style='border-collapse:collapse'>";

        html+="<tr><th></th>";

        names.forEach(n=>{
        html+="<th>"+n+"</th>";
        });

        html+="</tr>";

        for(let i=0;i<polys.length;i++){

        html+="<tr>";

        html+="<th>"+names[i]+"</th>";

        for(let j=0;j<polys.length;j++){

        if(i==j){
        html+="<td>0</td>";
        }
        else{

        let c1=polys[i].getBounds().getCenter();
        let c2=polys[j].getBounds().getCenter();

        let d=map.distance(c1,c2);

        html+="<td>"+Math.round(d)+" m</td>";

        }

        }

        html+="</tr>";

        }

        html+="</table>";

        document.getElementById("matrixResult").innerHTML=html;

        }
        /* ================= ADJACENT ================= */

        function checkAdjacency(){

        let polys=[];
        let names=[];

        drawnItems.eachLayer(function(layer){

        polys.push(layer);
        names.push("Zone " + layer.zoneId);

        });

        let html="<h3>Ma trận vùng kề</h3>";
        html+="<table border='1' style='border-collapse:collapse'>";

        html+="<tr><th></th>";

        names.forEach(n=>{
        html+="<th>"+n+"</th>";
        });

        html+="</tr>";

        for(let i=0;i<polys.length;i++){

        html+="<tr>";
        html+="<th>"+names[i]+"</th>";

        for(let j=0;j<polys.length;j++){

        if(i==j){
        html+="<td>0</td>";
        }
        else{

        let isAdjacent = polys[i]
        .getBounds()
        .intersects(polys[j].getBounds());

        html+="<td>"+(isAdjacent ? 1 : 0)+"</td>";

        }

        }

        html+="</tr>";

        }

        html+="</table>";

        document.getElementById("matrixResult").innerHTML=html;

        }

        /* ================= CENTER ================= */

        function getCenter(points){

        let lat=0;
        let lng=0;

        points.forEach(p=>{
        lat+=p[0];
        lng+=p[1];
        });

        return{
        lat:lat/points.length,
        lng:lng/points.length
        };

        }
        function loadUsers(){

        fetch("/User/GetUsers")
        .then(r=>r.json())
        .then(data=>{

        let html = `<h2>Quản lý User</h2>`;

        html += `<table border="1">
        <tr>
        <th>ID</th>
        <th>User</th>
        <th>Role</th>
        <th>Approve</th>
        <th>Active</th>
        <th>Area</th>
        <th>Action</th>
        </tr>`;

        data.forEach(u=>{

        html += `
        <tr>
        <td>${u.id}</td>
        <td>${u.username}</td>

        <td>
        <select onchange="changeRole(${u.id}, this.value)">
        <option ${u.role=='Admin'?'selected':''}>Admin</option>
        <option ${u.role=='Dispatcher'?'selected':''}>Dispatcher</option>
        <option ${u.role=='Driver'?'selected':''}>Driver</option>
        </select>
        </td>

        <td>
        ${u.isApproved
        ? '✔'
        : `<button onclick="approveUser(${u.id})">Approve</button>`}
        </td>

        <td>
        <button onclick="toggleActive(${u.id})">
        ${u.isActive ? 'Active' : 'Deactive'}
        </button>
        </td>

        <td>
        ${u.areaName || "Chưa có"}
        <br>
        <button onclick="assignArea(${u.id})">Gán</button>
        </td>

        <td>
        <button onclick="viewUser(${u.id})">Xem</button>
        </td>

        </tr>
        `;

        });

        html += `</table>`;

        document.getElementById("content-area").innerHTML = html;

        });
        }
                function approveUser(id){
            fetch("/User/Approve",{
                method:"POST",
                headers:{
                    'Content-Type':'application/x-www-form-urlencoded'
                },
                body:"id="+id
            })
            .then(r=>r.json())
            .then(d=>{
                if(d.success){
                    loadUsers();
                }
            });
        }
                function toggleActive(id){
            fetch("/User/ToggleActive",{
                method:"POST",
                headers:{
                    'Content-Type':'application/x-www-form-urlencoded'
                },
                body:"id="+id
            })
            .then(r=>r.json())
            .then(d=>{
                if(d.success){
                    loadUsers();
                }
            });
        }
                function changeRole(id, role){
            fetch("/User/ChangeRole",{
                method:"POST",
                headers:{
                    'Content-Type':'application/x-www-form-urlencoded'
                },
                body:`id=${id}&role=${role}`
            })
            .then(r=>r.json())
            .then(d=>{
                if(d.success){
                    console.log("Đã đổi role");
                }
            });
        }
                function viewUser(id){
            fetch("/User/Detail?id="+id)
            .then(r=>r.json())
            .then(u=>{
                alert(`
        User: ${u.username}
        Role: ${u.role}
        Active: ${u.isActive}
        Approved: ${u.isApproved}
        Area: ${u.areaName || "Chưa có"}
                `);
            });
        }
                function assignArea(id){

            let areaId = prompt("Nhập AreaId:");

            if(!areaId) return;

            fetch("/User/AssignArea",{
                method:"POST",
                headers:{
                    'Content-Type':'application/x-www-form-urlencoded'
                },
                body:`id=${id}&areaId=${areaId}`
            })
            .then(r=>r.json())
            .then(d=>{
                if(d.success){
                    loadUsers();
                }
            });
        }
                        function toggleDriverMenu(){

            var menu = document.getElementById("driverMenu");
            var arrow = document.getElementById("arrowDriver");

            if(menu.style.display === "block"){
                menu.style.display = "none";
                arrow.innerHTML = "▼";
            } else {
                menu.style.display = "block";
                arrow.innerHTML = "▲";
            }
        }
                function loadPage(url){
            fetch(url)
            .then(res => res.text())
            .then(data => {
                const content = document.getElementById("content-area");
                content.innerHTML = data;

                // chạy script trong view
                const scripts = content.querySelectorAll("script");
                scripts.forEach(oldScript => {
                    const newScript = document.createElement("script");
                    newScript.text = oldScript.text;
                    document.body.appendChild(newScript);
                });

                // 👇 FIX QUAN TRỌNG NHẤT
                setTimeout(function(){
                    if(typeof loadAreas === "function"){
                        loadAreas();
                    }
                }, 100);
            });
        }
                function openCreateVersion(areaId) {

            if (!areaId) {
                alert("Thiếu AreaId");
                return;
            }

            fetch("/ZoneVersion/Create?areaId=" + areaId)
                .then(res => res.text())
                .then(html => {

                    // 👉 nếu chưa có modal thì tạo
                    let modal = document.getElementById("modal");

                    if (!modal) {
                        modal = document.createElement("div");
                        modal.id = "modal";

                        modal.style.position = "fixed";
                        modal.style.top = "50%";
                        modal.style.left = "50%";
                        modal.style.transform = "translate(-50%, -50%)";
                        modal.style.background = "#1e293b";
                        modal.style.color = "white";
                        modal.style.padding = "20px";
                        modal.style.borderRadius = "10px";
                        modal.style.zIndex = "9999";
                        modal.style.minWidth = "300px";

                        document.body.appendChild(modal);
                    }

                    // 👉 gán nội dung form
                    modal.innerHTML = html;

                    // 👉 hiển thị
                    modal.style.display = "block";
                })
                .catch(err => {
                    console.error(err);
                    alert("Lỗi mở form");
                });
        }
                document.addEventListener("click", function (e) {
            let modal = document.getElementById("modal");

            if (modal && e.target === modal) {
                modal.style.display = "none";
            }
        });
                function deleteVersion(id) {

            if (!confirm("Bạn có chắc muốn xoá version này?")) return;

            fetch("/ZoneVersion/Delete?id=" + id)
                .then(res => res.text())
                .then(html => {

                    // 👉 reload lại danh sách version
                    document.getElementById("content-area").innerHTML = html;

                })
                .catch(err => {
                    console.error(err);
                    alert("Lỗi khi xoá");
                });
        }
                function setActive(id) {

            fetch("/ZoneVersion/SetActive?id=" + id)
                .then(res => {
                    if (!res.ok) throw new Error("Lỗi set active");

                    // 👉 reload lại list version
                    // lấy lại areaId từ button hiện tại
                    let areaId = getCurrentAreaId();

                    return fetch("/ZoneVersion/Index?areaId=" + areaId);
                })
                .then(res => res.text())
                .then(html => {
                    document.getElementById("content-area").innerHTML = html;
                })
                .catch(err => {
                    console.error(err);
                    alert("Lỗi khi active");
                });
        }
                function getCurrentAreaId() {

            // cách đơn giản: lấy từ button "+ Thêm Version"
            let btn = document.querySelector(".btn-add");

            if (!btn) return 0;

            let onclick = btn.getAttribute("onclick");

            // lấy số trong openCreateVersion(1)
            let match = onclick.match(/\d+/);

            return match ? match[0] : 0;
        }
                        function toggleReportMenu(){

            var menu = document.getElementById("reportMenu");
            var arrow = document.getElementById("arrowReport");

            if(menu.style.display === "block"){
                menu.style.display = "none";
                arrow.innerHTML = "▼";
            } else {
                menu.style.display = "block";
                arrow.innerHTML = "▲";
            }
        }
