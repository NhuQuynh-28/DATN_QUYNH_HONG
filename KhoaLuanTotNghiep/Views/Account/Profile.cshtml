@model KhoaLuanTotNghiep.Models.User
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    var role = Context.Session.GetString("Role");
    string backUrl = role switch
    {
        "Admin" => "/Admin/Index",
        "Dispatcher" => "/Dispatcher/Index",
        "Driver" => "/DriverDashboard/Index",
        _ => "/"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Hồ sơ cá nhân - Delivery Zone</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:'Inter',sans-serif; background:#0f172a; color:#f1f5f9; }
        
        .profile-container {
            padding: 60px 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
        }

        .back-nav {
            max-width: 800px;
            width: 100%;
            margin: 0 auto 20px;
            display: flex;
        }

        .back-link {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: 0.2s;
        }

    <div class="profile-container" style="flex-direction:column; align-items:center;">
    <div class="back-nav">
        <a href="@backUrl" class="back-link">
            <i class="fas fa-arrow-left"></i> Quay lại Dashboard
        </a>
    </div>
    <div class="profile-card">
        <div class="profile-header">
            <h3>Thiết lập tài khoản</h3>
            <p>Quản lý thông tin cá nhân và ảnh đại diện</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        }

        <form asp-action="EditProfile" asp-controller="Account" method="post" enctype="multipart/form-data" class="profile-form">
            <div class="avatar-section">
                <div class="avatar-wrapper">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="Avatar" id="avatarPreview" />
                    }
                    else
                    {
                        <div class="avatar-placeholder" id="avatarPlaceholder">
                            <i class="fas fa-user"></i>
                        </div>
                    }
                    <label for="avatarInput" class="avatar-upload-btn">
                        <i class="fas fa-camera"></i>
                        <input type="file" id="avatarInput" name="avatar" accept="image/*" onchange="previewImage(this)" style="display:none;" />
                    </label>
                </div>
                <div class="avatar-info">
                    <strong>Ảnh đại diện</strong>
                    <span>Dung lượng tối đa 2MB. Định dạng: JPG, PNG</span>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label>Tên đăng nhập</label>
                    <input type="text" value="@Model.Username" disabled class="form-control disabled-input" title="Tên đăng nhập không thể thay đổi"/>
                </div>

                <div class="form-group">
                    <label>Email liên hệ</label>
                    <input type="email" name="Email" value="@Model.Email" class="form-control" placeholder="example@gmail.com" />
                </div>

                <div class="form-group">
                    <label>Số điện thoại</label>
                    <input type="text" name="Phone" value="@Model.Phone" class="form-control" placeholder="09xxxxxxx" />
                </div>

                <div class="form-group">
                    <label>CMND/CCCD</label>
                    <input type="text" name="Cccd" value="@Model.Cccd" class="form-control" placeholder="Số định danh cá nhân" />
                </div>

                <div class="form-group full-width">
                    <label>Địa chỉ thường chú</label>
                    <input type="text" name="Address" value="@Model.Address" class="form-control" placeholder="Số nhà, tên đường, phường/xã..." />
                </div>
            </div>


            <div class="form-actions">
                <button type="submit" class="save-btn">
                    <i class="fas fa-save"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .profile-container {
        padding: 40px 20px;
        display: flex;
        justify-content: center;
        background: #0f172a;
        min-height: calc(100vh - 65px);
    }

    .profile-card {
        background: #1e293b;
        width: 100%;
        max-width: 800px;
        border-radius: 16px;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        padding: 32px;
        border: 1px solid #334155;
    }

    .profile-header {
        margin-bottom: 32px;
        border-bottom: 1px solid #334155;
        padding-bottom: 16px;
    }

    .profile-header h3 {
        font-size: 24px;
        font-weight: 700;
        color: #f8fafc;
        margin-bottom: 4px;
    }

    .profile-header p {
        color: #94a3b8;
        font-size: 14px;
    }

    .alert-success {
        background: rgba(34, 197, 94, 0.1);
        border-left: 4px solid #22c55e;
        color: #4ade80;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar-section {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 32px;
        padding: 20px;
        background: rgba(15, 23, 42, 0.5);
        border-radius: 12px;
        border: 1px dashed #334155;
    }

    .avatar-wrapper {
        position: relative;
        width: 100px;
        height: 100px;
    }

    .avatar-wrapper img, .avatar-placeholder {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #3b82f6;
    }

    .avatar-placeholder {
        background: #334155;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: #64748b;
    }

    .avatar-upload-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 32px;
        height: 32px;
        background: #2563eb;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        border: 2px solid #1e293b;
        transition: 0.2s;
    }

    .avatar-upload-btn:hover {
        background: #3b82f6;
        transform: scale(1.1);
    }

    .avatar-info strong {
        display: block;
        color: #f1f5f9;
        font-size: 16px;
        margin-bottom: 4px;
    }

    .avatar-info span {
        font-size: 13px;
        color: #64748b;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .full-width {
        grid-column: span 2;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 500;
        color: #cbd5e1;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 10px;
        color: #f8fafc;
        outline: none;
        transition: 0.2s;
    }

    .form-control:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
    }

    .disabled-input {
        background: rgba(51, 65, 85, 0.5);
        color: #94a3b8;
        cursor: not-allowed;
    }

    .form-actions {
        margin-top: 32px;
        display: flex;
        justify-content: flex-end;
    }

    .save-btn {
        padding: 12px 32px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
    }

    .save-btn:hover {
        background: #3b82f6;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
    }

    @@media (max-width: 640px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
        .full-width {
            grid-column: span 1;
        }
    }
</style>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                let img = document.getElementById('avatarPreview');
                if (img) {
                    img.src = e.target.result;
                } else {
                    let placeholder = document.getElementById('avatarPlaceholder');
                    if (placeholder) {
                        let newImg = document.createElement('img');
                        newImg.id = 'avatarPreview';
                        newImg.src = e.target.result;
                        placeholder.parentNode.replaceChild(newImg, placeholder);
                    }
                }
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
</body>
</html>
