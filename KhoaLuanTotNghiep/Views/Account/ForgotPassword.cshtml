@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Quên mật khẩu — Delivery Zone</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

    body {
        font-family:'Inter',sans-serif;
        min-height:100vh;
        display:flex;
        background:#0b1120;
        overflow:hidden;
    }

    /* ===== LEFT PANEL ===== */
    .lp-left {
        flex:1;
        background:linear-gradient(135deg,#1a1f3a 0%,#0d1b2a 100%);
        display:flex;
        flex-direction:column;
        justify-content:center;
        padding:60px;
        position:relative;
        overflow:hidden;
    }

    .lp-brand { display:flex; align-items:center; gap:12px; margin-bottom:60px; }
    .lp-brand .icon {
        width:48px;height:48px;border-radius:14px;
        background:linear-gradient(135deg,#3b82f6,#6366f1);
        display:flex;align-items:center;justify-content:center;font-size:22px;
    }
    .lp-brand .name { font-size:20px;font-weight:800;color:#f1f5f9;letter-spacing:-.3px; }

    .lp-tagline { font-size:38px;font-weight:800;color:#f1f5f9;line-height:1.2;max-width:420px;margin-bottom:20px; }
    .lp-tagline span { color:#3b82f6; }
    .lp-sub { font-size:15px;color:#64748b;max-width:380px;line-height:1.7;margin-bottom:48px; }

    /* ===== RIGHT PANEL ===== */
    .lp-right {
        width:480px;
        background:#0f172a;
        display:flex;
        align-items:center;
        justify-content:center;
        padding:48px 44px;
        flex-shrink:0;
        position:relative;
    }

    .login-form { width:100%; }
    .lf-head { margin-bottom:32px; }
    .lf-head h2 { font-size:26px;font-weight:800;color:#f1f5f9;margin-bottom:6px; }
    .lf-head p  { font-size:13px;color:#64748b; }

    /* ERROR/SUCCESS BANNER */
    .lf-banner {
        border-radius:10px;
        padding:12px 16px;
        margin-bottom:20px;
        font-size:13px;
        font-weight:600;
        display:flex;
        align-items:center;
        gap:10px;
    }
    .lf-error {
        background:rgba(239,68,68,.1);
        border:1px solid rgba(239,68,68,.3);
        color:#f87171;
    }
    .lf-success {
        background:rgba(16,185,129,.1);
        border:1px solid rgba(16,185,129,.3);
        color:#10b981;
    }

    /* FORM GROUP */
    .lf-group { margin-bottom:18px; }
    .lf-group label { display:block;font-size:11px;color:#94a3b8;font-weight:700;margin-bottom:7px;text-transform:uppercase;letter-spacing:.05em; }
    .lf-input-wrap { position:relative; }
    .lf-input-wrap i.icon-l { 
        position:absolute;left:14px;top:50%;transform:translateY(-50%);
        color:#475569;font-size:14px;pointer-events:none;
    }
    .lf-input-wrap input {
        width:100%;
        background:#1e293b;
        border:1px solid #334155;
        border-radius:10px;
        padding:12px 14px 12px 42px;
        color:#f1f5f9;
        font-size:14px;
        font-family:'Inter',sans-serif;
        outline:none;
        transition:border-color .2s;
    }
    .lf-input-wrap input:focus { border-color:#3b82f6; }

    /* SUBMIT */
    .lf-submit {
        width:100%;
        padding:13px;
        background:linear-gradient(135deg,#3b82f6,#2563eb);
        border:none;border-radius:10px;
        color:white;font-size:15px;font-weight:700;
        font-family:'Inter',sans-serif;
        cursor:pointer;
        transition:opacity .2s, transform .1s;
        display:flex;align-items:center;justify-content:center;gap:8px;
    }
    .lf-submit:hover { opacity:.9; }
    .lf-submit:active { transform:scale(.98); }

    /* REGISTER */
    .lf-footer { text-align:center;font-size:13px;color:#64748b; margin-top:24px; }
    .lf-footer a { color:#3b82f6;font-weight:700;text-decoration:none; }
    .lf-footer a:hover { text-decoration:underline; }
    </style>
</head>
<body>

<div class="lp-left">
    <div class="lp-brand">
        <div class="icon">🚚</div>
        <div class="name">Delivery Zone</div>
    </div>
    <div class="lp-tagline">Khôi phục <span>quyền truy cập</span></div>
    <div class="lp-sub">Đừng lo lắng! Chỉ cần nhập email đã đăng ký, chúng tôi sẽ gửi mã khôi phục mật khẩu đến bạn ngay lập tức.</div>
</div>

<div class="lp-right">
    <div class="login-form">
        <div class="lf-head">
            <h2>Quên mật khẩu? 🔒</h2>
            <p>Nhập email của bạn để nhận mã khôi phục</p>
        </div>

        @if (ViewBag.Message != null) {
            <div class="lf-banner lf-error">
                <i class="fas fa-circle-exclamation"></i>
                <span>@ViewBag.Message</span>
            </div>
        }

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div class="lf-group">
                <label>Email khôi phục</label>
                <div class="lf-input-wrap">
                    <i class="fas fa-envelope icon-l"></i>
                    <input type="email" name="email" placeholder="john@example.com" required>
                </div>
            </div>

            <button type="submit" class="lf-submit">
                <i class="fas fa-paper-plane"></i> Gửi mã khôi phục
            </button>
        </form>

        <div class="lf-footer">
            Nhớ mật khẩu? <a asp-controller="Account" asp-action="Login"> Quay lại đăng nhập</a>
        </div>
    </div>
</div>

</body>
</html>