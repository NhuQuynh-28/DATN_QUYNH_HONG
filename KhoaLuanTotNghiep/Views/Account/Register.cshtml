@model KhoaLuanTotNghiep.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng ký</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        body {
            background: url('/imager/banner.png') no-repeat center center;
            background-size: cover;
            font-family: Arial;
        }

        .register-box {
            width: 420px;
            margin: 80px auto;
            background: #fff0f5;
            padding: 35px;
            border-radius: 18px;
            text-align: center;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

        h2 {
            margin-bottom: 5px;
            font-weight: bold;
        }

        .input-group {
            position: relative;
            width: 100%;
            margin: 15px 0;
        }

            .input-group i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: gray;
            }

            .input-group input,
            .input-group select {
                width: 100%;
                height: 45px;
                padding-left: 40px;
                padding-right: 10px;
                border-radius: 10px;
                border: 1px solid #ccc;
                box-sizing: border-box; /* QUAN TRỌNG */
                font-size: 15px;
            }

        .btn {
            width: 100%;
            height: 45px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(to right,#ff7b7b,#ff3d2e);
            color: white;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
        }

            .btn:hover {
                opacity: 0.9;
            }
    </style>
</head>
<body>

    <div class="register-box">

        <h2>ĐĂNG KÝ</h2>
        <p>Tạo tài khoản mới</p>

        <form asp-controller="Account" asp-action="Register" method="post">

            <div class="input-group">
                <i class="fa fa-user"></i>
                <input asp-for="Username" placeholder="Username" required />
            </div>

            <div class="input-group">
                <i class="fa fa-lock"></i>
                <input asp-for="Password" type="password" placeholder="Password" required />
            </div>

            <div class="input-group">
                <i class="fa fa-lock"></i>
                <input asp-for="ConfirmPassword" type="password" placeholder="Confirm Password" />
            </div>

            <div class="input-group">
                <i class="fa fa-user-shield"></i>
                <select asp-for="Role">
                    <option value="">Chọn Role</option>
                    <option value="Admin">Admin</option>
                    <option value="Dispatcher">Dispatcher</option>
                    <option value="Driver">Driver</option>
                </select>
            </div>

            <button type="submit" class="btn">ĐĂNG KÝ</button>

            <p>
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login">
                    Đăng nhập
                </a>
            </p>

        </form>

    </div>

</body>
</html>