<div class="report-header" style="margin-bottom: 24px;">
    <h2 style="display:flex; align-items:center; gap:10px; color:#f1f5f9; font-size:24px;">
        <i class="fas fa-layer-group" style="color:#3b82f6"></i>
        Thống kê theo Vùng giao hàng
    </h2>
    <p style="color:#64748b; font-size:14px; margin-top:4px;">Top 10 vùng có lượng đơn hàng cao nhất</p>
</div>

<div class="report-container">
    <div class="table-card">
        <table class="report-table">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Tên Vùng</th>
                    <th>Khu vực</th>
                    <th>Tổng Đơn hàng</th>
                    <th>Tổng Khách hàng</th>
                    <th>Hiệu suất</th>
                </tr>
            </thead>
            <tbody id="zoneTableBody">
                <!-- Data injected here -->
            </tbody>
        </table>
    </div>

    <div class="chart-card">
        <h4 style="margin-bottom:20px; color:#f1f5f9; font-size:16px;">Biểu đồ so sánh Top 10 Vùng</h4>
        <div style="height: 400px; position:relative;">
            <canvas id="zoneBarChart"></canvas>
        </div>
    </div>
</div>

<style>
    .report-container { display: grid; gap: 24px; }
    .table-card, .chart-card {
        background: #1e293b;
        padding: 24px;
        border-radius: 16px;
        border: 1px solid #334155;
    }
    .report-table { width: 100%; border-collapse: collapse; color: #e2e8f0; font-size: 14px; }
    .report-table th { text-align: left; padding: 12px 16px; color: #64748b; border-bottom: 1px solid #334155; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
    .report-table td { padding: 14px 16px; border-bottom: 1px solid #334155; }
    .report-table tr:hover { background: rgba(59,130,246,0.05); }
    .zone-badge { background: rgba(59,130,246,0.1); color: #3b82f6; padding: 4px 8px; border-radius: 6px; font-weight: 700; font-size: 12px; }
</style>

<script>
    (function() {
        function loadZoneReport() {
            fetch("/Report/ZoneReportData")
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById("zoneTableBody");
                    if(tbody) {
                        tbody.innerHTML = data.map((z, i) => `
                            <tr>
                                <td style="color:#64748b; font-weight:700;">${i+1}</td>
                                <td style="font-weight:700; color:#f1f5f9;">${z.zoneName}</td>
                                <td style="color:#94a3b8;">${z.areaName}</td>
                                <td><span class="zone-badge">${z.totalOrders.toLocaleString()} Đơn</span></td>
                                <td>${z.totalCustomers.toLocaleString()} KH</td>
                                <td>
                                    <div style="width:100%; height:6px; background:#334155; border-radius:3px; overflow:hidden;">
                                        <div style="width:${Math.min(100, (z.totalOrders/500)*100)}%; height:100%; background:linear-gradient(to right, #3b82f6, #10b981);"></div>
                                    </div>
                                </td>
                            </tr>
                        `).join('');
                    }
                    renderZoneChart(data);
                });
        }

        function renderZoneChart(data) {
            const ctx = document.getElementById("zoneBarChart");
            if(!ctx) return;

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.map(z => z.zoneName),
                    datasets: [
                        {
                            label: 'Số đơn hàng',
                            data: data.map(z => z.totalOrders),
                            backgroundColor: '#3b82f6',
                            borderRadius: 6
                        },
                        {
                            label: 'Số khách hàng',
                            data: data.map(z => z.totalCustomers),
                            backgroundColor: '#8b5cf6',
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { grid: { color: '#334155' }, ticks: { color: '#94a3b8' } },
                        x: { grid: { display:false }, ticks: { color: '#94a3b8' } }
                    },
                    plugins: {
                        legend: { position: 'top', labels: { color: '#94a3b8' } }
                    }
                }
            });
        }
        loadZoneReport();
    })();
</script>
