<div class="report-header" style="margin-bottom: 24px;">
    <h2 style="display:flex; align-items:center; gap:10px; color:#f1f5f9; font-size:24px;">
        <i class="fas fa-user-friends" style="color:#f59e0b"></i>
        Báo cáo hiệu suất Bưu tá
    </h2>
    <p style="color:#64748b; font-size:14px; margin-top:4px;">Phân tích hiệu quả làm việc của đội ngũ giao hàng</p>
</div>

<div class="report-container">
    <div class="stats-row" style="display:flex; gap:20px; margin-bottom:24px;">
        <div class="stat-card" style="flex:1; background:#1e293b; padding:20px; border-radius:12px; border:1px solid #334155;">
             <div class="stat-icon" style="background:rgba(245,158,11,0.1); color:#f59e0b; width:40px; height:40px; border-radius:8px; display:flex; align-items:center; justify-content:center; margin-bottom:12px;"><i class="fas fa-medal"></i></div>
             <div style="font-size:12px; color:#94a3b8; font-weight:600;">Top Bưu tá</div>
             <div style="font-size:20px; color:#f1f5f9; font-weight:800; margin-top:4px;" id="topDriver">-</div>
        </div>
        <div class="stat-card" style="flex:1; background:#1e293b; padding:20px; border-radius:12px; border:1px solid #334155;">
             <div class="stat-icon" style="background:rgba(34,197,94,0.1); color:#22c55e; width:40px; height:40px; border-radius:8px; display:flex; align-items:center; justify-content:center; margin-bottom:12px;"><i class="fas fa-check-double"></i></div>
             <div style="font-size:12px; color:#94a3b8; font-weight:600;">Trung bình đơn/vùng</div>
             <div style="font-size:20px; color:#f1f5f9; font-weight:800; margin-top:4px;" id="avgOrdersPerZone">-</div>
        </div>
    </div>

    <div class="table-card" style="background:#1e293b; border-radius:16px; border:1px solid #334155; padding:24px;">
        <table class="report-table" style="width:100%; border-collapse:collapse; color:#e2e8f0;">
            <thead>
                <tr style="border-bottom:1px solid #334155;">
                    <th style="padding:12px; text-align:left; color:#64748b; font-size:11px; text-transform:uppercase;">Bưu tá</th>
                    <th style="padding:12px; text-align:left; color:#64748b; font-size:11px; text-transform:uppercase;">Số vùng phụ trách</th>
                    <th style="padding:12px; text-align:left; color:#64748b; font-size:11px; text-transform:uppercase;">Tổng Đơn hàng xử lý</th>
                    <th style="padding:12px; text-align:left; color:#64748b; font-size:11px; text-transform:uppercase;">Trạng thái</th>
                    <th style="padding:12px; text-align:center; color:#64748b; font-size:11px; text-transform:uppercase;">Phân bổ</th>
                </tr>
            </thead>
            <tbody id="driverTableBody">
                <!-- Data injected here -->
            </tbody>
        </table>
    </div>
</div>

<script>
    function loadDriverReport() {
        fetch("/Report/DriverReportData")
            .then(r => r.json())
            .then(data => {
                const tbody = document.getElementById("driverTableBody");
                if(data.length > 0) {
                    document.getElementById("topDriver").innerText = data[0].driverName;
                    const totalOrders = data.reduce((a,b) => a + b.ordersHandled, 0);
                    const totalZones = data.reduce((a,b) => a + b.zonesCount, 0);
                    document.getElementById("avgOrdersPerZone").innerText = totalZones > 0 ? (totalOrders/totalZones).toFixed(1) : "0";
                }

                tbody.innerHTML = data.map(d => `
                    <tr style="border-bottom:1px solid #0f172a55;">
                        <td style="padding:14px 12px; display:flex; align-items:center; gap:10px;">
                            <div style="width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg, #f59e0b22, #d9770622); border:1px solid #f59e0b33; display:flex; align-items:center; justify-content:center; color:#f59e0b; font-weight:700; font-size:11px;">
                                ${d.driverName[0].toUpperCase()}
                            </div>
                            <div>
                                <div style="font-weight:700; color:#f1f5f9;">${d.driverName}</div>
                                <div style="font-size:11px; color:#64748b;">${d.phone}</div>
                            </div>
                        </td>
                        <td style="padding:14px 12px; font-weight:600; color:#94a3b8;">${d.zonesCount} Vùng</td>
                        <td style="padding:14px 12px;">
                            <span style="background:rgba(16,185,129,0.1); color:#10b981; padding:4px 10px; border-radius:6px; font-weight:700; font-size:12px;">
                                ${d.ordersHandled.toLocaleString()} Đơn
                            </span>
                        </td>
                        <td style="padding:14px 12px;">
                            <span style="font-size:11px; color:${d.status === 'DangLam' ? '#22c55e' : '#ef4444'}; font-weight:600;">
                                <i class="fas fa-circle" style="font-size:8px; margin-right:4px;"></i>
                                ${d.status === 'DangLam' ? 'Đang làm' : 'Nghỉ làm'}
                            </span>
                        </td>
                        <td style="padding:14px 12px;">
                            <div style="width:100px; height:6px; background:#334155; border-radius:3px; overflow:hidden; margin:0 auto;">
                                <div style="width:${Math.min(100, (d.zonesCount/10)*100)}%; height:100%; background:#f59e0b;"></div>
                            </div>
                        </td>
                    </tr>
                `).join('');
            });
    }
    loadDriverReport();
</script>
