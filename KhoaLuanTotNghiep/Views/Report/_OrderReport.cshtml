<div class="report-header" style="margin-bottom: 24px;">
    <h2 style="display:flex; align-items:center; gap:10px; color:#f1f5f9; font-size:24px;">
        <i class="fas fa-boxes" style="color:#ef4444"></i>
        Phân tích Đơn hàng & Xu hướng
    </h2>
    <p style="color:#64748b; font-size:14px; margin-top:4px;">Lịch sử đơn hàng thực tế so với mục tiêu dự kiến</p>
</div>

<div class="report-container">
    <div class="chart-main" style="background:#1e293b; border-radius:16px; border:1px solid #334155; padding:24px; margin-bottom:24px;">
        <h4 style="margin-bottom:24px; color:#f1f5f9; font-size:16px; display:flex; align-items:center; gap:8px;">
            <i class="fas fa-chart-area" style="color:#ef4444"></i>
            Biểu đồ xu hướng Đơn hàng
        </h4>
        <div style="height: 450px; position:relative;">
            <canvas id="orderTrendChart"></canvas>
        </div>
    </div>

    <div class="summary-cards" style="display:grid; grid-template-columns: repeat(3, 1fr); gap:20px;">
        <div class="summary-card" style="background:#1e293b; border-radius:12px; border:1px solid #334155; padding:20px;">
            <div style="font-size:12px; color:#64748b; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">Tổng Đơn thực tế</div>
            <div style="font-size:28px; font-weight:800; color:#ef4444;" id="sumReal">0</div>
        </div>
        <div class="summary-card" style="background:#1e293b; border-radius:12px; border:1px solid #334155; padding:20px;">
            <div style="font-size:12px; color:#64748b; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">Tổng Đơn dự kiến</div>
            <div style="font-size:28px; font-weight:800; color:#3b82f6;" id="sumFc">0</div>
        </div>
        <div class="summary-card" style="background:#1e293b; border-radius:12px; border:1px solid #334155; padding:20px;">
            <div style="font-size:12px; color:#64748b; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">Độ lệch trung bình</div>
            <div style="font-size:28px; font-weight:800; color:#10b981;" id="avgAccuracy">0%</div>
        </div>
    </div>
</div>

<script>
    (function() {
        function loadOrderReport() {
            fetch("/Report/OrderReportData")
                .then(r => r.json())
                .then(data => {
                    let sumReal = 0;
                    let sumFc = 0;
                    let totalAccuracy = 0;

                    data.forEach(d => {
                    sumReal += d.orders;
                    sumFc += d.forecast;
                    if(d.forecast > 0) {
                        totalAccuracy += (1 - Math.abs(d.orders - d.forecast) / d.forecast);
                    }
                    });

                    const realEl = document.getElementById("sumReal");
                    const fcEl = document.getElementById("sumFc");
                    const accEl = document.getElementById("avgAccuracy");

                    if(realEl) realEl.innerText = sumReal.toLocaleString();
                    if(fcEl) fcEl.innerText = sumFc.toLocaleString();
                    if(accEl) accEl.innerText = data.length > 0 ? (totalAccuracy / data.length * 100).toFixed(1) + "%" : "0%";

                    renderOrderTrendChart(data);
                });
        }

        function renderOrderTrendChart(data) {
            const ctx = document.getElementById("orderTrendChart");
            if(!ctx) return;

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(d => d.label),
                    datasets: [
                        {
                            label: 'Đơn hàng thực tế',
                            data: data.map(d => d.orders),
                            borderColor: '#ef4444',
                            backgroundColor: 'rgba(239, 68, 68, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#ef4444',
                            pointRadius: 4
                        },
                        {
                            label: 'Mục tiêu dự kiến',
                            data: data.map(d => d.forecast),
                            borderColor: '#3b82f6',
                            borderDash: [5, 5],
                            tension: 0.4,
                            borderWidth: 2,
                            fill: false,
                            pointRadius: 0
                        }
                    ]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { 
                            grid: { color: '#334155', borderDash: [2, 2] },
                            ticks: { color: '#64748b', font: { size: 11 } }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { color: '#64748b', font: { size: 11 } }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            align: 'end',
                            labels: { color: '#f1f5f9', font: { weight: 600 } }
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: '#0f172a',
                            titleColor: '#f1f5f9',
                            borderColor: '#334155',
                            borderWidth: 1
                        }
                    }
                }
            });
        }
        loadOrderReport();
    })();
</script>
